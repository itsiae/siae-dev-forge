.DS_Store
*.swp
*.swo
*~

# DevForge sentinel files (session context, never committed)
.devforge-active-*

# Eval workspace (risultati temporanei skill-creator)
evals/workspace/*
!evals/workspace/.gitkeep

# Eval results (log trigger regression, generati da run-trigger-eval.py)
evals/results/

# Terraform state and cache (infra deployed separately)
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
infra/**/handler.zip

# Eval reports (generati da reporter.py)
evals/reports/*
!evals/reports/.gitkeep

# siae-dev-analytics cache (dati GitHub PR/commit — confidenziali)
.cache/
__pycache__/
*.pyc
.pytest_cache/

# Claude Code session state (locale per utente)
.claude/

# Pytest-hypothesis cache
.hypothesis/
