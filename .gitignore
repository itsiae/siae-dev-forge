.DS_Store
*.swp
*.swo
*~

# DevForge sentinel files (session context, never committed)
.devforge-active-*

# Eval workspace (risultati temporanei skill-creator)
evals/workspace/*
!evals/workspace/.gitkeep

# Eval results (log trigger regression, generati da run-trigger-eval.py)
evals/results/

# Terraform state and cache (infra deployed separately)
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
infra/**/handler.zip

# Eval reports (generati da reporter.py)
evals/reports/*
!evals/reports/.gitkeep

# siae-dev-analytics cache (dati GitHub PR/commit — confidenziali)
.cache/
__pycache__/
*.pyc
.pytest_cache/

# Claude Code session state (locale per utente)
.claude/

# Pytest-hypothesis cache
.hypothesis/

# Coverage.py artifacts (locali a sviluppo skill code-coverage)
.coverage
htmlcov/

# Review evidence cache (per-SHA, deterministically computed by hooks/review-evidence)
.claude/review-evidence/

# DevForge runtime artifacts (commit accidentale via git add -A)
.playwright-mcp/
coverage.xml
.coverage
devforge-analytics.yml
docs/demos/
docs/releases/
reports/

# iCloud sync duplicates
* 2.py
*\ 2.py
*\ 2.md
tests/fixtures/perf_corpus_200k/

