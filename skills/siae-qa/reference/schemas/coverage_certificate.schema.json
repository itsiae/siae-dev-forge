{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://siae.it/devforge/schemas/coverage_certificate.schema.json",
  "title": "CoverageCertificate",
  "description": "Coverage Certificate emesso dalla Phase 4d/5 della skill siae-qa. Persistito in docs/qa/{STORY_ID}/coverage_certificate.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stato",
    "story_id",
    "timestamp",
    "m_final_rows",
    "j5_gap_rows",
    "tc_generated",
    "tc_added_post_j5",
    "coverage_score",
    "gate_1",
    "gate_2",
    "j5_gaps",
    "developer_overrides"
  ],
  "properties": {
    "stato": {
      "type": "string",
      "enum": ["FULL_PASS", "CONDITIONAL_PASS", "FAIL"]
    },
    "story_id": {
      "type": "string",
      "pattern": "^[A-Z]+-[0-9]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "m_final_rows": { "type": "integer", "minimum": 0 },
    "j5_gap_rows": { "type": "integer", "minimum": 0 },
    "tc_generated": { "type": "integer", "minimum": 0 },
    "tc_added_post_j5": { "type": "integer", "minimum": 0 },
    "coverage_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "gate_1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "j1_matrix", "j2_matrix"],
      "properties": {
        "status": { "type": "string", "enum": ["PASS", "FAIL"] },
        "j1_matrix": {
          "type": "object",
          "additionalProperties": false,
          "required": ["percentage", "status", "gap"],
          "properties": {
            "percentage": { "type": "integer", "minimum": 0, "maximum": 100 },
            "status": { "type": "string", "enum": ["PASS", "FAIL"] },
            "gap": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "j2_matrix": {
          "type": "object",
          "additionalProperties": false,
          "required": ["duplicates"],
          "properties": {
            "duplicates": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "gate_2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "rerun_post_j5", "j3", "j4"],
      "properties": {
        "status": { "type": "string", "enum": ["PASS", "FAIL"] },
        "rerun_post_j5": { "type": "boolean" },
        "j3": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "orphan_rows", "orphan_tc"],
          "properties": {
            "status": { "type": "string", "enum": ["PASS", "FAIL"] },
            "orphan_rows": { "type": "array", "items": { "type": "string" } },
            "orphan_tc": { "type": "array", "items": { "type": "string" } }
          }
        },
        "j4": {
          "type": "object",
          "additionalProperties": false,
          "required": ["percentage", "status", "generic_tc"],
          "properties": {
            "percentage": { "type": "integer", "minimum": 0, "maximum": 100 },
            "status": { "type": "string", "enum": ["PASS", "FAIL"] },
            "generic_tc": { "type": "array", "items": { "type": "string" } }
          }
        },
        "j6": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "evaluated_tc", "pass_tc", "fail_tc"],
          "description": "J6 NegativeExecutability Check (R1-R5). Aggiunto in v2.3.0 (ADR-013).",
          "properties": {
            "status": { "type": "string", "enum": ["PASS", "FAIL"] },
            "evaluated_tc": { "type": "integer", "minimum": 0 },
            "pass_tc": { "type": "integer", "minimum": 0 },
            "fail_tc": { "type": "integer", "minimum": 0 },
            "failures": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["tc_id", "matrix_row_id", "rule_violated"],
                "properties": {
                  "tc_id": { "type": "string" },
                  "matrix_row_id": { "type": "string" },
                  "rule_violated": { "type": "string", "enum": ["R1", "R2", "R3", "R4", "R5"] },
                  "routing_suggerito": { "type": "string", "enum": ["automated-only", "eliminated"] }
                }
              }
            }
          }
        }
      }
    },
    "j5_gaps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["high_resolved", "high_open", "medium_open", "low_open", "accepted_gaps"],
      "properties": {
        "high_resolved": { "type": "integer", "minimum": 0 },
        "high_open": { "type": "integer", "minimum": 0 },
        "medium_open": { "type": "integer", "minimum": 0 },
        "low_open": { "type": "integer", "minimum": 0 },
        "accepted_gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["priority", "description"],
            "properties": {
              "priority": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW"] },
              "description": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "developer_overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tc_id", "field", "old_value", "new_value"],
        "properties": {
          "tc_id": { "type": "integer", "minimum": 1 },
          "field": { "type": "string", "enum": ["automazione", "nrt", "j6_bypass"] },
          "old_value": { "type": "string" },
          "new_value": { "type": "string" }
        }
      }
    },
    "eliminated_rows": {
      "type": "array",
      "description": "Righe M_FINAL rimosse perche' classificate executability_class='eliminated' (R4 mirror negativo).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["matrix_row_id", "rule_violated", "reason"],
        "properties": {
          "matrix_row_id": { "type": "string" },
          "rule_violated": { "type": "string", "const": "R4" },
          "reason": { "type": "string", "minLength": 1 },
          "mirror_of_pos_matrix_row_id": { "type": "string" }
        }
      }
    },
    "automated_only_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Numero di righe M_FINAL classificate automated-only (output in automated_only_notes.md, non nel CSV)."
    }
  }
}
