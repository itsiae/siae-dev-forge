{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://siae.it/devforge/schemas/tc_draft.schema.json",
  "title": "TC_DRAFT",
  "description": "Lista di test case step-based prodotti dalla Phase 4b. Ogni TC ha bijection 1:1 con una riga M_FINAL via matrix_row_id.",
  "type": "object",
  "additionalProperties": false,
  "required": ["story_id", "timestamp", "test_cases"],
  "properties": {
    "story_id": {
      "type": "string",
      "pattern": "^[A-Z]+-[0-9]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "test_cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/testCase" }
    }
  },
  "$defs": {
    "testCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "matrix_row_id",
        "title",
        "entity",
        "field",
        "test_type",
        "description",
        "preconditions",
        "steps",
        "automazione",
        "nrt"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "matrix_row_id": {
          "type": "string",
          "minLength": 1,
          "description": "Riferimento alla riga M_FINAL. La coerenza con M_FINAL non e' validata dallo schema ma da J3."
        },
        "title": {
          "type": "string",
          "pattern": "^\\[(POS|NEG|EDGE|ROLE)\\] .+",
          "description": "Titolo con prefisso categoria. Vedi SKILL.md:495."
        },
        "entity": { "type": "string", "minLength": 1 },
        "field": { "type": "string", "minLength": 1 },
        "test_type": {
          "type": "string",
          "enum": ["POS", "NEG", "EDGE", "ROLE"]
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "allOf": [
            { "pattern": "matrix_row_id:" },
            { "pattern": "entity:" },
            { "pattern": "field:" }
          ],
          "description": "Description deve contenere matrix_row_id:, entity:, field: per tracciabilita'."
        },
        "preconditions": { "type": "string", "minLength": 1 },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["step_number", "action", "expected_result"],
            "properties": {
              "step_number": { "type": "integer", "minimum": 1 },
              "action": { "type": "string", "minLength": 1 },
              "expected_result": { "type": "string", "minLength": 1 }
            }
          }
        },
        "automazione": {
          "type": "string",
          "enum": ["Y", "N"],
          "default": "N"
        },
        "nrt": {
          "type": "string",
          "enum": ["Y", "N"],
          "default": "Y"
        },
        "data": {
          "type": "string",
          "description": "Dati di test opzionali."
        }
      }
    }
  }
}
