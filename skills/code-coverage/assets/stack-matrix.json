      "vitest_environment": "node",
      "runner_command": "npx vitest run",
      "coverage_command": "npx vitest run --coverage --coverage.reporter=json-summary",
      "coverage_provider": "@vitest/coverage-v8",
      "coverage_report_format": "vitest",
      "coverage_report_path": "coverage/coverage-summary.json",
      "install_dev_deps": ["vitest", "@vitest/coverage-v8", "@aws-sdk/client-dynamodb", "@aws-sdk/client-s3"],
