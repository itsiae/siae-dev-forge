      "activation_note": "Conditions (a)→(b)→(c/d) evaluated in order. First match wins. SKILL.md Principle 4 is the single authoritative definition — do not re-evaluate from this file.",
      "test_framework": "jest",
      "runner_command": "npx jest",
      "coverage_command": "npx jest --coverage --coverageReporters=json-summary",
      "coverage_provider": "@jest/coverage",
      "coverage_report_format": "jest",
      "coverage_report_path": "coverage/coverage-summary.json",
      "install_dev_deps": ["jest", "@types/jest", "ts-jest"],
      "config_file": "jest.config.ts",
      "template": "jest.template.ts"
    },
    "python": {
      "detection_files": ["requirements.txt", "pyproject.toml", "setup.py", "setup.cfg", "Pipfile", "poetry.lock"],
