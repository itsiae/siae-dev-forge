      "coverage_provider": "@vitest/coverage-v8",
      "coverage_report_format": "vitest",
      "coverage_report_path": "coverage/coverage-summary.json",
      "install_dev_deps": ["vitest", "@vitest/coverage-v8"],
      "config_file": "vitest.config.ts",
      "template": "vitest.template.ts",
      "min_node_version": "18"
    },
    "javascript_node": {
