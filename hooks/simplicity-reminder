#!/usr/bin/env bash
# simplicity-reminder — UserPromptSubmit hook
# ─────────────────────────────────────────────────────────────────
# Inietta il principio ingegneristico di semplicita del codice (KISS/YAGNI/AHA)
# ogni 5 prompt, come nudge anti-over-engineering.
#
# Contatore GLOBALE cumulativo (NON per-sessione): scelta dettata dal premortem.
# Uno slot per-sessione si auto-annullerebbe con 2+ sessioni concorrenti nella
# stessa repo (session_id alterna -> reset ad ogni prompt -> reminder mai emesso).
# Il contatore globale e' anche piu' semplice: non legge stdin, non parsa session_id.
#
# Fail-safe ASSOLUTO: non blocca MAI il prompt — ogni errore -> exit 0 silenzioso.
# NESSUN set -e/-u/pipefail: un'operazione fallita non deve propagare exit != 0.
# Non legge stdin (nessun rischio di hang in attesa dell'input dell'evento).
# Design: docs/plans/2026-06-25-simplicity-reminder-hook-design.md
# ─────────────────────────────────────────────────────────────────
export DEVFORGE_CURRENT_HOOK="simplicity-reminder"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" 2>/dev/null && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." 2>/dev/null && pwd)"
# logger opzionale (sanitize JSON + telemetria); degrada se assente
source "${PLUGIN_ROOT}/lib/logger.sh" 2>/dev/null || true

INTERVAL=5
STATE_DIR="${HOME}/.claude"
COUNTER_FILE="${STATE_DIR}/.devforge-simplicity-counter"

# --- contatore globale cumulativo (scrittura atomica) ---
mkdir -p "$STATE_DIR" 2>/dev/null || true
prev_n="$(cat "$COUNTER_FILE" 2>/dev/null || true)"
case "$prev_n" in ''|*[!0-9]*) prev_n=0 ;; esac
n=$((prev_n + 1))
printf '%s' "$n" > "${COUNTER_FILE}.tmp" 2>/dev/null && mv "${COUNTER_FILE}.tmp" "$COUNTER_FILE" 2>/dev/null || true

# --- inietta solo ogni INTERVAL prompt ---
[ "$((n % INTERVAL))" -eq 0 ] || exit 0

# Principio fondato sulla letteratura di software design (KISS / YAGNI / AHA).
PRINCIPLE="DevForge - Semplicita del codice: KISS, fai la cosa piu semplice che funziona; YAGNI, implementa solo cio che serve ORA, non cio che forse servira poi; evita astrazioni premature (AHA: meglio un po' di duplicazione che l'astrazione sbagliata). Meno codice = meno bug; la complessita si aggiunge solo con una ragione concreta e dimostrata."

# escape JSON: helper centralizzato se disponibile, altrimenti fallback minimale
if command -v devforge_sanitize_json_str >/dev/null 2>&1; then
    PRINCIPLE_ESC="$(devforge_sanitize_json_str "$PRINCIPLE")"
else
    PRINCIPLE_ESC="$(printf '%s' "$PRINCIPLE" | sed 's/\\/\\\\/g; s/"/\\"/g')"
fi
CONTEXT="[DevForge Reminder - Semplicita del codice (KISS/YAGNI)]\\n${PRINCIPLE_ESC}"

# telemetria best-effort
devforge_log "simplicity_reminder_emitted" "success" "{\"n\":${n}}" 2>/dev/null || true

cat <<EOF
{
  "additional_context": "${CONTEXT}",
  "hookSpecificOutput": {
    "hookEventName": "UserPromptSubmit",
    "additionalContext": "${CONTEXT}"
  }
}
EOF
exit 0
