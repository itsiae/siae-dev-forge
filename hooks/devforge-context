#!/usr/bin/env bash
# devforge-context — unified context injection with budget + diff-based dedup
# ─────────────────────────────────────────────────────────────────
# Replaces: user-prompt-context + devforge-reinject + devforge-context-always
# batch-reset remains separate (different responsibility).
# ─────────────────────────────────────────────────────────────────

set -euo pipefail
export DEVFORGE_CURRENT_HOOK="devforge-context"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${PLUGIN_ROOT}/lib/logger.sh" 2>/dev/null || true
devforge_init_session 2>/dev/null || true

STATE_DIR="${HOME}/.claude"
HASH_FILE="${STATE_DIR}/.devforge-last-injection-hash"
MAX_BYTES=2048

# Compute state hash: skills invoked + branch + gate violations + tdd phase
#                   + latest design doc mtime (so design revisions trigger re-emit).
compute_state_hash() {
    local skills branch tdd_phase gate_violation mtime now design_doc design_mtime
    skills=$(cat "${STATE_DIR}/.devforge-session-skills" 2>/dev/null || echo "")
    branch=$(git branch --show-current 2>/dev/null || echo "detached")
    tdd_phase=$(cat "${STATE_DIR}/.devforge-tdd-state" 2>/dev/null | cut -d'|' -f1 || echo "")
    # Recent block (<60s): check stop-block-count mtime
    gate_violation=0
    if [ -f "${STATE_DIR}/.devforge-stop-block-count" ]; then
        mtime=$(stat -f%m "${STATE_DIR}/.devforge-stop-block-count" 2>/dev/null || stat -c%Y "${STATE_DIR}/.devforge-stop-block-count" 2>/dev/null || echo 0)
        now=$(date +%s)
        [ $((now - mtime)) -lt 60 ] && gate_violation=1
    fi
    # Design doc mtime: edits to design doc must re-trigger context (baseline changes).
    design_mtime=0
    if [ -d docs/plans ]; then
        design_doc=$(ls -1t docs/plans/*-design.md 2>/dev/null | head -1)
        if [ -n "$design_doc" ] && [ -f "$design_doc" ]; then
            design_mtime=$(stat -f%m "$design_doc" 2>/dev/null || stat -c%Y "$design_doc" 2>/dev/null || echo 0)
        fi
    fi
    printf '%s|%s|%s|%s|%s' "$skills" "$branch" "$tdd_phase" "$gate_violation" "$design_mtime" | shasum | cut -d' ' -f1
}

CURRENT_HASH=$(compute_state_hash)
LAST_HASH=$(cat "$HASH_FILE" 2>/dev/null || echo "")

# Diff-based: skip if state unchanged
if [ "$CURRENT_HASH" = "$LAST_HASH" ]; then
    exit 0
fi

# Task transition (PR #2 ADR-001): if the current task_id differs from the
# last one we observed, run evidence copy-forward. This is the only path
# that realises the mitigation documented in the design doc for
# "task_id cambia mid-task → gate reset".
if source "${PLUGIN_ROOT}/lib/task-id.sh" 2>/dev/null; then
    _CURR_TASK_ID=$(devforge_compute_task_id 2>/dev/null || echo "")
    _LAST_TASK_ID_FILE="${STATE_DIR}/.devforge-last-task-id"
    _LAST_TASK_ID=$(cat "$_LAST_TASK_ID_FILE" 2>/dev/null || echo "")
    if [ -n "$_CURR_TASK_ID" ] && [ -n "$_LAST_TASK_ID" ] && [ "$_CURR_TASK_ID" != "$_LAST_TASK_ID" ]; then
        devforge_task_id_transition "$_LAST_TASK_ID" "$_CURR_TASK_ID" 2>/dev/null || true
        devforge_log "task_id_transition" "info" \
            "{\"from\":\"${_LAST_TASK_ID}\",\"to\":\"${_CURR_TASK_ID}\"}" 2>/dev/null || true
    fi
    if [ -n "$_CURR_TASK_ID" ]; then
        echo "$_CURR_TASK_ID" > "${_LAST_TASK_ID_FILE}.tmp" \
            && mv "${_LAST_TASK_ID_FILE}.tmp" "$_LAST_TASK_ID_FILE"
    fi
fi

# Determine tier (top-level: no 'local'; use plain vars)
TIER="none"
TAG_OPEN=""
TAG_CLOSE=""
if [ -f "${STATE_DIR}/.devforge-stop-block-count" ]; then
    SB_MTIME=$(stat -f%m "${STATE_DIR}/.devforge-stop-block-count" 2>/dev/null || stat -c%Y "${STATE_DIR}/.devforge-stop-block-count" 2>/dev/null || echo 0)
    SB_NOW=$(date +%s)
    if [ $((SB_NOW - SB_MTIME)) -lt 60 ]; then
        TIER="important"
        TAG_OPEN="<IMPORTANT>"
        TAG_CLOSE="</IMPORTANT>"
    fi
fi
# Tier 'extreme' riserved for active hard-gate; in PR #1 we don't escalate here.

# Build compact payload (max $MAX_BYTES bytes)
PAYLOAD=""
# 1. Git state (1 line)
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    GIT_BRANCH=$(git branch --show-current 2>/dev/null || echo "detached")
    GIT_LAST=$(git log --oneline -1 2>/dev/null || echo "")
    PAYLOAD="${PAYLOAD}Git: branch=${GIT_BRANCH} | ${GIT_LAST}\n"
fi
# 2. Session stats (1 line)
SKILLS_COUNT=$(cat "${STATE_DIR}/.devforge-session-skills" 2>/dev/null | tr ',' '\n' | grep -c . || true)
SKILLS_COUNT=${SKILLS_COUNT:-0}
COMMITS_COUNT=$(cat "${STATE_DIR}/.devforge-session-commits" 2>/dev/null || echo 0)
PAYLOAD="${PAYLOAD}Session: skills=${SKILLS_COUNT} | commits=${COMMITS_COUNT}\n"
# 3. Backbone 1-liner (compact)
PAYLOAD="${PAYLOAD}Backbone: brainstorm→plan→tdd→verification. If 1% applicable, invoke skill.\n"

# Trim to budget
PAYLOAD=$(printf '%.*s' "$MAX_BYTES" "$PAYLOAD")

# Use centralized JSON escape helper (lib/logger.sh :: devforge_sanitize_json_str).
# Handles \, ", \n, \r, \t, and strips control chars 0x00-0x1F.
PAYLOAD_ESCAPED=$(devforge_sanitize_json_str "$PAYLOAD")

# Final context with optional tier tag
if [ -n "$TAG_OPEN" ]; then
    CONTEXT="${TAG_OPEN}\\n[DevForge Context]\\n${PAYLOAD_ESCAPED}${TAG_CLOSE}"
else
    CONTEXT="[DevForge Context]\\n${PAYLOAD_ESCAPED}"
fi

# Telemetry
SIZE=$(printf '%s' "$CONTEXT" | wc -c | tr -d ' ')
devforge_log "prompt_injection_emitted" "success" "{\"size_bytes\":${SIZE},\"tier\":\"${TIER}\"}" 2>/dev/null || true

# Emit context JSON to stdout. Store hash ONLY on successful emission — if cat
# fails (pipe broken, disk full), the hash is NOT updated so the next invocation
# retries the emission instead of assuming it already happened.
if cat <<EOF
{
  "additional_context": "${CONTEXT}",
  "hookSpecificOutput": {
    "hookEventName": "UserPromptSubmit",
    "additionalContext": "${CONTEXT}"
  }
}
EOF
then
    echo "$CURRENT_HASH" > "${HASH_FILE}.tmp" && mv "${HASH_FILE}.tmp" "$HASH_FILE"
fi
exit 0
