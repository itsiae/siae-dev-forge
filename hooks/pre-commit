#!/usr/bin/env bash
# PreToolUse hook: BLOCCA git commit senza siae-git-workflow + quality gate
# ─────────────────────────────────────────────────────────────────
# Hook:     pre-commit
# Evento:   PreToolUse
# Matcher:  Bash
# Timeout:  10s — Check branch + design doc rapido
# Formato:  decision:"block" se siae-git-workflow non invocata (HARD GATE)
#           additional_context per quality gate (se skill presente)
# History:  v1.3.0 ALLOW+warn → v1.4.0 BLOCK per git commit (determinismo SDLC)
# ─────────────────────────────────────────────────────────────────

set -euo pipefail
export DEVFORGE_CURRENT_HOOK="pre-commit"

# Read tool input from stdin (JSON with tool_name and tool_input)
HOOK_INPUT=$(cat)

# Extract the command from the tool input (jq handles escaped quotes in paths with spaces)
if command -v jq >/dev/null 2>&1; then
    TOOL_COMMAND=$(echo "$HOOK_INPUT" | jq -r '.command // .tool_input.command // empty' 2>/dev/null || true)
else
    TOOL_COMMAND=$(echo "$HOOK_INPUT" | grep -o '"command"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"command"[[:space:]]*:[[:space:]]*"//;s/"$//' || true)
fi

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Source activity logger + token parser (ADR-006 rewrite) + task-id
source "${PLUGIN_ROOT}/lib/logger.sh"
source "${PLUGIN_ROOT}/lib/cmd-parser.sh" 2>/dev/null || true
source "${PLUGIN_ROOT}/lib/task-id.sh" 2>/dev/null || true
source "${PLUGIN_ROOT}/lib/block-explainer.sh" 2>/dev/null || true
devforge_init_session 2>/dev/null || true

# --- Session-aware enforcement + catalog re-injection ---
SESSION_SKILLS_FILE="${HOME}/.claude/.devforge-session-skills"
SESSION_SKILLS=$(cat "$SESSION_SKILLS_FILE" 2>/dev/null || echo "")

# Tool counter for periodic catalog re-injection
TOOL_COUNTER_FILE="${HOME}/.claude/.devforge-tool-counter"
COUNTER=$(cat "$TOOL_COUNTER_FILE" 2>/dev/null || echo "0")
COUNTER=$((COUNTER + 1))
echo "$COUNTER" > "$TOOL_COUNTER_FILE"

# Generate catalog re-injection every N Bash calls
CATALOG_REINJECT=""
REINJECT_INTERVAL=20
if [ $((COUNTER % REINJECT_INTERVAL)) -eq 0 ]; then
    if command -v node >/dev/null 2>&1; then
        RAW_CATALOG=$(node "${PLUGIN_ROOT}/lib/skills-core.js" "${PLUGIN_ROOT}" 2>/dev/null || echo "")
        if [ -n "$RAW_CATALOG" ]; then
            CATALOG_REINJECT="$RAW_CATALOG"
        fi
    fi
fi
# --- End session-aware block ---

# JSON escaping is centralized in lib/logger.sh :: devforge_sanitize_json_str.
# Local alias for readability in this file.
escape_for_json() { devforge_sanitize_json_str "$1"; }

# Route to appropriate check based on command. Use the token parser when
# available — it eliminates false positives on inputs like
# `git log | grep commit`, `echo "git commit"`, and `python run_git_commit.py`.
# Fallback to the legacy regex only if cmd-parser failed to source.
if command -v devforge_cmd_has_subcommand >/dev/null 2>&1; then
    # Segment-aware: matcha anche dentro comandi composti (cd X && git commit)
    # — il match first-segment-only veniva bypassato (root cause PR #311).
    if devforge_cmd_has_subcommand "$TOOL_COMMAND" git commit; then
        IS_GIT_COMMIT=1
    else
        IS_GIT_COMMIT=0
    fi
    if devforge_cmd_has_subcommand "$TOOL_COMMAND" git checkout \
       || devforge_cmd_has_subcommand "$TOOL_COMMAND" git switch; then
        IS_GIT_CHECKOUT=1
    else
        IS_GIT_CHECKOUT=0
    fi
elif command -v devforge_cmd_matches >/dev/null 2>&1; then
    TC_FIRST=$(devforge_first_token "$TOOL_COMMAND")
    TC_SECOND=$(devforge_second_token "$TOOL_COMMAND")
    if [ "$TC_FIRST" = "git" ] && [ "$TC_SECOND" = "commit" ]; then
        IS_GIT_COMMIT=1
    else
        IS_GIT_COMMIT=0
    fi
    if [ "$TC_FIRST" = "git" ] && { [ "$TC_SECOND" = "checkout" ] || [ "$TC_SECOND" = "switch" ]; }; then
        IS_GIT_CHECKOUT=1
    else
        IS_GIT_CHECKOUT=0
    fi
else
    if [[ "$TOOL_COMMAND" =~ ^[[:space:]]*git[[:space:]]+commit ]]; then
        IS_GIT_COMMIT=1
    else
        IS_GIT_COMMIT=0
    fi
    if [[ "$TOOL_COMMAND" =~ git[[:space:]]+(checkout[[:space:]]+-b|switch[[:space:]]+-c) ]]; then
        IS_GIT_CHECKOUT=1
    else
        IS_GIT_CHECKOUT=0
    fi
fi

if [ "$IS_GIT_COMMIT" = "1" ]; then
    # Check if siae-git-workflow was invoked this session — HARD GATE
    if ! echo "$SESSION_SKILLS" | grep -qF "siae-git-workflow"; then
        SAFE_TOOL_COMMAND=$(devforge_sanitize_json_str "$TOOL_COMMAND")
        devforge_log "pre_commit" "blocked" "{\"command\":\"${SAFE_TOOL_COMMAND}\",\"skill_missing\":\"siae-git-workflow\"}"
        _PC_EXPL=""
        if command -v devforge_block_explainer >/dev/null 2>&1; then
            _PC_EXPL=$(devforge_block_explainer siae-git-workflow 2>/dev/null || true)
            [ -n "$_PC_EXPL" ] && _PC_EXPL=" ${_PC_EXPL}"
        fi
        cat <<BLOCK_EOF
{
  "decision": "block",
  "reason": "DevForge Git Gate — BLOCCATO. NON hai invocato siae-git-workflow in questa sessione. La skill stabilisce naming convention, conventional commits, e pre-flight checks. Invoca siae-git-workflow PRIMA di procedere con il commit: Skill tool -> siae-devforge:siae-git-workflow. Dopo aver invocato la skill, potrai procedere.${_PC_EXPL}"
}
BLOCK_EOF
        exit 0
    fi

    # Task-scope shadow-log (PR #2 ADR-001): session is still source of
    # truth here because commits aggregate work across many gates — we
    # just record divergence for post-deploy analysis.
    _PC_USE_SESSION="${DEVFORGE_USE_SESSION_SCOPE:-0}"
    if [ "$_PC_USE_SESSION" != "1" ] && command -v devforge_compute_task_id >/dev/null 2>&1; then
        _PC_TASK_ID=$(devforge_compute_task_id 2>/dev/null || echo "")
        if [ -n "$_PC_TASK_ID" ]; then
            _PC_INVOKED="${HOME}/.claude/.devforge-task-skills/${_PC_TASK_ID}/skills_invoked"
            _PC_TASK_OK=0
            if [ -f "$_PC_INVOKED" ] && grep -qxF "siae-git-workflow" "$_PC_INVOKED" 2>/dev/null; then
                _PC_TASK_OK=1
            fi
            # session_ok = 1 here by construction (we're past the gate if)
            if [ "$_PC_TASK_OK" = "0" ]; then
                devforge_log "pre_commit_task_divergence" "info" \
                    "{\"task_id\":\"${_PC_TASK_ID}\",\"session\":1,\"task\":0}" 2>/dev/null || true
            fi
        fi
    fi
    SKILL_REMINDER=""

    # Coverage gate applicability: applies ONLY when the commit introduces or
    # modifies production source code in a coverage-measured language. A
    # config-only or test-only commit (e.g. editing .mcp.json plus a guardrail
    # test) has no production Python/TS/Java/Go to cover, so the 70% gate and
    # the force-run together create a catch-22 (force-run demands fresh
    # coverage; any measurement is 0% because there is no source to cover; the
    # gate then rejects 0%). Skip both when no production source is staged.
    STAGED_SRC=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null \
        | grep -iE '\.(py|ts|tsx|js|jsx|java|go)$' \
        | grep -vE '(^|/)tests?/|(^|/)__tests__/|\.(spec|test)\.[tj]sx?$|(^|/)test_[^/]*\.py$|_test\.py$|_test\.go$|Test\.java$|IT\.java$|(^|/)conftest\.py$' \
        || true)
    COVERAGE_APPLIES=1
    if [ -z "$STAGED_SRC" ]; then
        COVERAGE_APPLIES=0
        devforge_log "coverage_gate" "skipped_no_source" "{\"reason\":\"no production source in staged diff\"}" 2>/dev/null || true
    fi

    # Coverage Gate — HARD BLOCK if coverage below threshold
    COVERAGE_FILE="${HOME}/.claude/.devforge-last-coverage"
    if [ "$COVERAGE_APPLIES" = "1" ] && [ -f "$COVERAGE_FILE" ]; then
        COVERAGE_DATA=$(cat "$COVERAGE_FILE" 2>/dev/null || echo "")
        COVERAGE_PCT=$(echo "$COVERAGE_DATA" | cut -d'|' -f1)
        COVERAGE_TS=$(echo "$COVERAGE_DATA" | cut -d'|' -f2)

        # Validate coverage is numeric before comparing
        if [ -n "$COVERAGE_PCT" ] && echo "$COVERAGE_PCT" | grep -qE '^[0-9]+(\.[0-9]+)?$'; then
            # Determine threshold: 70% for all branches
            # P1 modules require 80% — enforced by code-coverage skill (skills/code-coverage/assets/priority-rules.json)
            CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || echo "")
            THRESHOLD=70

            # Integer comparison (truncate decimals)
            COVERAGE_INT=${COVERAGE_PCT%%.*}
            if [ "$COVERAGE_INT" -lt "$THRESHOLD" ] 2>/dev/null; then
                # Check coverage is fresh (< 30 min old)
                NOW_S=$(date +%s)
                COVERAGE_AGE=$(( NOW_S - ${COVERAGE_TS:-0} ))
                if [ "$COVERAGE_AGE" -lt 1800 ]; then
                    SAFE_BRANCH=$(devforge_sanitize_json_str "$CURRENT_BRANCH")
                    devforge_log "coverage_gate" "blocked" "{\"coverage\":${COVERAGE_PCT},\"threshold\":${THRESHOLD},\"branch\":\"${SAFE_BRANCH}\"}"
                    cat <<COV_BLOCK_EOF
{
  "decision": "block",
  "reason": "DevForge Coverage Gate — BLOCCATO. Coverage attuale: ${COVERAGE_PCT}% (soglia minima: ${THRESHOLD}%). Aggiungi test per raggiungere almeno ${THRESHOLD}% di copertura prima di committare. Branch: ${CURRENT_BRANCH}."
}
COV_BLOCK_EOF
                    exit 0
                fi
            fi
        fi
    fi

    # --- Coverage-Force-Run (PR #2 ADR-008) ---
    # If the commit contains test files but the cached coverage data is
    # stale (> 30 minutes) or missing, block and ask the developer to
    # actually run the test suite. This prevents the coverage gate from
    # passing silently just because tests were not executed.
    STAGED_TEST_HITS=$(git diff --cached --name-only 2>/dev/null \
        | grep -E "\.(spec|test)\.|Test\.java$|IT\.java$|test_.*\.py$|_test\.go$" || true)
    if [ "$COVERAGE_APPLIES" = "1" ] && [ -n "$STAGED_TEST_HITS" ]; then
        COVERAGE_AGE=9999
        if [ -f "$COVERAGE_FILE" ]; then
            COVERAGE_TS=$(cut -d'|' -f2 "$COVERAGE_FILE" 2>/dev/null || echo 0)
            NOW_S=$(date +%s)
            COVERAGE_AGE=$(( NOW_S - ${COVERAGE_TS:-0} ))
        fi
        if [ "$COVERAGE_AGE" -gt 1800 ]; then
            devforge_log "coverage_force_run" "blocked" "{\"age_s\":${COVERAGE_AGE}}"
            cat <<COV_FORCE_EOF
{
  "decision": "block",
  "reason": "DevForge Coverage Force-Run — BLOCCATO. Stai committando file di test ma i dati di coverage sono stale (${COVERAGE_AGE}s > 1800s) o assenti. Esegui la test suite con coverage (mvn test, npm test -- --coverage, pytest --cov) prima del commit. Questo evita che la gate di coverage passi solo perche' i test non sono stati eseguiti."
}
COV_FORCE_EOF
            exit 0
        fi
    fi

    : # proceed to quality gate below
elif [ "$IS_GIT_CHECKOUT" = "1" ]; then
    # Branch check: warn if feature branch without design doc
    BRANCH_NAME=$(echo "$TOOL_COMMAND" | grep -oE '[a-zA-Z0-9/_.-]+$' || true)
    BRANCH_JIRA=$(git branch --show-current 2>/dev/null | grep -oE '(feature|bugfix|hotfix)/[A-Z]+-[0-9]+' | grep -oE '[A-Z]+-[0-9]+' || echo "")
    JIRA_ID="${BRANCH_JIRA:-$(echo "$BRANCH_NAME" | grep -oE '[A-Z]+-[0-9]+' | head -1 || true)}"

    if [ -z "$JIRA_ID" ]; then
        # No JIRA ID — skip silently
        echo '{}'
        exit 0
    fi

    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
    PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
    PLANS_DIR="${PLUGIN_ROOT}/docs/plans"

    if [ -d "$PLANS_DIR" ] && ls "$PLANS_DIR"/*"${JIRA_ID}"*design* 2>/dev/null | head -1 | grep -q .; then
        # Design doc found — proceed silently
        echo '{}'
        exit 0
    fi

    # Design doc NOT found — inject warning
    WARNING_MSG="Stai creando il branch '${BRANCH_NAME}'. Non esiste un design doc in docs/plans/ per ${JIRA_ID}. Hai eseguito siae-brainstorming prima di iniziare il codice? Procedo comunque con git checkout, ma il design e' consigliato prima dell'implementazione."

    warning_escaped=$(escape_for_json "$WARNING_MSG")
    branch_context="<IMPORTANT>\nDevForge Branch Check: ${warning_escaped}\n</IMPORTANT>"

    cat <<EOF
{
  "additional_context": "${branch_context}",
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "additionalContext": "${branch_context}"
  }
}
EOF
    exit 0
else
    # Non-git commands: inject catalog re-injection if counter hit
    if [ -n "$CATALOG_REINJECT" ]; then
        catalog_reinject_escaped=$(escape_for_json "$CATALOG_REINJECT")
        reinject_context="<IMPORTANT>\\nDevForge Skill Catalog (reminder periodico — invoca le skill rilevanti):\\n\\n${catalog_reinject_escaped}\\n</IMPORTANT>"

        cat <<EOF
{
  "additional_context": "${reinject_context}",
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "additionalContext": "${reinject_context}"
  }
}
EOF
        exit 0
    fi
    echo '{}'
    exit 0
fi

# Log quality gate activation
SAFE_TOOL_COMMAND=$(devforge_sanitize_json_str "$TOOL_COMMAND")
devforge_log "quality_gate" "success" "{\"check_name\":\"pre_commit_activated\",\"command\":\"${SAFE_TOOL_COMMAND}\"}"

# Pre-commit quality gate instructions (embedded directly)
read -r -d '' PRECOMMIT_INSTRUCTIONS << 'INSTRUCTIONS_EOF' || true
# DevForge Pre-Commit Quality Gate

Prima di procedere con il commit, DEVI eseguire TUTTE le verifiche seguenti sui file staged.
Se una qualsiasi verifica fallisce, BLOCCA il commit e mostra la pre-flight card appropriata
secondo il DevForge Visual Design System.

---

## 1. Secret Scan (CRITICO)

Controlla TUTTI i file staged per i seguenti pattern. Se trovi una corrispondenza,
mostra la pre-flight card CRITICO e BLOCCA il commit.

Pattern regex da intercettare:
- **AWS Keys**: `AKIA[0-9A-Z]{16}`, `aws_secret_access_key\s*=\s*.+`
- **Password**: `[pP]assword\s*[:=]\s*["'][^"']+["']`
- **API Key**: `[aA][pP][iI][-_]?[kK][eE][yY]\s*[:=]\s*["'][^"']+["']`
- **Token**: `[tT]oken\s*[:=]\s*["'][^"']+["']`
- **Secret generico**: `[sS]ecret\s*[:=]\s*["'][^"']+["']`
- **Env hardcoded**: `process\.env\.\w+\s*\|\|\s*["'][^"']+["']`
- **Private key**: `-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----`
- **Connection string con password**: `(mysql|postgres|mongodb)://[^:]+:[^@]+@`

File ad alto rischio da verificare sempre:
- `.env`, `.env.*` — mai in git
- `.aws/credentials` — mai in git
- `application-*.yml` con campi password/secret
- Qualsiasi file con estensione `.pem`, `.key`, `.p12`, `.pfx`

Se trovi un secret:

| 🚨 CRITICO (irreversibile) — 🔨 DevForge · pre-commit-quality-gate |
|:---|
| ⚠️ COMMIT BLOCCATO — SECRET RILEVATO |
| 🔍 Pattern: `[tipo di secret rilevato]` |
| 1. 🚫 Azione: Rimuovi il secret prima di procedere |
| 📦 File: `[percorso del file]` |
| 💡 Perche': Credenziali nei sorgenti sono una violazione critica di sicurezza |
| 🚫 Se non risolto: Le credenziali finiscono nel repository e sono compromesse |

---

## 2. Naming Convention Check (MEDIO)

Verifica che i file staged rispettino le convenzioni SIAE:

- **File sorgente**: `kebab-case` (es. `user-service.ts`, `payment-handler.ts`)
  - Eccezioni: file Python usano `snake_case` (es. `user_service.py`)
  - Eccezioni: file Terraform di base usano `_prefix` (es. `_input.tf`, `_local.tf`)
  - Eccezioni: classi Java seguono `PascalCase` (es. `UserService.java`)
- **Classi / Tipi**: `PascalCase` (es. `UserService`, `PaymentDto`)
- **Costanti**: `UPPER_SNAKE_CASE` (es. `MAX_RETRY_COUNT`)
- **Directory**: `kebab-case` (es. `diritti-api/`, `common-networking/`)

Se trovi violazioni, elencale con una pre-flight card MEDIO prima di procedere.

---

## 3. Test Check (MEDIO)

Per ogni file sorgente modificato nello staging, verifica che esista un file di test corrispondente:

| Stack | File sorgente | File test atteso |
|-------|--------------|-----------------|
| TypeScript | `src/user-service.ts` | `test/user-service.spec.ts` o `__tests__/user-service.spec.ts` |
| Java | `src/.../UserService.java` | `test/.../UserServiceTest.java` o `UserServiceIT.java` |
| Python | `src/user_service.py` | `tests/test_user_service.py` |

Se mancano test per file sorgente modificati, avvisa l'utente con una pre-flight card MEDIO.
Non bloccare il commit, ma segnala chiaramente i file senza copertura test.

---

## 4. File Size Check (ALTO)

Controlla che nessun file staged superi 1 MB (1048576 byte).

File grandi nel repository causano problemi di performance e spesso indicano
che un artefatto binario e' stato aggiunto per errore.

Se trovi file > 1 MB:

| 🔴 ALTO (difficile da annullare) — 🔨 DevForge · pre-commit-quality-gate |
|:---|
| ⚠️ OPERAZIONE DIFFICILE DA ANNULLARE |
| 📦 File: `[percorso del file] ([dimensione] MB)` |
| 1. 🚫 Azione: File staged supera 1 MB |
| 💡 Perche': File grandi degradano performance del repository |
| 🚫 Se NO: Il file grande viene committato nel repository |

---

## 5. Lint Check (MEDIO)

Se il progetto ha un linter configurato, eseguilo sui file staged:

| Linter | File di config | Comando |
|--------|---------------|---------|
| **ESLint** | `.eslintrc.*`, `eslint.config.*` | `npx eslint [files]` |
| **Checkstyle** | `checkstyle.xml`, nel POM | `mvn checkstyle:check` |
| **Flake8** | `.flake8`, `setup.cfg` | `flake8 [files]` |
| **tflint** | `.tflint.hcl` | `tflint` |
| **Prettier** | `.prettierrc*` | `npx prettier --check [files]` |
| **Shellcheck** | `.shellcheckrc` | `shellcheck [files.sh]` |

Verifica se il file di configurazione esiste nella root del progetto E se il binary del linter
e' disponibile nel PATH (usa `which <linter>` o `command -v <linter>`).

Se entrambe le condizioni sono vere, esegui il linter. Se rileva errori, mostra una pre-flight
card MEDIO con il riepilogo degli errori prima di procedere con il commit.

In tutti gli altri casi (config assente, binary non installato, errore di rete, timeout),
salta silenziosamente con SKIP — non bloccare mai il commit per tool assenti.

---

## Riepilogo Quality Gate

Dopo aver completato tutte le verifiche, mostra un riepilogo compatto come markdown table.

Usa queste emoji per ogni esito:
- PASS  → ✅
- FAIL  → ❌
- WARN  → ⚠️
- SKIP  → ⏭️

Per l'esito complessivo:
- Tutti i check bloccanti PASS → 🟢 COMMIT CONSENTITO
- Almeno un check bloccante FAIL → 🔴 COMMIT BLOCCATO
- Solo check non-bloccanti in WARN/FAIL → 🟡 COMMIT CONSENTITO CON AVVISI

Esempio di formato:

| 🔨 DevForge · Pre-Commit Quality Gate — Riepilogo |
|:---|
| 1. 🔍 Secret Scan:       ✅ PASS |
| 2. 📝 Naming Convention: ✅ PASS |
| 3. 🧪 Test Coverage:     ⏭️ SKIP (file .md) |
| 4. 📦 File Size:         ✅ PASS |
| 5. 🔎 Lint Check:        ⏭️ SKIP |
| **🟢 Esito: COMMIT CONSENTITO** |

**Regole di blocco:**
- Secret Scan ❌ → 🔴 COMMIT BLOCCATO (non negoziabile)
- File Size ❌ → 🔴 COMMIT BLOCCATO (richiede conferma esplicita per override)
- Naming / Test / Lint ❌ → 🟡 Mostra warning, consenti commit con conferma utente

Procedi con il commit SOLO se tutte le verifiche bloccanti passano.
INSTRUCTIONS_EOF

precommit_escaped=$(escape_for_json "$PRECOMMIT_INSTRUCTIONS")

# Compose catalog section if due for re-injection
catalog_reinject_section=""
if [ -n "$CATALOG_REINJECT" ]; then
    catalog_reinject_escaped=$(escape_for_json "$CATALOG_REINJECT")
    catalog_reinject_section="\\n\\n**DevForge Skill Catalog (re-injection periodica):**\\n\\n${catalog_reinject_escaped}"
fi

precommit_context="${SKILL_REMINDER}<EXTREMELY_IMPORTANT>\\nDevForge Pre-Commit Quality Gate attivo.\\n\\n**PRIMA di eseguire qualsiasi commit, DEVI completare TUTTE le verifiche seguenti sui file staged.**\\n\\n${precommit_escaped}${catalog_reinject_section}\\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Keep both shapes for compatibility:
# - Cursor hooks expect additional_context.
# - Claude hooks expect hookSpecificOutput.additionalContext.
cat <<EOF
{
  "additional_context": "${precommit_context}",
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "additionalContext": "${precommit_context}"
  }
}
EOF

exit 0
