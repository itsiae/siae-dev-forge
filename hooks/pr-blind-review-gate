#!/usr/bin/env bash
# PreToolUse hook: BLOCCA `gh pr create|edit` senza siae-blind-review validata
# ─────────────────────────────────────────────────────────────────
# Hook:     pr-blind-review-gate
# Evento:   PreToolUse
# Matcher:  Bash
# Timeout:  10s
# Formato:  decision:"block" se siae-blind-review non è validata per il task
# History:  v1.47.0 NEW — PR #2 ADR-008, chiude gap #9 (adoption 0%).
# ─────────────────────────────────────────────────────────────────

set -euo pipefail
export DEVFORGE_CURRENT_HOOK="pr-blind-review-gate"

HOOK_INPUT=$(cat)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${PLUGIN_ROOT}/lib/logger.sh" 2>/dev/null || true
source "${PLUGIN_ROOT}/lib/block-explainer.sh" 2>/dev/null || true
if ! source "${PLUGIN_ROOT}/lib/cmd-parser.sh" 2>/dev/null \
   || ! source "${PLUGIN_ROOT}/lib/task-id.sh" 2>/dev/null \
   || ! source "${PLUGIN_ROOT}/lib/evidence-check.sh" 2>/dev/null; then
    command -v devforge_log >/dev/null 2>&1 \
        && devforge_log "hook_degraded" "warning" "{\"hook\":\"pr-blind-review-gate\"}" 2>/dev/null || true
fi

# Extract command from tool input
if command -v jq >/dev/null 2>&1; then
    TOOL_COMMAND=$(echo "$HOOK_INPUT" | jq -r '.command // .tool_input.command // empty' 2>/dev/null || true)
else
    TOOL_COMMAND=$(echo "$HOOK_INPUT" | grep -o '"command"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"command"[[:space:]]*:[[:space:]]*"//;s/"$//' || true)
fi

[ -z "$TOOL_COMMAND" ] && { echo '{}'; exit 0; }

# Token match: only `gh pr create` or `gh pr edit` trigger the gate.
# Fallback to substring if cmd-parser unavailable (safety).
# Segment-aware: matcha anche dentro comandi composti (cd X && env -u P gh pr create)
# — il match first-segment-only veniva bypassato (root cause PR #311).
TRIGGERS=0
if command -v devforge_cmd_has_subcommand >/dev/null 2>&1; then
    if devforge_cmd_has_subcommand "$TOOL_COMMAND" gh pr create \
       || devforge_cmd_has_subcommand "$TOOL_COMMAND" gh pr edit; then
        TRIGGERS=1
    fi
elif command -v devforge_first_token >/dev/null 2>&1; then
    FIRST=$(devforge_first_token "$TOOL_COMMAND")
    SECOND=$(devforge_second_token "$TOOL_COMMAND")
    THIRD=$(devforge_third_token "$TOOL_COMMAND")
    if [ "$FIRST" = "gh" ] && [ "$SECOND" = "pr" ]; then
        case "$THIRD" in
            create|edit) TRIGGERS=1 ;;
        esac
    fi
else
    # Be conservative in the fallback: require `gh pr create` or `gh pr edit`
    # as leading tokens on a whitespace-normalised command.
    NORM=$(echo "$TOOL_COMMAND" | sed -E 's/^[[:space:]]+//;s/[[:space:]]+/ /g')
    case "$NORM" in
        "gh pr create"*|"gh pr edit"*) TRIGGERS=1 ;;
    esac
fi

if [ "$TRIGGERS" != "1" ]; then
    echo '{}'
    exit 0
fi

# Scope check: itsiae/* only (consistent with all PR #2 gates)
GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || true)
if [ -z "$GIT_ROOT" ]; then
    echo '{}'
    exit 0
fi
REMOTE_URL=$(git -C "$GIT_ROOT" remote get-url origin 2>/dev/null || true)
if ! echo "$REMOTE_URL" | grep -qE "[/:]itsiae/"; then
    echo '{}'
    exit 0
fi

devforge_init_session 2>/dev/null || true

# Explicit bypass with daily abuse tracking
if [ "${DEVFORGE_SKIP_BLIND_REVIEW:-0}" = "1" ]; then
    BYPASS_FILE="${HOME}/.claude/.devforge-blind-review-bypass-count"
    TODAY=$(date -u +%Y-%m-%d)
    DATA=$(cat "$BYPASS_FILE" 2>/dev/null || echo "")
    STORED_DATE="${DATA%%|*}"
    STORED_N="${DATA##*|}"
    if [ "$STORED_DATE" != "$TODAY" ] || [ -z "$STORED_N" ]; then
        STORED_N=0
    fi
    NEW_N=$((STORED_N + 1))
    echo "${TODAY}|${NEW_N}" > "${BYPASS_FILE}.tmp" && mv "${BYPASS_FILE}.tmp" "$BYPASS_FILE"
    devforge_log "pr_blind_review_bypassed" "warning" "{\"count_today\":${NEW_N}}"
    if [ "$NEW_N" -ge 5 ]; then
        devforge_log "pr_blind_review_bypass_abuse_suspected" "warning" "{\"count_today\":${NEW_N}}"
    fi
    echo '{}'
    exit 0
fi

# Validation check: task-scoped first, session-scoped fallback
USE_SESSION_SCOPE="${DEVFORGE_USE_SESSION_SCOPE:-0}"
VALIDATED=0

if [ "$USE_SESSION_SCOPE" != "1" ] \
   && command -v devforge_compute_task_id >/dev/null 2>&1 \
   && command -v devforge_skill_validated >/dev/null 2>&1; then
    TASK_ID=$(devforge_compute_task_id 2>/dev/null || echo "")
    if [ -n "$TASK_ID" ] && devforge_skill_validated siae-blind-review "$TASK_ID" 2>/dev/null; then
        VALIDATED=1
    fi
fi

if [ "$VALIDATED" != "1" ]; then
    # Rollback / fallback: session-level invocation counts.
    if grep -qF "siae-blind-review" "${HOME}/.claude/.devforge-session-skills" 2>/dev/null; then
        VALIDATED=1
    fi
fi

if [ "$VALIDATED" = "1" ]; then
    echo '{}'
    exit 0
fi

# Block
devforge_log "pr_blind_review_gate" "blocked" "{\"task_id\":\"${TASK_ID:-}\"}"
_BR_EXPL=""
if command -v devforge_block_explainer >/dev/null 2>&1; then
    _BR_EXPL=$(devforge_block_explainer siae-blind-review 2>/dev/null || true)
    [ -n "$_BR_EXPL" ] && _BR_EXPL=" ${_BR_EXPL}"
fi
cat <<EOF
{
  "decision": "block",
  "reason": "DevForge Blind Review Gate — BLOCCATO. Stai aprendo o modificando una PR ma NON risulta evidenza di siae-blind-review per questo task. Il blind review verifica l'allineamento spec ↔ codice con atteggiamento da auditor ostile. Invoca siae-blind-review, completa il verdict, poi riprova.${_BR_EXPL} Bypass tracked (5/giorno): DEVFORGE_SKIP_BLIND_REVIEW=1 <comando>."
}
EOF
exit 0
