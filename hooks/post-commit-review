#!/usr/bin/env bash
# PostToolUse hook: after PR creation or push, trigger code-reviewer + security agents
# Fires on Bash tool completion вЂ” checks if the command was gh pr create or git push.
# Reviews only CHANGED files in the branch (diff vs base branch).
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Hook:     post-commit-review
# Evento:   PostToolUse
# Matcher:  Bash
# Timeout:  10s вЂ” Analisi diff post-push
# Formato:  additional_context (standard DevForge)
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

set -euo pipefail

# Read tool input from stdin (JSON with tool_name, tool_input, tool_output)
HOOK_INPUT=$(cat)

# Determine plugin root (needed early for telemetry upload)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Extract the command that was executed (jq handles escaped quotes in paths with spaces)
if command -v jq >/dev/null 2>&1; then
    TOOL_COMMAND=$(echo "$HOOK_INPUT" | jq -r '.command // .tool_input.command // empty' 2>/dev/null || true)
else
    TOOL_COMMAND=$(echo "$HOOK_INPUT" | grep -o '"command"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"command"[[:space:]]*:[[:space:]]*"//;s/"$//' || true)
fi

# F2: Detect new commit by comparing HEAD hash with saved hash (robust for heredoc/complex commands)
LAST_HASH_FILE="${HOME}/.claude/.devforge-last-commit-hash"
CURRENT_HEAD=$(git rev-parse HEAD 2>/dev/null || echo "")
SAVED_HASH=$(cat "$LAST_HASH_FILE" 2>/dev/null || echo "")

if [ -n "$CURRENT_HEAD" ] && [ "$CURRENT_HEAD" != "$SAVED_HASH" ]; then
    source "${PLUGIN_ROOT}/lib/telemetry-upload.sh" 2>/dev/null || true
    devforge_upload_logs &

    source "${PLUGIN_ROOT}/lib/logger.sh" 2>/dev/null || true
    DIFF_STAT=$(git diff --stat HEAD~1 HEAD 2>/dev/null || echo "")
    FILES_CHANGED=$(echo "$DIFF_STAT" | tail -1 | grep -oE '[0-9]+ file' | grep -oE '[0-9]+' || echo "0")
    INSERTIONS=$(echo "$DIFF_STAT" | tail -1 | grep -oE '[0-9]+ insertion' | grep -oE '[0-9]+' || echo "0")
    DELETIONS=$(echo "$DIFF_STAT" | tail -1 | grep -oE '[0-9]+ deletion' | grep -oE '[0-9]+' || echo "0")

    CHANGED_FILES=$(git diff --name-only HEAD~1 HEAD 2>/dev/null || echo "")
    HAS_TESTS="false"
    if echo "$CHANGED_FILES" | grep -qE '(Test\.|_test\.|\.test\.|\.spec\.|/test/|/tests/|^test_|^tests/)'; then
        HAS_TESTS="true"
    fi

    devforge_log "commit_created" "success" \
        "{\"files_changed\":${FILES_CHANGED:-0},\"insertions\":${INSERTIONS:-0},\"deletions\":${DELETIONS:-0},\"has_tests\":${HAS_TESTS}}"

    # Increment session commit counter (atomic via temp file)
    SESSION_COMMITS_FILE="${HOME}/.claude/.devforge-session-commits"
    CURRENT_COMMITS=$(cat "$SESSION_COMMITS_FILE" 2>/dev/null || echo "0")
    echo $((CURRENT_COMMITS + 1)) > "${SESSION_COMMITS_FILE}.tmp" && mv "${SESSION_COMMITS_FILE}.tmp" "$SESSION_COMMITS_FILE"

    # Save current HEAD for next comparison
    echo "$CURRENT_HEAD" > "$LAST_HASH_FILE"
fi

# Emit pr_opened event after push if a PR exists (requires gh CLI)
if [[ "$TOOL_COMMAND" =~ git[[:space:]]+push ]]; then
    source "${PLUGIN_ROOT}/lib/logger.sh" 2>/dev/null || true
    if command -v gh >/dev/null 2>&1; then
        PR_JSON=$(gh pr view --json number,baseRefName,changedFiles,commits 2>/dev/null || echo "")
        if [ -n "$PR_JSON" ]; then
            PR_NUMBER=$(echo "$PR_JSON" | grep -o '"number":[0-9]*' | grep -oE '[0-9]+' || echo "0")
            BASE_BRANCH=$(echo "$PR_JSON" | grep -o '"baseRefName":"[^"]*"' | sed 's/.*"baseRefName":"//;s/"$//' || echo "unknown")
            FILES_CHANGED=$(echo "$PR_JSON" | grep -o '"changedFiles":[0-9]*' | grep -oE '[0-9]+' || echo "0")
            COMMITS_COUNT=$(echo "$PR_JSON" | grep -o '"totalCount":[0-9]*' | grep -oE '[0-9]+' || echo "0")
            # Sanitize BASE_BRANCH for safe JSON embedding (logger.sh already sourced above)
            SAFE_BASE_BRANCH=$(devforge_sanitize_json_str "$BASE_BRANCH")
            devforge_log "pr_opened" "success" \
                "{\"pr_number\":${PR_NUMBER},\"base_branch\":\"${SAFE_BASE_BRANCH}\",\"files_changed\":${FILES_CHANGED},\"commits_count\":${COMMITS_COUNT}}"
        fi
    fi
fi

# Only trigger review on PR creation or git push (not on every commit)
if [[ ! "$TOOL_COMMAND" =~ gh[[:space:]]+pr[[:space:]]+create ]] && \
   [[ ! "$TOOL_COMMAND" =~ git[[:space:]]+push ]]; then
    echo '{}'
    exit 0
fi

# Check if push/PR actually succeeded (look for error indicators in output)
if command -v jq >/dev/null 2>&1; then
    TOOL_OUTPUT=$(echo "$HOOK_INPUT" | jq -r '.stdout // .tool_output.stdout // empty' 2>/dev/null || true)
else
    TOOL_OUTPUT=$(echo "$HOOK_INPUT" | grep -o '"stdout"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 || true)
fi
if echo "$TOOL_OUTPUT" | grep -qi "error\|fatal\|rejected\|failed"; then
    echo '{}'
    exit 0
fi

# Source activity logger
source "${PLUGIN_ROOT}/lib/logger.sh" 2>/dev/null || true

# Log PR review trigger (sanitize command for JSON safety)
SAFE_TOOL_COMMAND=$(devforge_sanitize_json_str "$TOOL_COMMAND")
devforge_log "pr_auto_review" "triggered" "{\"command\":\"${SAFE_TOOL_COMMAND}\"}" 2>/dev/null || true

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

read -r -d '' REVIEW_INSTRUCTIONS << 'REVIEW_EOF' || true
# DevForge PR Auto-Review

Una PR e' stata creata o il branch e' stato pushato. DEVI lanciare automaticamente questi due agent in parallelo.

## REGOLA CRITICA: Passa il DIFF, non i path dei file

Gli agent di review DEVONO ricevere il diff testuale nel prompt, NON i path dei file.
Passare i path causa la lettura dei file interi вЂ” spreco di token enorme.

**Step preliminare obbligatorio:**
```bash
git diff origin/main...HEAD
```

Salva l'output di questo comando. Lo passerai nel prompt di ENTRAMBI gli agent.

## 1. Code Review (siae-devforge:code-reviewer)

Lancia l'agent con subagent_type="siae-devforge:code-reviewer".
Nel prompt INCLUDI il diff testuale completo, NON i path dei file.
L'agent eseguira' la review a 6 punti SOLO sul diff: conformita' al piano, code standards,
security, error handling, test coverage, architettura.

## 2. Security Check (siae-devforge:siae-security)

Invoca la skill siae-devforge:siae-security per verificare SOLO il diff:
- Nessun secret/credenziale nel diff
- IAM least privilege se ci sono policy AWS
- OWASP Top 10 compliance
- PII handling per dati autori/artisti SIAE

## Istruzioni

1. Ottieni il diff completo: `git diff origin/main...HEAD`
2. Lancia ENTRAMBI in parallelo usando il tool Agent:
   - Agent con subagent_type="siae-devforge:code-reviewer" вЂ” passa il DIFF nel prompt
   - Invoca Skill("siae-devforge:siae-security") per il security check вЂ” passa il DIFF
3. Mostra i risultati quando arrivano
4. Se trovano problemi critici, segnalali PRIMA di qualsiasi altra azione

IMPORTANTE: Analizza SOLO il diff вЂ” NON leggere file interi. Gli agent NON devono usare
Read o Glob per leggere file completi. Tutto il contesto necessario e' nel diff.
Se un agent ha bisogno di contesto aggiuntivo (es. design doc),
passa il path nel prompt ma SOLO per i criteri di accettazione, non per rileggere il codice.

NON chiedere all'utente se vuole la review вЂ” e' automatica.
NON saltare questo step вЂ” ogni PR viene revisionata.
REVIEW_EOF

review_escaped=$(escape_for_json "$REVIEW_INSTRUCTIONS")
review_context="<EXTREMELY_IMPORTANT>\nDevForge PR Auto-Review attivato.\n\n${review_escaped}\n</EXTREMELY_IMPORTANT>"

# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# RETROSPECTIVE TRIGGER вЂ” only on gh pr create (not git push)
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
RETRO_CONTEXT=""
if [[ "$TOOL_COMMAND" =~ gh[[:space:]]+pr[[:space:]]+create ]]; then
    read -r -d '' RETRO_INSTRUCTIONS << 'RETRO_EOF' || true
# DevForge Retrospective Trigger

Una PR e' stata creata. DOPO la code review, invoca `siae-retrospective` per estrarre
e persistere le lezioni apprese dalla sessione corrente.

La retrospettiva e' il momento naturale per riflettere: la PR chiude il ciclo di lavoro.
NON saltare questo step. Le lezioni non salvate sono lezioni perse.

Invoca: Skill tool -> siae-devforge:siae-retrospective
RETRO_EOF
    retro_escaped=$(escape_for_json "$RETRO_INSTRUCTIONS")
    RETRO_CONTEXT="\\n\\n<IMPORTANT>\\n${retro_escaped}\\n</IMPORTANT>"
fi

FULL_CONTEXT="${review_context}${RETRO_CONTEXT}"

cat <<EOF
{
  "additional_context": "${FULL_CONTEXT}",
  "hookSpecificOutput": {
    "hookEventName": "PostToolUse",
    "additionalContext": "${FULL_CONTEXT}"
  }
}
EOF

exit 0
