#!/usr/bin/env bash
# PostToolUse hook for siae-devforge plugin (intercepts Skill tool invocations)
# Logs skill_invoked events and skill_completed via timestamp chaining.
#
# Timestamp chaining: each invocation closes the PREVIOUS skill by computing
# its duration from the saved timestamp, then records the CURRENT skill start.
# ─────────────────────────────────────────────────────────────────
# Hook:     post-skill
# Evento:   PostToolUse
# Matcher:  Skill
# Timeout:  5s — Solo logging JSONL
# Formato:  additional_context (standard DevForge)
# ─────────────────────────────────────────────────────────────────

set -euo pipefail
export DEVFORGE_CURRENT_HOOK="post-skill"

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Source activity logger
source "${PLUGIN_ROOT}/lib/logger.sh"
devforge_init_session 2>/dev/null || true

# Timestamp file for chaining
SKILL_TS_FILE="${HOME}/.claude/.devforge-skill-start"

# Read tool output from stdin (JSON with tool_name and tool_input)
HOOK_INPUT=$(cat)

# Extract skill name from the input
# The Skill tool input contains a "skill" field with the skill name
SKILL_NAME=$(echo "$HOOK_INPUT" | grep -o '"skill"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"skill"[[:space:]]*:[[:space:]]*"//;s/"$//' || true)

if [ -z "$SKILL_NAME" ]; then
    # Try alternative field name patterns
    SKILL_NAME=$(echo "$HOOK_INPUT" | grep -o '"name"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"name"[[:space:]]*:[[:space:]]*"//;s/"$//' || true)
fi

# Only proceed if we could extract a valid skill name
if [ -n "$SKILL_NAME" ]; then
    # Step 1 (CRITICAL): Write SESSION_SKILLS_FILE first.
    # This file is read by tdd-gate and other PreToolUse gates to verify skill
    # invocation. It MUST be written before any logging call that can fail:
    # with set -euo pipefail, a failing devforge_log* would exit the script
    # before reaching this write, leaving the gate unable to detect the skill.
    SESSION_SKILLS_FILE="${HOME}/.claude/.devforge-session-skills"
    EXISTING_SKILLS=$(cat "$SESSION_SKILLS_FILE" 2>/dev/null || echo "")
    if [ -z "$EXISTING_SKILLS" ]; then
        echo "$SKILL_NAME" > "${SESSION_SKILLS_FILE}.tmp" && mv "${SESSION_SKILLS_FILE}.tmp" "$SESSION_SKILLS_FILE"
    elif ! echo "$EXISTING_SKILLS" | grep -qF "$SKILL_NAME"; then
        echo "${EXISTING_SKILLS},${SKILL_NAME}" > "${SESSION_SKILLS_FILE}.tmp" && mv "${SESSION_SKILLS_FILE}.tmp" "$SESSION_SKILLS_FILE"
    fi

    # Step 1b (PR #2 ADR-001): mirror into per-task ledger.
    # Also writes the task metadata file on first write so
    # devforge_task_id_transition can decide if evidence copy-forward is
    # warranted on a later design-doc revision.
    if source "${PLUGIN_ROOT}/lib/task-id.sh" 2>/dev/null; then
        _POST_TASK_ID=$(devforge_compute_task_id 2>/dev/null || echo "")
        if [ -n "$_POST_TASK_ID" ]; then
            _POST_TASK_DIR="${HOME}/.claude/.devforge-task-skills/${_POST_TASK_ID}"
            mkdir -p "$_POST_TASK_DIR"
            # Strip plugin prefix (e.g. "siae-devforge:siae-tdd" → "siae-tdd")
            # for a stable ledger key — gates grep on the bare name.
            _CLEAN_SKILL="${SKILL_NAME##*:}"
            devforge_task_skill_invoked "$_POST_TASK_ID" "$_CLEAN_SKILL" 2>/dev/null || true
            if [ ! -f "$_POST_TASK_DIR/metadata" ]; then
                _POST_BRANCH=$(git branch --show-current 2>/dev/null || echo "")
                _POST_DESIGN=""
                if [ -d docs/plans ]; then
                    _POST_DESIGN=$(ls -1t docs/plans/*-design.md 2>/dev/null | head -1 || true)
                fi
                {
                    printf 'branch_name=%s\n' "$_POST_BRANCH"
                    printf 'design_doc=%s\n' "$_POST_DESIGN"
                    printf 'created_ns=%s\n' "$(_devforge_epoch_ns 2>/dev/null || date +%s)"
                } > "${_POST_TASK_DIR}/metadata.tmp" \
                  && mv "${_POST_TASK_DIR}/metadata.tmp" "${_POST_TASK_DIR}/metadata"
            fi
        fi
    fi

    # Step 2: Logging (non-critical — || true prevents set -euo pipefail from
    # aborting the script if the JSONL log write fails).
    SAFE_SKILL_NAME=$(devforge_sanitize_json_str "$SKILL_NAME")

    # Current cumulative token snapshot (for per-skill delta). Refresh first,
    # then read total/output via the token-collector field contract (f1/f2).
    # No-op if no session dir / stats yet → snapshot stays 0, delta omitted.
    TOKEN_NOW_TOTAL=0
    TOKEN_NOW_OUTPUT=0
    if [ -n "${DEVFORGE_SESSION_DIR:-}" ] && [ -f "${DEVFORGE_SESSION_DIR}/token-stats.json" ]; then
        python3 "${PLUGIN_ROOT}/lib/token-collector.py" update >/dev/null 2>&1 || true
        _TOK_LINE=$(python3 "${PLUGIN_ROOT}/lib/token-collector.py" fields 2>/dev/null) || true
        if [ -n "${_TOK_LINE:-}" ]; then
            TOKEN_NOW_TOTAL=$(printf '%s' "$_TOK_LINE" | cut -f1)
            TOKEN_NOW_OUTPUT=$(printf '%s' "$_TOK_LINE" | cut -f2)
        fi
    fi

    # Close the previous skill cycle before overwriting SKILL_TS_FILE
    if [ -f "$SKILL_TS_FILE" ]; then
        PREV_DATA=$(cat "$SKILL_TS_FILE")
        PREV_START_NS=$(echo "$PREV_DATA" | cut -d'|' -f1)
        PREV_SKILL=$(echo "$PREV_DATA" | cut -d'|' -f2)
        PREV_PHASE=$(echo "$PREV_DATA" | cut -d'|' -f3)
        # Token snapshot from the previous invocation (fields 4/5). Legacy
        # 3-field files have NO baseline → delta 0 (we must not attribute the
        # whole cumulative total to a single skill).
        PREV_TOKEN_TOTAL=$(echo "$PREV_DATA" | cut -d'|' -f4)
        PREV_TOKEN_OUTPUT=$(echo "$PREV_DATA" | cut -d'|' -f5)
        SAFE_PREV_SKILL=$(devforge_sanitize_json_str "$PREV_SKILL")
        SAFE_PREV_PHASE=$(devforge_sanitize_json_str "$PREV_PHASE")

        # Delta only when BOTH the previous baseline and the current snapshot are
        # numeric. Legacy 3-field files (empty) or a corrupted SKILL_TS_FILE
        # (non-numeric) → delta 0, never a `$(( ))` syntax error that would abort
        # the hook under set -euo pipefail and drop the skill_completed log.
        TOKENS_TOTAL_DELTA=0
        TOKENS_OUTPUT_DELTA=0
        if [[ "$PREV_TOKEN_TOTAL" =~ ^[0-9]+$ ]] && [[ "$TOKEN_NOW_TOTAL" =~ ^[0-9]+$ ]]; then
            # Delta clamped to >=0 (a cursor reset mid-skill could invert it).
            TOKENS_TOTAL_DELTA=$(( TOKEN_NOW_TOTAL - PREV_TOKEN_TOTAL ))
            [ "$TOKENS_TOTAL_DELTA" -lt 0 ] && TOKENS_TOTAL_DELTA=0
        fi
        if [[ "$PREV_TOKEN_OUTPUT" =~ ^[0-9]+$ ]] && [[ "$TOKEN_NOW_OUTPUT" =~ ^[0-9]+$ ]]; then
            TOKENS_OUTPUT_DELTA=$(( TOKEN_NOW_OUTPUT - PREV_TOKEN_OUTPUT ))
            [ "$TOKENS_OUTPUT_DELTA" -lt 0 ] && TOKENS_OUTPUT_DELTA=0
        fi

        if [ -n "$PREV_START_NS" ] && [ -n "$PREV_SKILL" ]; then
            devforge_log_timed "skill_completed" "success" "$PREV_START_NS" \
                "{\"skill_name\":\"${SAFE_PREV_SKILL}\",\"sdlc_phase\":\"${SAFE_PREV_PHASE}\",\"outcome\":\"success\",\"tokens_total_delta\":${TOKENS_TOTAL_DELTA},\"tokens_output_delta\":${TOKENS_OUTPUT_DELTA}}" || true
        fi
    fi

    SDLC_PHASE=$(devforge_get_sdlc_phase "$SKILL_NAME")
    SAFE_SDLC_PHASE=$(devforge_sanitize_json_str "$SDLC_PHASE")
    devforge_log "skill_invoked" "success" "{\"skill_name\":\"${SAFE_SKILL_NAME}\",\"sdlc_phase\":\"${SAFE_SDLC_PHASE}\"}" || true

    # Step 3 (CRITICAL): Save skill start timestamp for duration tracking.
    # Written after logging so we don't overwrite the previous skill's data
    # before devforge_log_timed has read it above.
    NOW_NS=$(_devforge_epoch_ns)
    # 5-field format: START_NS|SKILL|PHASE|TOKEN_TOTAL|TOKEN_OUTPUT (additive;
    # legacy 3-field readers using cut -f1..3 remain valid).
    echo "${NOW_NS}|${SKILL_NAME}|${SDLC_PHASE}|${TOKEN_NOW_TOTAL}|${TOKEN_NOW_OUTPUT}" > "$SKILL_TS_FILE"

    # Plan lifecycle events (AC-9, AC-10)
    # Euristica: cerca design doc recentemente modificato (last PLAN_EVENT_WINDOW_SEC) nel cwd corrente
    # Portable mtime check (no `find -newermt`: unsupported on busybox/git-bash on Windows).
    # Ordering via `ls -1t` (mtime-desc) + age via stat (BSD -f %m / GNU -c %Y).
    PLAN_EVENT_WINDOW_SEC=60
    CLEAN_SKILL_TOKEN="${SKILL_NAME##*:}"
    _plan_latest_recent() {
        # stdout: path del design doc piu' recente in docs/plans/*-design.md
        # se la sua eta' e' nel range [0, PLAN_EVENT_WINDOW_SEC] secondi; vuoto altrimenti.
        if [ ! -d "docs/plans" ]; then
            return 0
        fi
        local latest
        latest=$(ls -1t docs/plans/*-design.md 2>/dev/null | head -1)
        if [ -z "$latest" ] || [ ! -f "$latest" ]; then
            return 0
        fi
        local file_mtime now_epoch age_sec
        file_mtime=$(stat -f %m "$latest" 2>/dev/null || stat -c %Y "$latest" 2>/dev/null || echo 0)
        now_epoch=$(date +%s)
        age_sec=$(( now_epoch - file_mtime ))
        if [ "$age_sec" -ge 0 ] && [ "$age_sec" -le "$PLAN_EVENT_WINDOW_SEC" ]; then
            echo "$latest"
        fi
    }

    if [ "$CLEAN_SKILL_TOKEN" = "siae-brainstorming" ]; then
        # plan_created vs plan_revised: se esiste gia' un plan_created per questo plan_path
        # nel log JSONL locale, emetti plan_revised (iterazione successiva di design).
        RECENT_PLAN=$(_plan_latest_recent)
        if [ -n "$RECENT_PLAN" ]; then
            SAFE_PLAN_PATH=$(devforge_sanitize_json_str "$RECENT_PLAN")
            if [ -f "$DEVFORGE_LOG_FILE" ] && grep -q "\"event\":\"plan_created\".*\"plan_path\":\"${SAFE_PLAN_PATH}\"" "$DEVFORGE_LOG_FILE" 2>/dev/null; then
                devforge_log "plan_revised" "success" "{\"plan_path\":\"${SAFE_PLAN_PATH}\",\"origin_skill\":\"${SAFE_SKILL_NAME}\"}" || true
            else
                devforge_log "plan_created" "success" "{\"plan_path\":\"${SAFE_PLAN_PATH}\",\"origin_skill\":\"${SAFE_SKILL_NAME}\"}" || true
            fi
        fi

        # Reset brainstorming-gate counter (T05) + emit conversion event
        CURRENT_SID_RESET=$(devforge_get_sid 2>/dev/null || echo "unknown")
        BRAINSTORM_COUNTER_FILE="${HOME}/.claude/.devforge-brainstorm-counter"
        PRE_RESET_DATA=$(cat "$BRAINSTORM_COUNTER_FILE" 2>/dev/null || echo "")
        PRE_RESET_N="${PRE_RESET_DATA##*|}"
        TRIGGER="none"
        case "${PRE_RESET_N:-0}" in
            1) TRIGGER="nudge" ;;
            2|3) TRIGGER="warn" ;;
            [4-9]|[0-9][0-9]*) TRIGGER="block" ;;
        esac
        echo "${CURRENT_SID_RESET}|0" > "${BRAINSTORM_COUNTER_FILE}.tmp" && \
            mv "${BRAINSTORM_COUNTER_FILE}.tmp" "$BRAINSTORM_COUNTER_FILE"
        if [ "$TRIGGER" != "none" ]; then
            devforge_log "brainstorming_invoked_post_gate" "success" "{\"trigger\":\"${TRIGGER}\",\"counter_before_reset\":${PRE_RESET_N:-0}}" || true
        fi
    elif [ "$CLEAN_SKILL_TOKEN" = "siae-writing-plans" ]; then
        # plan_approved: doc con frontmatter status:approved modificato ultimi PLAN_EVENT_WINDOW_SEC
        RECENT_PLAN=$(_plan_latest_recent)
        if [ -n "$RECENT_PLAN" ] && head -10 "$RECENT_PLAN" 2>/dev/null | grep -qiE '^status:[[:space:]]*approved'; then
            SAFE_PLAN_PATH=$(devforge_sanitize_json_str "$RECENT_PLAN")
            devforge_log "plan_approved" "success" "{\"plan_path\":\"${SAFE_PLAN_PATH}\",\"origin_skill\":\"${SAFE_SKILL_NAME}\"}" || true

            # plan_metrics: iterations + duration calcolati dal log JSONL locale.
            # Skip emit se plan_created non esiste (utente skippa brainstorming).
            if [ -f "$DEVFORGE_LOG_FILE" ]; then
                CREATED_LINE=$(grep "\"event\":\"plan_created\".*\"plan_path\":\"${SAFE_PLAN_PATH}\"" "$DEVFORGE_LOG_FILE" 2>/dev/null | head -1 || true)
                if [ -n "$CREATED_LINE" ]; then
                    ITERATIONS=$(grep -c "\"event\":\"plan_revised\".*\"plan_path\":\"${SAFE_PLAN_PATH}\"" "$DEVFORGE_LOG_FILE" 2>/dev/null || echo 0)
                    CREATED_TS=$(echo "$CREATED_LINE" | grep -oE '"ts":"[^"]+"' | head -1 | sed 's/"ts":"//;s/"$//')
                    if command -v python3 >/dev/null 2>&1 && [ -n "$CREATED_TS" ]; then
                        CREATED_EPOCH=$(python3 -c "import sys;from datetime import datetime;t=datetime.fromisoformat(sys.argv[1].replace('Z','+00:00'));print(int(t.timestamp()))" "$CREATED_TS" 2>/dev/null || echo 0)
                        NOW_EPOCH=$(date -u +%s)
                        if [ "${CREATED_EPOCH:-0}" -gt 0 ]; then
                            DURATION_SEC=$((NOW_EPOCH - CREATED_EPOCH))
                            devforge_log "plan_metrics" "success" "{\"plan_path\":\"${SAFE_PLAN_PATH}\",\"iterations\":${ITERATIONS:-0},\"duration_sec\":${DURATION_SEC},\"origin_skill\":\"${SAFE_SKILL_NAME}\"}" || true
                        else
                            devforge_log "plan_metrics" "success" "{\"plan_path\":\"${SAFE_PLAN_PATH}\",\"iterations\":${ITERATIONS:-0},\"origin_skill\":\"${SAFE_SKILL_NAME}\"}" || true
                        fi
                    else
                        devforge_log "plan_metrics" "success" "{\"plan_path\":\"${SAFE_PLAN_PATH}\",\"iterations\":${ITERATIONS:-0},\"origin_skill\":\"${SAFE_SKILL_NAME}\"}" || true
                    fi
                fi
            fi
        fi
    fi
fi

# --- TDD State Machine: initialize state when siae-tdd is invoked ---
if [ -n "$SKILL_NAME" ]; then
    CLEAN_SKILL="${SKILL_NAME##*:}"
    if [ "$CLEAN_SKILL" = "siae-tdd" ]; then
        TDD_STATE_FILE="${HOME}/.claude/.devforge-tdd-state"
        CURRENT_TDD=$(cat "$TDD_STATE_FILE" 2>/dev/null || echo "")
        CURRENT_TDD_PHASE=$(echo "$CURRENT_TDD" | cut -d'|' -f1)
        # Only initialize if no active TDD cycle (avoid resetting mid-cycle)
        if [ -z "$CURRENT_TDD_PHASE" ] || [ "$CURRENT_TDD_PHASE" = "NONE" ]; then
            echo "INIT|pending|awaiting-test|$(date +%s)" > "$TDD_STATE_FILE"
        fi
    fi
fi

# Pass through — PostToolUse hooks should not block
echo '{}'
exit 0
