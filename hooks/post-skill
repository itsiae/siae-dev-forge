#!/usr/bin/env bash
# PostToolUse hook for siae-devforge plugin (intercepts Skill tool invocations)
# Logs skill_invoked events and skill_completed via timestamp chaining.
#
# Timestamp chaining: each invocation closes the PREVIOUS skill by computing
# its duration from the saved timestamp, then records the CURRENT skill start.

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Source activity logger
source "${PLUGIN_ROOT}/lib/logger.sh"

# Timestamp file for chaining
SKILL_TS_FILE="${HOME}/.claude/.devforge-skill-start"

# Read tool output from stdin (JSON with tool_name and tool_input)
HOOK_INPUT=$(cat)

# Extract skill name from the input
# The Skill tool input contains a "skill" field with the skill name
SKILL_NAME=$(echo "$HOOK_INPUT" | grep -o '"skill"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"skill"[[:space:]]*:[[:space:]]*"//;s/"$//' || true)

if [ -z "$SKILL_NAME" ]; then
    # Try alternative field name patterns
    SKILL_NAME=$(echo "$HOOK_INPUT" | grep -o '"name"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"name"[[:space:]]*:[[:space:]]*"//;s/"$//' || true)
fi

# Only proceed if we could extract a valid skill name
if [ -n "$SKILL_NAME" ]; then
    # Sanitize skill name for safe JSON embedding
    SAFE_SKILL_NAME=$(devforge_sanitize_json_str "$SKILL_NAME")

    # Step 1: If a previous skill timestamp exists, close it with skill_completed
    if [ -f "$SKILL_TS_FILE" ]; then
        PREV_DATA=$(cat "$SKILL_TS_FILE")
        PREV_START_NS=$(echo "$PREV_DATA" | cut -d'|' -f1)
        PREV_SKILL=$(echo "$PREV_DATA" | cut -d'|' -f2)
        PREV_PHASE=$(echo "$PREV_DATA" | cut -d'|' -f3)
        SAFE_PREV_SKILL=$(devforge_sanitize_json_str "$PREV_SKILL")
        SAFE_PREV_PHASE=$(devforge_sanitize_json_str "$PREV_PHASE")

        if [ -n "$PREV_START_NS" ] && [ -n "$PREV_SKILL" ]; then
            devforge_log_timed "skill_completed" "success" "$PREV_START_NS" \
                "{\"skill_name\":\"${SAFE_PREV_SKILL}\",\"sdlc_phase\":\"${SAFE_PREV_PHASE}\",\"outcome\":\"success\"}"
        fi
    fi

    # Step 2: Log skill_invoked for the CURRENT skill and save its timestamp
    SDLC_PHASE=$(devforge_get_sdlc_phase "$SKILL_NAME")
    SAFE_SDLC_PHASE=$(devforge_sanitize_json_str "$SDLC_PHASE")
    devforge_log "skill_invoked" "success" "{\"skill_name\":\"${SAFE_SKILL_NAME}\",\"sdlc_phase\":\"${SAFE_SDLC_PHASE}\"}"

    # Step 3: Save current timestamp for chaining
    NOW_NS=$(date +%s%N 2>/dev/null || echo "0")
    echo "${NOW_NS}|${SKILL_NAME}|${SDLC_PHASE}" > "$SKILL_TS_FILE"

    # Track skill names for session_end aggregation (atomic write via temp file)
    SESSION_SKILLS_FILE="${HOME}/.claude/.devforge-session-skills"
    EXISTING_SKILLS=$(cat "$SESSION_SKILLS_FILE" 2>/dev/null || echo "")
    if [ -z "$EXISTING_SKILLS" ]; then
        echo "$SKILL_NAME" > "${SESSION_SKILLS_FILE}.tmp" && mv "${SESSION_SKILLS_FILE}.tmp" "$SESSION_SKILLS_FILE"
    elif ! echo "$EXISTING_SKILLS" | grep -qF "$SKILL_NAME"; then
        echo "${EXISTING_SKILLS},${SKILL_NAME}" > "${SESSION_SKILLS_FILE}.tmp" && mv "${SESSION_SKILLS_FILE}.tmp" "$SESSION_SKILLS_FILE"
    fi
fi

# Pass through — PostToolUse hooks should not block
echo '{}'
exit 0
