#!/usr/bin/env bash
# PreToolUse hook: BLOCCA invocazione skill se prerequisiti non soddisfatti
# ─────────────────────────────────────────────────────────────────
# Hook:     sub-skill-gate
# Evento:   PreToolUse
# Matcher:  Skill
# Timeout:  5s — Check prerequisiti da mappa statica
# Formato:  decision:"block" se REQUIRED SUB-SKILL prerequisite non invocate
# History:  v1.4.0 NEW (determinismo SDLC — enforcement catena skill)
# ─── GATE CONTRACT ───
# Behavior:  fail-closed
# Requires:  SESSION_SKILLS_FILE (state)
# Reads:     ${DEVFORGE_STATE_DIR}/.devforge-session-skills
# On-missing: block (prerequisiti non verificabili)
# ─────────────────────────────────────────────────────────────────
#
# Mappa prerequisiti: skill che DEVONO essere invocate PRIMA di quella corrente.
# Derivata dall'analisi delle dichiarazioni REQUIRED SUB-SKILL nelle SKILL.md.
# Solo prerequisiti sequenziali (non dipendenze "durante esecuzione" come
# siae-verification che e' gestita da stop-gate).
# ─────────────────────────────────────────────────────────────────

set -euo pipefail

HOOK_INPUT=$(cat)

# Extract skill name from tool input
SKILL_NAME=$(echo "$HOOK_INPUT" | grep -o '"skill"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"skill"[[:space:]]*:[[:space:]]*"//;s/"$//' || true)

if [ -z "$SKILL_NAME" ]; then
    echo '{}'
    exit 0
fi

# Strip plugin prefix if present (e.g., "siae-devforge:siae-tdd" → "siae-tdd")
SKILL_NAME="${SKILL_NAME##*:}"

# ─── SDLC Stage-Based Gate ───
# Replaces hardcoded PREREQ_MAP with SDLC backbone stage checks.
# Backbone skills: checked via SDLC_BACKBONE_MAP
# Specialist skills: stage read from frontmatter backbone_stage
# Support skills: no gate, always allowed

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${PLUGIN_ROOT}/lib/logger.sh"
source "${PLUGIN_ROOT}/lib/sdlc-state.sh"

# Look up backbone stage for this skill
SKILL_STAGE=$(sdlc_lookup_stage "$SKILL_NAME")

# If not a backbone skill, check if it's a specialist with a stage
if [ -z "$SKILL_STAGE" ]; then
    SKILL_STAGE=$(node -e "
const {findSkillsInDir} = require('$PLUGIN_ROOT/lib/skills-core');
const skills = findSkillsInDir('$PLUGIN_ROOT/skills');
const s = skills.find(s => s.name === '$SKILL_NAME');
console.log(s && s.backbone_stage ? s.backbone_stage : '');
" 2>/dev/null || echo "")
fi

# No stage = support skill, no gate
if [ -z "$SKILL_STAGE" ]; then
    echo '{}'
    exit 0
fi

# Check prerequisites for the target stage
PREREQS=$(sdlc_check_prerequisites "$SKILL_STAGE")
if [ "$PREREQS" != "ok" ]; then
    MISSING="${PREREQS#missing:}"
    devforge_log "stage_gate" "blocked" "{\"skill\":\"$SKILL_NAME\",\"stage\":\"$SKILL_STAGE\",\"missing\":\"$MISSING\"}"
    cat <<EOF
{
  "decision": "block",
  "reason": "DevForge Stage Gate — BLOCCATO. La skill ${SKILL_NAME} (fase: ${SKILL_STAGE}) richiede prima: ${MISSING}. Segui il backbone SDLC."
}
EOF
    exit 0
fi

echo '{}'
exit 0
