#!/usr/bin/env bash
# PreToolUse hook: BLOCCA invocazione skill se prerequisiti non soddisfatti
# ─────────────────────────────────────────────────────────────────
# Hook:     sub-skill-gate
# Evento:   PreToolUse
# Matcher:  Skill
# Timeout:  5s — Check prerequisiti da mappa statica
# Formato:  decision:"block" se REQUIRED SUB-SKILL prerequisite non invocate
# History:  v1.4.0 NEW (determinismo SDLC — enforcement catena skill)
# ─────────────────────────────────────────────────────────────────
#
# Mappa prerequisiti: skill che DEVONO essere invocate PRIMA di quella corrente.
# Derivata dall'analisi delle dichiarazioni REQUIRED SUB-SKILL nelle SKILL.md.
# Solo prerequisiti sequenziali (non dipendenze "durante esecuzione" come
# siae-verification che e' gestita da stop-gate).
# ─────────────────────────────────────────────────────────────────

set -euo pipefail
export DEVFORGE_CURRENT_HOOK="sub-skill-gate"

HOOK_INPUT=$(cat)

# Extract skill name from tool input
SKILL_NAME=$(echo "$HOOK_INPUT" | grep -o '"skill"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"skill"[[:space:]]*:[[:space:]]*"//;s/"$//' || true)

if [ -z "$SKILL_NAME" ]; then
    echo '{}'
    exit 0
fi

# Strip plugin prefix if present (e.g., "siae-devforge:siae-tdd" → "siae-tdd")
SKILL_NAME="${SKILL_NAME##*:}"

# ─── Prerequisite Map ───
# Format: "skill_name=prereq1,prereq2"
# Only hard prerequisites (must be invoked BEFORE), not during-execution deps.
#
# Primary source: lib/prereq-map.generated (autogenerated from skill
# frontmatter + curated overrides — run lib/generate-prereq-map.sh to refresh).
# Fallback (if generated file is missing): 7-entry hardcoded map below.
SCRIPT_DIR_SSG="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT_SSG="$(cd "${SCRIPT_DIR_SSG}/.." && pwd)"
PREREQ_MAP_FILE="${PLUGIN_ROOT_SSG}/lib/prereq-map.generated"
PREREQ_MAP=()
if [ -f "$PREREQ_MAP_FILE" ]; then
    while IFS= read -r line; do
        # Skip comment (#) and empty lines
        case "$line" in
            ''|\#*) continue ;;
        esac
        PREREQ_MAP+=("$line")
    done < "$PREREQ_MAP_FILE"
fi
if [ "${#PREREQ_MAP[@]}" -eq 0 ]; then
    # Generated file missing or empty — fall back to hardcoded minimum set
    # and log the degradation so the operator can rebuild the map.
    PREREQ_MAP=(
        "siae-git-workflow=siae-git-env"
        "siae-finishing-branch=siae-git-env,siae-git-workflow"
        "siae-git-worktrees=siae-git-env"
        "siae-service-logic-map=siae-microservices-map"
        "siae-writing-plans=siae-brainstorming"
        "siae-executing-plans=siae-writing-plans"
        "siae-requesting-review=siae-finishing-branch"
    )
fi

# Find prerequisites for current skill
REQUIRED_PREREQS=""
for entry in "${PREREQ_MAP[@]}"; do
    MAP_SKILL="${entry%%=*}"
    MAP_PREREQS="${entry#*=}"
    if [ "$MAP_SKILL" = "$SKILL_NAME" ]; then
        REQUIRED_PREREQS="$MAP_PREREQS"
        break
    fi
done

# No prerequisites defined — allow
if [ -z "$REQUIRED_PREREQS" ]; then
    echo '{}'
    exit 0
fi

# Check session skills.
#
# NB: sub-skill-gate is INTENTIONALLY session-scoped (not task-scoped) —
# skill prerequisites are about invocation order within a session ("you
# must have run siae-git-env before siae-git-workflow"), not per-task
# evidence. A prereq satisfied once remains satisfied for the whole
# session. See docs/plans/anti-dilution-pr2-task-scope/task-09-sub-skill-gate-autogen.md
# (§"Out of scope") and ADR-007.
SESSION_SKILLS_FILE="${HOME}/.claude/.devforge-session-skills"
SESSION_SKILLS=$(cat "$SESSION_SKILLS_FILE" 2>/dev/null || echo "")

# Check each prerequisite
MISSING_PREREQS=""
IFS=',' read -ra PREREQS <<< "$REQUIRED_PREREQS"
for prereq in "${PREREQS[@]}"; do
    if ! echo "$SESSION_SKILLS" | grep -qF "$prereq"; then
        if [ -z "$MISSING_PREREQS" ]; then
            MISSING_PREREQS="$prereq"
        else
            MISSING_PREREQS="${MISSING_PREREQS}, ${prereq}"
        fi
    fi
done

# All prerequisites met — allow
if [ -z "$MISSING_PREREQS" ]; then
    echo '{}'
    exit 0
fi

# Prerequisites missing — BLOCK
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${PLUGIN_ROOT}/lib/logger.sh"
devforge_init_session 2>/dev/null || true
SAFE_SKILL_NAME=$(devforge_sanitize_json_str "$SKILL_NAME")
SAFE_MISSING_PREREQS=$(devforge_sanitize_json_str "$MISSING_PREREQS")
devforge_log "sub_skill_gate" "blocked" "{\"skill\":\"${SAFE_SKILL_NAME}\",\"missing_prereqs\":\"${SAFE_MISSING_PREREQS}\"}"

cat <<EOF
{
  "decision": "block",
  "reason": "DevForge Sub-Skill Gate — BLOCCATO. La skill ${SKILL_NAME} richiede come prerequisito: ${MISSING_PREREQS}. Invoca prima le skill mancanti, poi riprova ${SKILL_NAME}."
}
EOF
exit 0
