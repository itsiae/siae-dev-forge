#!/usr/bin/env bash
# UserPromptSubmit hook — injects active session context into every user message
# ─────────────────────────────────────────────────────────────────
# Hook:     user-prompt-context
# Evento:   UserPromptSubmit
# Matcher:  * (ogni messaggio utente)
# Timeout:  5s
# Formato:  additional_context (standard DevForge)
# ─────────────────────────────────────────────────────────────────
# Inspired by: https://github.com/obra/autoresearch-claude-code

set -euo pipefail
export DEVFORGE_CURRENT_HOOK="user-prompt-context"
shopt -s nullglob

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${PLUGIN_ROOT}/lib/logger.sh"
devforge_init_session 2>/dev/null || true

# Max bytes to read from a sentinel file
MAX_SENTINEL_SIZE=200

# Max age in seconds before a sentinel is considered stale (24h)
MAX_SENTINEL_AGE=86400

# Whitelist of recognized mode names
VALID_MODES="tdd|plan|brainstorming"

# Find active sentinel files in working directory
SENTINEL_FILES=(.devforge-active-*)

# No active modes → exit silently (zero overhead)
if [ ${#SENTINEL_FILES[@]} -eq 0 ]; then
    exit 0
fi

# Build context message from sentinel files
CONTEXT_LINES="DevForge Session Context:"
MODES_FOUND=0

for sentinel in "${SENTINEL_FILES[@]}"; do
    mode_name="${sentinel#.devforge-active-}"

    # Skip unrecognized modes (whitelist only)
    if ! echo "$mode_name" | grep -qE "^(${VALID_MODES})$"; then
        devforge_log "user_prompt_context" "warning" "{\"mode\":\"$(devforge_sanitize_json_str "$mode_name")\",\"reason\":\"unknown_mode\"}"
        continue
    fi

    # Skip stale sentinels (older than MAX_SENTINEL_AGE)
    file_mtime=$(stat -f%m "$sentinel" 2>/dev/null || stat -c%Y "$sentinel" 2>/dev/null || echo "0")
    now=$(date +%s)
    age=$((now - file_mtime))
    if [ "$age" -gt "$MAX_SENTINEL_AGE" ]; then
        SAFE_MODE=$(devforge_sanitize_json_str "$mode_name")
        devforge_log "user_prompt_context" "warning" "{\"mode\":\"${SAFE_MODE}\",\"reason\":\"stale_sentinel\",\"age_hours\":$((age / 3600))}"
        rm -f "$sentinel"
        continue
    fi

    # Read and sanitize content: strip control chars, limit size
    content=$(head -c "$MAX_SENTINEL_SIZE" "$sentinel" 2>/dev/null | tr -cd '[:print:]' || echo "")

    if [ -z "$content" ]; then
        SAFE_MODE=$(devforge_sanitize_json_str "$mode_name")
        devforge_log "user_prompt_context" "warning" "{\"mode\":\"${SAFE_MODE}\",\"reason\":\"empty_sentinel\"}"
        continue
    fi

    MODES_FOUND=$((MODES_FOUND + 1))

    case "$mode_name" in
        tdd)
            # Prefer global TDD state file (updated by capture-test-result state machine)
            TDD_STATE_FILE="${HOME}/.claude/.devforge-tdd-state"
            if [ -f "$TDD_STATE_FILE" ]; then
                tdd_state=$(cat "$TDD_STATE_FILE")
                phase=$(echo "$tdd_state" | cut -d'|' -f1)
                target=$(echo "$tdd_state" | cut -d'|' -f2)
                test_name=$(echo "$tdd_state" | cut -d'|' -f3)
            else
                phase=$(echo "$content" | cut -d'|' -f1)
                target=$(echo "$content" | cut -d'|' -f2)
                test_name=$(echo "$content" | cut -d'|' -f3)
            fi
            CONTEXT_LINES="${CONTEXT_LINES}\n- Modo attivo: TDD (fase ${phase})"
            [ -n "$target" ] && CONTEXT_LINES="${CONTEXT_LINES}\n- Target: ${target}"
            [ -n "$test_name" ] && CONTEXT_LINES="${CONTEXT_LINES}\n- Test: ${test_name}"
            # Phase-specific guidance
            case "$phase" in
                RED)
                    CONTEXT_LINES="${CONTEXT_LINES}\n- AZIONE: Scrivi il test. NON toccare codice produzione."
                    ;;
                GREEN)
                    CONTEXT_LINES="${CONTEXT_LINES}\n- AZIONE: Scrivi il MINIMO codice produzione per far passare il test."
                    ;;
                REFACTOR)
                    CONTEXT_LINES="${CONTEXT_LINES}\n- AZIONE: Migliora il codice. I test DEVONO restare verdi."
                    ;;
            esac
            ;;
        plan)
            CONTEXT_LINES="${CONTEXT_LINES}\n- Piano attivo: ${content}"
            ;;
        brainstorming)
            CONTEXT_LINES="${CONTEXT_LINES}\n- Brainstorming attivo: ${content}"
            ;;
    esac
done

# No valid modes processed → exit silently
if [ "$MODES_FOUND" -eq 0 ]; then
    exit 0
fi

CONTEXT_LINES="${CONTEXT_LINES}\nContinua da dove eri rimasto. Non chiedere conferma, prosegui."

# Escape for JSON
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

context_escaped=$(escape_for_json "$CONTEXT_LINES")
session_context="<EXTREMELY_IMPORTANT>\n${context_escaped}\n</EXTREMELY_IMPORTANT>"

cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "UserPromptSubmit",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
