#!/usr/bin/env bash
# PreToolUse hook: BLOCCA EnterPlanMode senza siae-brainstorming
# ─────────────────────────────────────────────────────────────────
# Hook:     plan-gate
# Evento:   PreToolUse
# Matcher:  EnterPlanMode
# Timeout:  5s — Solo check file flat
# Formato:  decision:"block" se siae-brainstorming non invocata (HARD GATE)
# History:  v1.3.0 ALLOW+warn → v1.4.0 BLOCK (determinismo SDLC)
# ─────────────────────────────────────────────────────────────────

set -euo pipefail

# Check if siae-brainstorming was invoked this session
SESSION_SKILLS_FILE="${HOME}/.claude/.devforge-session-skills"
SESSION_SKILLS=$(cat "$SESSION_SKILLS_FILE" 2>/dev/null || echo "")

if echo "$SESSION_SKILLS" | grep -qF "siae-brainstorming"; then
    echo '{}'
    exit 0
fi

# siae-brainstorming NOT invoked — BLOCK operation (hard gate)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${PLUGIN_ROOT}/lib/logger.sh"
devforge_init_session 2>/dev/null || true
devforge_log "plan_gate" "blocked" "{\"skill_missing\":\"siae-brainstorming\"}"

cat <<EOF
{
  "decision": "block",
  "reason": "DevForge Plan Gate — BLOCCATO. Stai per entrare in PlanMode ma NON hai invocato siae-brainstorming in questa sessione. NESSUNA IMPLEMENTAZIONE SENZA DESIGN APPROVATO. Invoca siae-brainstorming PRIMA di procedere: Skill tool -> siae-devforge:siae-brainstorming. Dopo il brainstorming, potrai usare EnterPlanMode."
}
EOF
exit 0
