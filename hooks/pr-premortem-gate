#!/usr/bin/env bash
# PreToolUse hook: BLOCCA `gh pr create|edit` senza siae-premortem validata
# ─────────────────────────────────────────────────────────────────
# Hook:     pr-premortem-gate
# Evento:   PreToolUse
# Matcher:  Bash
# Timeout:  10s
# Formato:  decision:"block" se siae-premortem non e' validata per il task
# History:  v1.68.0 NEW — Klein premortem method (HBR 2007) as pre-PR gate
# ─────────────────────────────────────────────────────────────────

set -euo pipefail
export DEVFORGE_CURRENT_HOOK="pr-premortem-gate"

HOOK_INPUT=$(cat)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${PLUGIN_ROOT}/lib/logger.sh" 2>/dev/null || true
source "${PLUGIN_ROOT}/lib/block-explainer.sh" 2>/dev/null || true
if ! source "${PLUGIN_ROOT}/lib/cmd-parser.sh" 2>/dev/null \
   || ! source "${PLUGIN_ROOT}/lib/task-id.sh" 2>/dev/null \
   || ! source "${PLUGIN_ROOT}/lib/evidence-check.sh" 2>/dev/null; then
    command -v devforge_log >/dev/null 2>&1 \
        && devforge_log "hook_degraded" "warning" "{\"hook\":\"pr-premortem-gate\"}" 2>/dev/null || true
fi

# Extract command from tool input
if command -v jq >/dev/null 2>&1; then
    TOOL_COMMAND=$(echo "$HOOK_INPUT" | jq -r '.command // .tool_input.command // empty' 2>/dev/null || true)
else
    TOOL_COMMAND=$(echo "$HOOK_INPUT" | grep -o '"command"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"command"[[:space:]]*:[[:space:]]*"//;s/"$//' || true)
fi

[ -z "$TOOL_COMMAND" ] && { echo '{}'; exit 0; }

# Token match: only `gh pr create` or `gh pr edit` trigger the gate.
# Segment-aware: matcha anche dentro comandi composti (cd X && env -u P gh pr create)
# — il match first-segment-only veniva bypassato (root cause PR #311).
TRIGGERS=0
if command -v devforge_cmd_has_subcommand >/dev/null 2>&1; then
    if devforge_cmd_has_subcommand "$TOOL_COMMAND" gh pr create \
       || devforge_cmd_has_subcommand "$TOOL_COMMAND" gh pr edit; then
        TRIGGERS=1
    fi
elif command -v devforge_first_token >/dev/null 2>&1; then
    FIRST=$(devforge_first_token "$TOOL_COMMAND")
    SECOND=$(devforge_second_token "$TOOL_COMMAND")
    THIRD=$(devforge_third_token "$TOOL_COMMAND")
    if [ "$FIRST" = "gh" ] && [ "$SECOND" = "pr" ]; then
        case "$THIRD" in
            create|edit) TRIGGERS=1 ;;
        esac
    fi
else
    # Conservative fallback: require `gh pr create` or `gh pr edit` leading
    NORM=$(echo "$TOOL_COMMAND" | sed -E 's/^[[:space:]]+//;s/[[:space:]]+/ /g')
    case "$NORM" in
        "gh pr create"*|"gh pr edit"*) TRIGGERS=1 ;;
    esac
fi

if [ "$TRIGGERS" != "1" ]; then
    echo '{}'
    exit 0
fi

# Scope check: itsiae/* only (consistent with other PR gates)
GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || true)
if [ -z "$GIT_ROOT" ]; then
    echo '{}'
    exit 0
fi
REMOTE_URL=$(git -C "$GIT_ROOT" remote get-url origin 2>/dev/null || true)
if ! echo "$REMOTE_URL" | grep -qE "[/:]itsiae/"; then
    echo '{}'
    exit 0
fi

devforge_init_session 2>/dev/null || true


# Validation check: task-scoped first, session-scoped fallback
USE_SESSION_SCOPE="${DEVFORGE_USE_SESSION_SCOPE:-0}"
VALIDATED=0

if [ "$USE_SESSION_SCOPE" != "1" ] \
   && command -v devforge_compute_task_id >/dev/null 2>&1 \
   && command -v devforge_skill_validated >/dev/null 2>&1; then
    TASK_ID=$(devforge_compute_task_id 2>/dev/null || echo "")
    if [ -n "$TASK_ID" ] && devforge_skill_validated siae-premortem "$TASK_ID" 2>/dev/null; then
        VALIDATED=1
    fi
fi

if [ "$VALIDATED" != "1" ]; then
    # Rollback / fallback: session-level invocation counts.
    if grep -qF "siae-premortem" "${HOME}/.claude/.devforge-session-skills" 2>/dev/null; then
        VALIDATED=1
    fi
fi

if [ "$VALIDATED" = "1" ]; then
    echo '{}'
    exit 0
fi

# Block
devforge_log "pr_premortem_gate" "blocked" "{\"task_id\":\"${TASK_ID:-}\"}"
_PM_EXPL=""
if command -v devforge_block_explainer >/dev/null 2>&1; then
    _PM_EXPL=$(devforge_block_explainer siae-premortem 2>/dev/null || true)
    [ -n "$_PM_EXPL" ] && _PM_EXPL=" ${_PM_EXPL}"
fi
cat <<EOF
{
  "decision": "block",
  "reason": "DevForge Premortem Gate — BLOCCATO. Stai aprendo/modificando una PR ma NON risulta evidenza di siae-premortem per questo task. Klein premortem (HBR 2007) trova failure mode che la code review missa per hindsight bias. Invoca siae-premortem, scrivi le top-3 cause con mitigazione, poi riprova.${_PM_EXPL}"
}
EOF
exit 0
