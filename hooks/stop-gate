#!/usr/bin/env bash
# stop-gate — Stop hook: telemetry + BLOCCA stop senza verification
# ─────────────────────────────────────────────────────────────────
# Hook:     stop-gate
# Evento:   Stop
# Matcher:  *
# Timeout:  5s — Telemetry + verification block
# Formato:  decision:"block" se completion claim senza siae-verification (HARD GATE)
# History:  v1.3.0 ALLOW+warn → v1.4.0 BLOCK (determinismo SDLC)
# ─────────────────────────────────────────────────────────────────

set -euo pipefail
export DEVFORGE_CURRENT_HOOK="stop-gate"

# --- BLOCCO 1: Setup + stdin (F5: read stdin FIRST, consumed once) ---
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${PLUGIN_ROOT}/lib/logger.sh"
devforge_init_session
source "${PLUGIN_ROOT}/lib/telemetry-upload.sh" 2>/dev/null || true

# Zero-loss PR-A: flush SYNC PRIMA dei gate, garantisce backlog drained
# anche se un gate (verification/retrospective) blocca lo stop.
# Senza questo, gli eventi della sessione restano nell'outbox finché non riapri Claude.
# Il flush dentro _devforge_emit_session_end() resta come secondo flush idempotente
# per catturare gli eventi della session_end stessa.
devforge_upload_logs 2>/dev/null || true

INPUT=$(cat)

# --- BLOCCO 2: Read counters EARLY (needed by gate checks), but do NOT emit session_end yet ---
SESSION_START_NS_FILE="${HOME}/.claude/.devforge-session-start-ns"
SESSION_COMMITS_FILE="${HOME}/.claude/.devforge-session-commits"
SESSION_SKILLS_FILE="${HOME}/.claude/.devforge-session-skills"

SESSION_START_NS=$(cat "$SESSION_START_NS_FILE" 2>/dev/null || echo "0")
COMMITS_COUNT=$(cat "$SESSION_COMMITS_FILE" 2>/dev/null || echo "0")
SKILLS_LIST=$(cat "$SESSION_SKILLS_FILE" 2>/dev/null || echo "")

if [ -n "$SKILLS_LIST" ]; then
    SKILLS_USED_COUNT=$(echo "$SKILLS_LIST" | tr ',' '\n' | sort -u | wc -l | tr -d ' ')
else
    SKILLS_USED_COUNT=0
fi

# --- Helper: emit session_end + flush (called ONLY when stop is actually permitted) ---
SESSION_END_GUARD="${HOME}/.claude/.devforge-session-end-guard"
_devforge_emit_session_end() {
    if ! mkdir "$SESSION_END_GUARD" 2>/dev/null; then
        return 0  # already emitted (guard exists)
    fi

    # Close last skill via timestamp chaining
    SKILL_TS_FILE="${HOME}/.claude/.devforge-skill-start"
    if [ -f "$SKILL_TS_FILE" ]; then
        PREV_DATA=$(cat "$SKILL_TS_FILE")
        PREV_START_NS=$(echo "$PREV_DATA" | cut -d'|' -f1)
        PREV_SKILL=$(echo "$PREV_DATA" | cut -d'|' -f2)
        PREV_PHASE=$(echo "$PREV_DATA" | cut -d'|' -f3)
        SAFE_PREV_SKILL=$(devforge_sanitize_json_str "$PREV_SKILL")
        SAFE_PREV_PHASE=$(devforge_sanitize_json_str "$PREV_PHASE")

        if [ -n "$PREV_START_NS" ] && [ -n "$PREV_SKILL" ]; then
            devforge_log_timed "skill_completed" "success" "$PREV_START_NS" \
                "{\"skill_name\":\"${SAFE_PREV_SKILL}\",\"sdlc_phase\":\"${SAFE_PREV_PHASE}\",\"outcome\":\"success\"}"
        fi
        rm -f "$SKILL_TS_FILE"
    fi

    # Refresh token stats
    python3 "${PLUGIN_ROOT}/lib/token-collector.py" update 2>/dev/null || true

    # Token stats for session_end enrichment (field contract: token-collector.py fields)
    local TOKEN_TOTAL=0 TOKEN_OUTPUT=0 TOKEN_COST_EUR="0" TOKEN_MODEL=""
    local TOKEN_INPUT=0 TOKEN_CACHE_READ=0 TOKEN_CW5M=0 TOKEN_CW1H=0
    local TOKEN_BY_MODEL="{}" TOKEN_BY_TOOL="{}"
    local TOKEN_BY_SKILL="{}" TOKEN_BY_MODEL_TOKENS="{}" TOKEN_PRICING="{}"
    if [ -n "${DEVFORGE_SESSION_DIR:-}" ] && [ -f "${DEVFORGE_SESSION_DIR}/token-stats.json" ]; then
        local TDATA
        TDATA=$(python3 "${PLUGIN_ROOT}/lib/token-collector.py" fields 2>/dev/null) || true
        if [ -n "$TDATA" ]; then
            TOKEN_TOTAL=$(printf '%s' "$TDATA" | cut -f1)
            TOKEN_OUTPUT=$(printf '%s' "$TDATA" | cut -f2)
            TOKEN_COST_EUR=$(printf '%s' "$TDATA" | cut -f3)
            TOKEN_MODEL=$(printf '%s' "$TDATA" | cut -f4)
            TOKEN_INPUT=$(printf '%s' "$TDATA" | cut -f5)
            TOKEN_CACHE_READ=$(printf '%s' "$TDATA" | cut -f6)
            TOKEN_CW5M=$(printf '%s' "$TDATA" | cut -f7)
            TOKEN_CW1H=$(printf '%s' "$TDATA" | cut -f8)
            TOKEN_BY_MODEL=$(printf '%s' "$TDATA" | cut -f9)
            TOKEN_BY_TOOL=$(printf '%s' "$TDATA" | cut -f10)
            TOKEN_BY_SKILL=$(printf '%s' "$TDATA" | cut -f11)
            TOKEN_BY_MODEL_TOKENS=$(printf '%s' "$TDATA" | cut -f12)
            TOKEN_PRICING=$(printf '%s' "$TDATA" | cut -f13)
        fi
    fi

    devforge_log_timed "session_end" "success" "$SESSION_START_NS" \
        "{\"skills_used_count\":${SKILLS_USED_COUNT},\"commits_count\":${COMMITS_COUNT},\"total_tokens\":${TOKEN_TOTAL},\"output_tokens\":${TOKEN_OUTPUT},\"cost_estimate_eur\":${TOKEN_COST_EUR},\"model_prevalent\":\"${TOKEN_MODEL}\",\"input_tokens\":${TOKEN_INPUT},\"cache_read_tokens\":${TOKEN_CACHE_READ},\"cache_write_5m_tokens\":${TOKEN_CW5M},\"cache_write_1h_tokens\":${TOKEN_CW1H},\"by_model\":${TOKEN_BY_MODEL},\"by_tool\":${TOKEN_BY_TOOL},\"by_skill\":${TOKEN_BY_SKILL},\"by_model_tokens\":${TOKEN_BY_MODEL_TOKENS},\"pricing\":${TOKEN_PRICING}}"

    # PR #3 ADR-009: 3-line recap to stderr so the operator sees adoption
    # numbers at session close (non-blocking, does NOT affect decision).
    # Opt-out via DEVFORGE_DISABLE_RECAP=1.
    if [ "${DEVFORGE_DISABLE_RECAP:-0}" != "1" ] \
       && command -v python3 >/dev/null 2>&1 \
       && [ -f "${PLUGIN_ROOT}/lib/adoption-analyzer.py" ]; then
        python3 "${PLUGIN_ROOT}/lib/adoption-analyzer.py" --format recap 2>/dev/null \
            | sed 's/^/[devforge-recap] /' >&2 || true
    fi

    # Flush telemetry
    devforge_upload_logs 2>/dev/null || true

    # Cleanup session files
    rm -f "$SESSION_START_NS_FILE" "$SESSION_COMMITS_FILE" "$SESSION_SKILLS_FILE"
    rm -f "${HOME}/.claude/.devforge-session-user" "${HOME}/.claude/.devforge-session-user-source"
    # v1.63.4 BUG A fix: cleanup session-scoped evidence bypass marker
    # (creato a runtime da utente via touch <session-dir>/.bypass-evidence
    # quando env var DEVFORGE_SKIP_EVIDENCE=1 non passa al subprocess hook)
    _SID_CLEANUP=$(cat "${HOME}/.claude/.devforge-sid" 2>/dev/null || echo "")
    if [ -n "$_SID_CLEANUP" ]; then
        rm -f "${HOME}/.claude/devforge-state/${_SID_CLEANUP}/.bypass-evidence" 2>/dev/null || true
    fi
}

# --- BLOCCO 3: Verification reminder (F5: skip if stdin empty) ---
if [ -z "$INPUT" ]; then
    _devforge_emit_session_end
    exit 0
fi

# JSON escaping is centralized in lib/logger.sh :: devforge_sanitize_json_str.
# Local alias for readability in this file.
escape_for_json() { devforge_sanitize_json_str "$1"; }

# Extract last assistant message text — cascading fallback: jq → node → python3
LAST_ASSISTANT_MSG=""
if command -v jq >/dev/null 2>&1; then
    LAST_ASSISTANT_MSG=$(echo "$INPUT" | jq -r '
        (.messages // .transcript // [])
        | map(select(.role == "assistant"))
        | last
        | if . == null then ""
          elif (.content | type) == "string" then .content
          else (.content | map(select(.type == "text") | .text) | join(" "))
          end
    ' 2>/dev/null || true)
elif command -v node >/dev/null 2>&1; then
    LAST_ASSISTANT_MSG=$(echo "$INPUT" | node -e "
        let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{
        try{const j=JSON.parse(d);const ms=(j.messages||j.transcript||[]).filter(m=>m.role==='assistant');
        const l=ms[ms.length-1];if(!l){process.stdout.write('');return;}
        const c=l.content;if(typeof c==='string')process.stdout.write(c);
        else process.stdout.write((c||[]).filter(b=>b.type==='text').map(b=>b.text).join(' '));
        }catch(e){process.stdout.write('');}});
    " 2>/dev/null || true)
elif command -v python3 >/dev/null 2>&1; then
    LAST_ASSISTANT_MSG=$(echo "$INPUT" | python3 -c "
import sys,json
try:
    j=json.load(sys.stdin)
    ms=[m for m in (j.get('messages') or j.get('transcript') or []) if m.get('role')=='assistant']
    if not ms:print('',end='')
    else:
        c=ms[-1].get('content','')
        if isinstance(c,str):print(c,end='')
        else:print(' '.join(b.get('text','') for b in c if b.get('type')=='text'),end='')
except:print('',end='')
    " 2>/dev/null || true)
else
    devforge_log "stop_gate" "warning" "{\"reason\":\"no_json_parser\",\"tried\":\"jq,node,python3\"}"
fi

# Completion claim keywords (case-insensitive check)
COMPLETION_KEYWORDS="fatto|fatti|fatta|fatte|fixato|fixata|completato|completata|completati|funziona|done|fixed|pass|implementato|implementata|risolto|risolta|aggiornato|creato|aggiunto|rimosso|corretto|pubblicato|deployato|mergeat|mergiato|finito|finita|concluso|conclusa|terminato|terminata|pronto|pronta"

if ! echo "$LAST_ASSISTANT_MSG" | grep -qiE "$COMPLETION_KEYWORDS"; then
    _devforge_emit_session_end
    exit 0
fi

# Completion claim detected — use in-memory SKILLS_LIST (file was cleaned in telemetry block above)

# --- BLOCCO 4: Retrospective gate ---
# DESIGN DECISION: hard-block deterministico (rimosso soft-block a 2 tentativi).
# Il gate scatta su qualsiasi sessione produttiva (skills>0 OR commits>0).
# Ambienti non interattivi (CI/CD, agent headless) possono bypassare via: DEVFORGE_SKIP_RETRO_GATE=1
if [ "$SKILLS_USED_COUNT" -gt 0 ] || [ "$COMMITS_COUNT" -gt 0 ]; then
    if ! echo "$SKILLS_LIST" | grep -qF "siae-retrospective"; then
        if [ "${DEVFORGE_SKIP_RETRO_GATE:-0}" = "1" ]; then
            devforge_log "stop_gate" "skipped_retro" "{\"reason\":\"DEVFORGE_SKIP_RETRO_GATE=1\",\"skills\":${SKILLS_USED_COUNT},\"commits\":${COMMITS_COUNT}}"
            _devforge_emit_session_end
            exit 0
        fi
        devforge_log "stop_gate" "blocked_retro" "{\"reason\":\"retrospective_missing\",\"skills\":${SKILLS_USED_COUNT},\"commits\":${COMMITS_COUNT}}"
        cat <<RETRO_EOF
{
  "decision": "block",
  "reason": "DevForge Retrospective Gate — Sessione produttiva (${SKILLS_USED_COUNT} skill invocate, ${COMMITS_COUNT} commit) senza siae-retrospective. Le lezioni non salvate sono lezioni perse. Invoca siae-retrospective per estrarre e persistere le lezioni apprese, poi potrai fermarti."
}
RETRO_EOF
        exit 0
    fi
fi

# --- BLOCCO 5: Verification gate — evidence-based (PR #2 ADR-006 + ADR-008) ---
#
# Gate passes when siae-verification can be proven to have run successfully
# for the current task:
#   task-scoped (default): evidence-check.sh::devforge_skill_validated
#                          (looks for verification_run event exit=0)
#   session-scoped (rollback, DEVFORGE_USE_SESSION_SCOPE=1):
#                          legacy grep of session-skills file
#
# The old 2-block auto-escape is gone (ADR-006). The only way past the gate
# without invoking verification is an EXPLICIT bypass:
#   DEVFORGE_FORCE_STOP=1 <command>
# which is tracked daily and logs bypass_abuse_suspected on the 3rd use.

source "${PLUGIN_ROOT}/lib/block-explainer.sh" 2>/dev/null || true
if ! source "${PLUGIN_ROOT}/lib/task-id.sh" 2>/dev/null \
   || ! source "${PLUGIN_ROOT}/lib/evidence-check.sh" 2>/dev/null; then
    command -v devforge_log >/dev/null 2>&1 \
        && devforge_log "hook_degraded" "warning" "{\"hook\":\"stop-gate\"}" 2>/dev/null || true
fi

USE_SESSION_SCOPE_STOP="${DEVFORGE_USE_SESSION_SCOPE:-0}"
VERIFICATION_OK=0

if [ "$USE_SESSION_SCOPE_STOP" != "1" ] \
   && command -v devforge_compute_task_id >/dev/null 2>&1 \
   && command -v devforge_skill_validated >/dev/null 2>&1; then
    TASK_ID_STOP=$(devforge_compute_task_id 2>/dev/null || echo "")
    if [ -n "$TASK_ID_STOP" ] && devforge_skill_validated siae-verification "$TASK_ID_STOP" 2>/dev/null; then
        VERIFICATION_OK=1
    fi
fi

# Session-scope fallback: if task-scope didn't validate (or rollback is set),
# accept the legacy grep. This keeps dual-write / rollback behaviour stable.
if [ "$VERIFICATION_OK" != "1" ] && echo "$SKILLS_LIST" | grep -qF "siae-verification"; then
    VERIFICATION_OK=1
fi

if [ "$VERIFICATION_OK" = "1" ]; then
    rm -f "${HOME}/.claude/.devforge-retro-reminded" 2>/dev/null
    rm -f "${HOME}/.claude/.devforge-stop-block-count" 2>/dev/null
    _devforge_emit_session_end
    exit 0
fi

# Explicit bypass — DEVFORGE_FORCE_STOP=1 (tracked, daily abuse counter)
if [ "${DEVFORGE_FORCE_STOP:-0}" = "1" ]; then
    FORCE_COUNT_FILE="${HOME}/.claude/.devforge-force-stop-count"
    TODAY=$(date -u +%Y-%m-%d)
    DATA=$(cat "$FORCE_COUNT_FILE" 2>/dev/null || echo "")
    STORED_DATE="${DATA%%|*}"
    STORED_N="${DATA##*|}"
    if [ "$STORED_DATE" != "$TODAY" ] || [ -z "$STORED_N" ]; then
        STORED_N=0
    fi
    NEW_N=$((STORED_N + 1))
    echo "${TODAY}|${NEW_N}" > "${FORCE_COUNT_FILE}.tmp" && mv "${FORCE_COUNT_FILE}.tmp" "$FORCE_COUNT_FILE"
    devforge_log "stop_gate_forced" "warning" "{\"count_today\":${NEW_N}}"
    if [ "$NEW_N" -ge 3 ]; then
        devforge_log "force_stop_abuse_suspected" "warning" "{\"count_today\":${NEW_N}}"
    fi
    _devforge_emit_session_end
    exit 0
fi

# Hard block — no auto-escape.
devforge_log "stop_gate" "blocked" "{\"reason\":\"completion_claim_without_verification\",\"task_id\":\"${TASK_ID_STOP:-}\"}"

_SG_EXPL=""
if command -v devforge_block_explainer >/dev/null 2>&1; then
    _SG_EXPL=$(devforge_block_explainer siae-verification 2>/dev/null || true)
    [ -n "$_SG_EXPL" ] && _SG_EXPL=" ${_SG_EXPL}"
fi

cat <<EOF
{
  "decision": "block",
  "reason": "DevForge Verification Gate — BLOCCATO. Il tuo ultimo output contiene un claim di completamento ma NON risulta evidenza di siae-verification per questo task. NESSUN CLAIM SENZA EVIDENZA. Invoca siae-verification e segui il protocollo IDENTIFICA -> ESEGUI -> LEGGI -> VERIFICA -> AFFERMA.${_SG_EXPL} Escape esplicito (tracciato 3/giorno): DEVFORGE_FORCE_STOP=1 <comando>."
}
EOF

exit 0
