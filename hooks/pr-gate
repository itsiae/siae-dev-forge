#!/usr/bin/env bash
# pr-gate — PreToolUse hook: blocking security scan + review gate before gh pr create/edit
# ─────────────────────────────────────────────────────────────────
# Hook:     pr-gate
# Evento:   PreToolUse
# Matcher:  Bash
# Timeout:  15s — Diff scan + security analysis
# Formato:  additional_context (standard DevForge)
# ─────────────────────────────────────────────────────────────────

set -euo pipefail
export DEVFORGE_CURRENT_HOOK="pr-gate"

HOOK_INPUT=$(cat)
if command -v jq >/dev/null 2>&1; then
    TOOL_COMMAND=$(echo "$HOOK_INPUT" | jq -r '.command // .tool_input.command // empty' 2>/dev/null || true)
else
    TOOL_COMMAND=$(echo "$HOOK_INPUT" | grep -o '"command"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"command"[[:space:]]*:[[:space:]]*"//;s/"$//' || true)
fi

# Only activate on gh pr create or gh pr edit
if [[ ! "$TOOL_COMMAND" =~ gh[[:space:]]+pr[[:space:]]+(create|edit) ]]; then
    echo '{}'
    exit 0
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

source "${PLUGIN_ROOT}/lib/logger.sh"
devforge_init_session 2>/dev/null || true
SAFE_TOOL_COMMAND=$(devforge_sanitize_json_str "$TOOL_COMMAND")
devforge_log "pr_gate" "success" "{\"check\":\"pr_security_activated\",\"command\":\"${SAFE_TOOL_COMMAND}\"}"

# ── Runner auto-bootstrap SYNC v1.63.8 ─────────────────────────
# All'apertura PR (gh pr create/edit) garantiamo i 16 runner OSS installati
# PRIMA del security scan. Modalita' --sync per coerenza: i runner DEVONO
# essere pronti quando la PR parte.
#
# Cooldown 1h gestito da runner-bootstrap.sh: se gia' eseguito di recente,
# la chiamata e' silent immediate. Cold-start (3-15min) capita SOLO al
# primissimo gh pr create di una macchina fresca.
#
# Non-blocking: warning rossi se install fallisce, ma il scan prosegue.
if [ -x "${PLUGIN_ROOT}/scripts/runner-bootstrap.sh" ]; then
    devforge_log "pr_gate" "info" "{\"check\":\"runner_bootstrap_start\"}"
    "${PLUGIN_ROOT}/scripts/runner-bootstrap.sh" --sync 2>&1 || true
    devforge_log "pr_gate" "success" "{\"check\":\"runner_bootstrap_done\"}"
fi

# JSON escaping is centralized in lib/logger.sh :: devforge_sanitize_json_str.
# Local alias for readability in this file.
escape_for_json() { devforge_sanitize_json_str "$1"; }

# ─────────────────────────────────────────────────────────────────
# SECURITY SCAN — automated, blocking
# ─────────────────────────────────────────────────────────────────

MERGE_BASE=$(git merge-base HEAD origin/sviluppo 2>/dev/null \
          || git merge-base HEAD origin/main 2>/dev/null \
          || echo "HEAD~1")

DIFF_CONTENT=$(git diff "${MERGE_BASE}...HEAD" 2>/dev/null || git diff HEAD~1 2>/dev/null || true)

CRITICAL_FINDINGS=""

# AWS Access Key
if echo "$DIFF_CONTENT" | grep -qE 'AKIA[0-9A-Z]{16}'; then
    CRITICAL_FINDINGS="${CRITICAL_FINDINGS}AWS Access Key (AKIA...) trovata nel diff\n"
fi

# Private Key (-- protetto con grep -e)
if echo "$DIFF_CONTENT" | grep -qE -e '-----BEGIN .* PRIVATE KEY-----' -e '-----BEGIN PRIVATE KEY-----'; then
    CRITICAL_FINDINGS="${CRITICAL_FINDINGS}Private key trovata nel diff\n"
fi

# Password hardcoded
if echo "$DIFF_CONTENT" | grep -qE '[pP]assword[[:space:]]*[:=][[:space:]]*"[^"]{4,}"'; then
    CRITICAL_FINDINGS="${CRITICAL_FINDINGS}Password hardcoded trovata nel diff\n"
fi

# Connection string with credentials
if echo "$DIFF_CONTENT" | grep -qE '(mysql|postgres|mongodb|redis|amqp)://[^:]+:[^@]+@'; then
    CRITICAL_FINDINGS="${CRITICAL_FINDINGS}Connection string con credenziali trovata nel diff\n"
fi

# API Key hardcoded (exclude booleans, variables, and Terraform attributes)
if echo "$DIFF_CONTENT" | grep -vE '(api_key_required|apiKeyRequired|\$\{?[A-Z_]+\}?)' | grep -qE '[aA][pP][iI][-_]?[kK][eE][yY][[:space:]]*[:=][[:space:]]*"[^"]{8,}"'; then
    CRITICAL_FINDINGS="${CRITICAL_FINDINGS}API key hardcoded trovata nel diff\n"
fi

# GitHub Personal Access Token
if echo "$DIFF_CONTENT" | grep -qE 'gh[pousr]_[A-Za-z0-9_]{36,}'; then
    CRITICAL_FINDINGS="${CRITICAL_FINDINGS}GitHub Personal Access Token trovato nel diff\n"
fi

# Stripe secret/restricted key (exclude comments, env vars, placeholder refs)
if echo "$DIFF_CONTENT" | grep -vE '(^[[:space:]]*#|^[[:space:]]*//|\$\{|process\.env|os\.environ|System\.getenv)' | grep -qE '(sk|rk)_(live|test)_[A-Za-z0-9]{20,}'; then
    CRITICAL_FINDINGS="${CRITICAL_FINDINGS}Stripe secret key trovata nel diff\n"
fi

# Bearer/JWT token (exclude comments, env vars, placeholder refs, curl examples)
if echo "$DIFF_CONTENT" | grep -vE '(^[[:space:]]*#|^[[:space:]]*//|\$\{|process\.env|os\.environ|System\.getenv|<[A-Z_]+>|example|Example)' | grep -qE '(Bearer|bearer)[[:space:]]+[A-Za-z0-9\-_\.]{20,}'; then
    CRITICAL_FINDINGS="${CRITICAL_FINDINGS}Bearer/JWT token trovato nel diff\n"
fi

# Slack token/webhook check removed — SIAE non usa Slack come canale comunicazione.

# AWS Secret Access Key (40-char base64 string near aws context keyword)
if echo "$DIFF_CONTENT" | grep -iE '(aws_secret|secret_access_key)' | grep -qE '["\x27][A-Za-z0-9/+=]{40}["\x27]'; then
    CRITICAL_FINDINGS="${CRITICAL_FINDINGS}AWS Secret Access Key trovata nel diff\n"
fi

# Generic secret assignment (exclude SDK definitions, env var refs, and comments)
if echo "$DIFF_CONTENT" | grep -vE '(^[[:space:]]*#|^[[:space:]]*//|^[[:space:]]*\*|\$\{?[A-Z_]+\}?|os\.environ|process\.env|System\.getenv|getParameter|getValue)' | grep -qE '(client_secret|secret_key|auth_token|access_token)[[:space:]]*[:=][[:space:]]*"[^"]{8,}"'; then
    CRITICAL_FINDINGS="${CRITICAL_FINDINGS}Generic secret hardcoded trovato nel diff\n"
fi

# ─────────────────────────────────────────────────────────────────
# BLOCK if critical findings
# ─────────────────────────────────────────────────────────────────

if [[ -n "$CRITICAL_FINDINGS" ]]; then
    BLOCK_REASON="DevForge PR Security Gate — BLOCCATO\n\nIssue CRITICI trovati nel diff:\n${CRITICAL_FINDINGS}\n--- Remediation ---\n1. Rimuovi i secret dal codice sorgente\n2. Usa AWS Secrets Manager, SSM Parameter Store, o variabili d'ambiente\n3. Se il secret e' gia' stato committato in history: usa BFG Repo-Cleaner per riscrivere la storia\n4. Ruota IMMEDIATAMENTE le credenziali esposte\n5. Dopo la remediation, ri-esegui gh pr create\n\nNON procedere finche' tutti i secret non sono stati rimossi."
    BLOCK_ESCAPED=$(escape_for_json "$BLOCK_REASON")
    devforge_log "pr_gate" "blocked" "{\"reason\":\"critical_secrets_found\"}"
    cat <<EOF
{
  "decision": "block",
  "reason": "${BLOCK_ESCAPED}"
}
EOF
    exit 0
fi

# ─────────────────────────────────────────────────────────────────
# SIAE Semgrep suppressions.yaml schema validation (ADR-009)
# ─────────────────────────────────────────────────────────────────

REPO_TARGET="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
SUPPRESSIONS_FILE="${REPO_TARGET}/rules/semgrep/siae/suppressions.yaml"
if [[ -f "$SUPPRESSIONS_FILE" ]]; then
  SUPP_VALIDATION_OUTPUT=$(python3 -c "
import sys
from pathlib import Path
try:
    from lib.review_evidence.suppression_validator import (
        validate_suppressions_yaml, ValidationError,
    )
    validate_suppressions_yaml(Path('$SUPPRESSIONS_FILE'))
    print('OK')
except ValidationError as e:
    print(f'FAIL: {e}', flush=True)
    sys.exit(2)
except ImportError:
    # validator module non installato (degraded mode): non-blocking warning
    print('SKIP: suppression_validator not importable', flush=True)
    sys.exit(0)
" 2>&1)
  SUPP_RC=$?
  if [[ "$SUPP_RC" == "2" ]]; then
    devforge_log "pr_gate" "fail" "{\"check\":\"suppressions_schema\",\"reason\":\"validation_failed\"}"
    BLOCK_REASON=$(printf '%s' "$SUPP_VALIDATION_OUTPUT" | head -20)
    BLOCK_ESCAPED=$(printf '%s' "$BLOCK_REASON" | python3 -c "import sys,json; print(json.dumps(sys.stdin.read())[1:-1])")
    cat <<EOF
{
  "permissionDecision": "deny",
  "reason": "DevForge PR Gate — suppressions.yaml schema ADR-009 violation:\n${BLOCK_ESCAPED}"
}
EOF
    exit 0
  fi
  devforge_log "pr_gate" "success" "{\"check\":\"suppressions_schema\",\"result\":\"$SUPP_VALIDATION_OUTPUT\"}"
fi

# ─────────────────────────────────────────────────────────────────
# Drools .drl review check (ADR-007 + EC-29 — WARNING, NON BLOCK)
# ─────────────────────────────────────────────────────────────────

# DRL files modificati nella PR (rispetto a origin/main)
DRL_FILES=$(cd "$REPO_TARGET" 2>/dev/null && git diff --name-only "origin/$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||' || echo main)"...HEAD 2>/dev/null | grep -E '\.drl$' || true)
if [[ -n "$DRL_FILES" ]]; then
  PR_LABELS="${GITHUB_PR_LABELS:-}"
  DROOLS_CHECK_OUTPUT=$(cd "$REPO_TARGET" && python3 -c "
import sys
from pathlib import Path
try:
    from lib.review_evidence.drools_check import check_drools_review
    modified = [Path(f.strip()) for f in '''$DRL_FILES'''.split('\n') if f.strip()]
    labels = [l.strip() for l in '''$PR_LABELS'''.split(',') if l.strip()]
    result = check_drools_review(modified, labels)
    print(result.message if not result.ok else f'OK via {result.method}')
except ImportError:
    print('SKIP: drools_check not importable')
" 2>&1)
  devforge_log "pr_gate" "success" "{\"check\":\"drools_review\",\"output\":\"${DROOLS_CHECK_OUTPUT:0:200}\"}"
fi

# ─────────────────────────────────────────────────────────────────
# PASS — security scan clean, inject review + security instructions
# ─────────────────────────────────────────────────────────────────

devforge_log "pr_gate" "success" "{\"check\":\"security_scan_clean\"}"

read -r -d '' PR_GATE_INSTRUCTIONS << 'INSTRUCTIONS_EOF' || true
# DevForge PR Gate — Security scan PASSED

Il security scan automatico e' passato (nessun secret nel diff).

## AZIONE OBBLIGATORIA — Dispatch Agent Review

DEVI dispatchare ENTRAMBI gli agent ADESSO, PRIMA di eseguire gh pr create.
Questo NON e' opzionale. NON e' un suggerimento. E' un gate bloccante.

### Step 0: Ottieni il diff (OBBLIGATORIO)

```bash
git diff origin/main...HEAD
```

Salva l'output. Lo passerai nel prompt di ENTRAMBI gli agent.
NON passare i path dei file — passa il DIFF TESTUALE. Leggere file interi spreca token.

### Step 1: Dispatch code-reviewer agent

Usa il tool Agent con subagent_type siae-devforge:code-reviewer.
Il prompt deve includere: il DIFF TESTUALE (da Step 0), design doc se presente.
L'agent NON deve usare Read/Glob per leggere file — tutto il contesto e' nel diff.
ATTENDI il risultato.

Se il verdetto e' BLOCKED (>= 1 CRITICAL): BLOCCA la PR. NON procedere.
Se il verdetto e' CHANGES REQUESTED (>= 1 MAJOR): mostra all'utente e chiedi conferma.
Se il verdetto e' APPROVED: procedi.

### Step 2: Dispatch spec-reviewer agent

Usa il tool Agent con subagent_type siae-devforge:spec-reviewer.
Il prompt deve includere: il DIFF TESTUALE (da Step 0), design doc path per i criteri di accettazione.
L'agent NON deve leggere i file interi — solo il diff + criteri dal design doc.
ATTENDI il risultato.

Se il verdetto e' FAIL: mostra discrepanze e chiedi conferma all'utente.
Se il verdetto e' PASS: procedi.

### Step 3: Verifica versione plugin.json

```bash
LATEST_TAG=$(gh release list --limit 1 --json tagName --jq '.[0].tagName' 2>/dev/null || echo "")
CURRENT_VERSION=$(python3 -c "import json; print(json.load(open('.claude-plugin/plugin.json'))['version'])" 2>/dev/null || echo "")
echo "Ultimo release: $LATEST_TAG"
echo "plugin.json:    v$CURRENT_VERSION"
```

Se versioni uguali: avvisa l'utente che la versione non e' stata aggiornata.

### Step 4: Solo dopo aver completato 1-3, procedi con `gh pr create`

Se hai saltato Step 1 o Step 2, stai violando il gate. FERMATI e torna indietro.

| Pensiero | Realta' |
|----------|---------|
| "Sono solo file markdown, non serve review" | Ogni PR merita review. I bug nascono dalle assunzioni. |
| "Ho gia' verificato io" | Il self-review ha bias. Gli agent sono indipendenti. |
| "L'utente ha fretta" | I bug in produzione rallentano piu' di una review. |
| "Gli agent sono lenti" | Lancia entrambi in parallelo. |
INSTRUCTIONS_EOF

pr_gate_escaped=$(escape_for_json "$PR_GATE_INSTRUCTIONS")
pr_gate_context="<EXTREMELY_IMPORTANT>\nDevForge PR Gate attivo — security scan PASSED.\n\n${pr_gate_escaped}\n</EXTREMELY_IMPORTANT>"

cat <<EOF
{
  "additional_context": "${pr_gate_context}",
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "additionalContext": "${pr_gate_context}"
  }
}
EOF

exit 0
