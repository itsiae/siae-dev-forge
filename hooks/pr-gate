#!/usr/bin/env bash
# pr-gate — PreToolUse hook: blocking security scan + review gate before gh pr create/edit

set -euo pipefail

HOOK_INPUT=$(cat)
TOOL_COMMAND=$(echo "$HOOK_INPUT" | grep -o '"command"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"command"[[:space:]]*:[[:space:]]*"//;s/"$//' || true)

# Only activate on gh pr create or gh pr edit
if [[ ! "$TOOL_COMMAND" =~ gh[[:space:]]+pr[[:space:]]+(create|edit) ]]; then
    echo '{}'
    exit 0
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

source "${PLUGIN_ROOT}/lib/logger.sh"
devforge_log "pr_gate" "success" "{\"check\":\"pr_security_activated\",\"command\":\"${TOOL_COMMAND}\"}"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# ─────────────────────────────────────────────────────────────────
# SECURITY SCAN — automated, blocking
# ─────────────────────────────────────────────────────────────────

MERGE_BASE=$(git merge-base HEAD origin/sviluppo 2>/dev/null \
          || git merge-base HEAD origin/main 2>/dev/null \
          || echo "HEAD~1")

DIFF_CONTENT=$(git diff "${MERGE_BASE}...HEAD" 2>/dev/null || git diff HEAD~1 2>/dev/null || true)

CRITICAL_FINDINGS=""

# AWS Access Key
if echo "$DIFF_CONTENT" | grep -qE 'AKIA[0-9A-Z]{16}'; then
    CRITICAL_FINDINGS="${CRITICAL_FINDINGS}AWS Access Key (AKIA...) trovata nel diff\n"
fi

# Private Key (-- protetto con grep -e)
if echo "$DIFF_CONTENT" | grep -qE -e '-----BEGIN .* PRIVATE KEY-----' -e '-----BEGIN PRIVATE KEY-----'; then
    CRITICAL_FINDINGS="${CRITICAL_FINDINGS}Private key trovata nel diff\n"
fi

# Password hardcoded
if echo "$DIFF_CONTENT" | grep -qE '[pP]assword[[:space:]]*[:=][[:space:]]*"[^"]{4,}"'; then
    CRITICAL_FINDINGS="${CRITICAL_FINDINGS}Password hardcoded trovata nel diff\n"
fi

# Connection string with credentials
if echo "$DIFF_CONTENT" | grep -qE '(mysql|postgres|mongodb)://[^:]+:[^@]+@'; then
    CRITICAL_FINDINGS="${CRITICAL_FINDINGS}Connection string con credenziali trovata nel diff\n"
fi

# API Key hardcoded
if echo "$DIFF_CONTENT" | grep -qE '[aA][pP][iI][-_]?[kK][eE][yY][[:space:]]*[:=][[:space:]]*"[^"]{8,}"'; then
    CRITICAL_FINDINGS="${CRITICAL_FINDINGS}API key hardcoded trovata nel diff\n"
fi

# ─────────────────────────────────────────────────────────────────
# BLOCK if critical findings
# ─────────────────────────────────────────────────────────────────

if [[ -n "$CRITICAL_FINDINGS" ]]; then
    BLOCK_REASON="DevForge PR Security Gate — BLOCCATO\n\nIssue CRITICI trovati nel diff:\n${CRITICAL_FINDINGS}\nRisolvi questi problemi prima di creare la PR. NON procedere."
    BLOCK_ESCAPED=$(escape_for_json "$BLOCK_REASON")
    devforge_log "pr_gate" "blocked" "{\"reason\":\"critical_secrets_found\"}"
    cat <<EOF
{
  "decision": "block",
  "reason": "${BLOCK_ESCAPED}"
}
EOF
    exit 0
fi

# ─────────────────────────────────────────────────────────────────
# PASS — security scan clean, inject review + security instructions
# ─────────────────────────────────────────────────────────────────

devforge_log "pr_gate" "success" "{\"check\":\"security_scan_clean\"}"

read -r -d '' PR_GATE_INSTRUCTIONS << 'INSTRUCTIONS_EOF' || true
# DevForge PR Gate — Security scan PASSED, review gate attivo

Il security scan automatico e' passato (nessun secret nel diff).

## OBBLIGATORIO — Prima di eseguire `gh pr create`:

### 1. Code Review
Invoca l'agent `siae-devforge:code-reviewer` sui file modificati in questo branch.
Se il code-reviewer restituisce BLOCKED o CHANGES REQUESTED con severity CRITICAL:
**NON procedere con gh pr create. Risolvi prima.**

### 2. Security Review
Invoca l'agent `siae-devforge:siae-security` per verificare:
- Nessuna IAM policy con `"*"` su Action o Resource
- Nessun S3 bucket pubblico
- Nessun dato PII (ISRC, IBAN, codice_fiscale) in log o console.log
Se trovati issue ALTO o CRITICO: **NON procedere. Risolvi prima.**

### 3. Verifica versione plugin.json

```bash
LATEST_TAG=$(gh release list --limit 1 --json tagName --jq '.[0].tagName' 2>/dev/null || echo "")
CURRENT_VERSION=$(python3 -c "import json; print(json.load(open('.claude-plugin/plugin.json'))['version'])" 2>/dev/null || echo "")
echo "Ultimo release: $LATEST_TAG"
echo "plugin.json:    v$CURRENT_VERSION"
```

Se versioni uguali: avvisa l'utente che la versione non e' stata aggiornata.

### 4. Solo dopo aver completato 1-3, procedi con `gh pr create`

NON saltare questi step. NON razionalizzare. Il gate esiste per proteggere il repository.
INSTRUCTIONS_EOF

pr_gate_escaped=$(escape_for_json "$PR_GATE_INSTRUCTIONS")
pr_gate_context="<EXTREMELY_IMPORTANT>\nDevForge PR Gate attivo — security scan PASSED.\n\n${pr_gate_escaped}\n</EXTREMELY_IMPORTANT>"

cat <<EOF
{
  "additional_context": "${pr_gate_context}",
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "additionalContext": "${pr_gate_context}"
  }
}
EOF

exit 0
