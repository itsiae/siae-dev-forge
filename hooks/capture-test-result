#!/usr/bin/env bash
# PostToolUse hook — captures test results from Bash commands
# ─────────────────────────────────────────────────────────────────
# Hook:     capture-test-result
# Evento:   PostToolUse
# Matcher:  Bash
# Timeout:  10s
# ─────────────────────────────────────────────────────────────────
# Detects test-related commands and saves a summary of results
# to ~/.claude/.devforge-last-test-result for context injection.

set -euo pipefail
export DEVFORGE_CURRENT_HOOK="capture-test-result"

STATE_DIR="${HOME}/.claude"
RESULT_FILE="${STATE_DIR}/.devforge-last-test-result"

# Source the activity logger for raw telemetry (Comp.2). MUST be best-effort: a
# missing logger must never abort a test run under set -euo pipefail.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${PLUGIN_ROOT}/lib/logger.sh" 2>/dev/null || true
devforge_init_session 2>/dev/null || true

# Read tool input from stdin (Claude passes JSON with tool_input)
INPUT=$(cat)

# Extract fields using jq (handles escaped quotes in JSON values correctly)
# Fallback to grep for environments without jq.
# Claude Code PostToolUse schema: tool_input.command, tool_response.is_error (boolean).
# Note: tool_response.exit_code does NOT exist in real Claude Code payloads — it is
# present only in synthetic/test payloads. Exit status is derived from is_error.
if command -v jq >/dev/null 2>&1; then
    COMMAND=$(echo "$INPUT" | jq -r '.command // .tool_input.command // ""' 2>/dev/null || echo "")
    # Claude Code PostToolUse Bash payload has no exit_code field: derive it from
    # tool_response.is_error (false=0, true=1) when the numeric field is absent.
    EXIT_CODE=$(echo "$INPUT" | jq -r '
      .exit_code //
      .tool_output.exit_code //
      .tool_response.exit_code //
      (if .tool_response.is_error == true then "1"
       elif .tool_response.is_error == false then "0"
       else "" end)
    ' 2>/dev/null || echo "")
    STDOUT=$(echo "$INPUT" | jq -r '.stdout // .tool_output.stdout // .tool_response.stdout // .tool_response.output // ""' 2>/dev/null || echo "")
else
    COMMAND=$(echo "$INPUT" | grep -o '"command"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/"command"[[:space:]]*:[[:space:]]*"//;s/"$//' || echo "")
    EXIT_CODE=$(echo "$INPUT" | grep -o '"exit_code"[[:space:]]*:[[:space:]]*[0-9]*' | head -1 | grep -o '[0-9]*$' || echo "")
    # Fallback: derive exit code from is_error when exit_code absent
    if [ -z "$EXIT_CODE" ]; then
        IS_ERROR=$(echo "$INPUT" | grep -o '"is_error"[[:space:]]*:[[:space:]]*[a-z]*' | head -1 | grep -o '[a-z]*$' || echo "")
        if [ "$IS_ERROR" = "false" ]; then EXIT_CODE="0"; elif [ "$IS_ERROR" = "true" ]; then EXIT_CODE="1"; fi
    fi
    STDOUT=$(echo "$INPUT" | grep -o '"stdout"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/"stdout"[[:space:]]*:[[:space:]]*"//;s/"$//' || echo "")
fi

# Only care about test-related commands
if ! echo "$COMMAND" | grep -qiE '(test|jest|vitest|pytest|mvn.*test|gradle.*test|npm.*test|yarn.*test|go test|cargo test|run-all\.sh|\.spec\.|\.test\.)'; then
    exit 0
fi

# --- TDD State Machine: FIRST — critical path, must survive before any I/O ---
# Positioned before RESULT_FILE write and coverage extraction to ensure it
# completes within timeout even when stdout is large.
SESSION_SKILLS_FILE="${HOME}/.claude/.devforge-session-skills"
SESSION_SKILLS=$(cat "$SESSION_SKILLS_FILE" 2>/dev/null || echo "")

if echo "$SESSION_SKILLS" | grep -qF "siae-tdd"; then
    TDD_STATE_FILE="${STATE_DIR}/.devforge-tdd-state"
    CURRENT_STATE=$(cat "$TDD_STATE_FILE" 2>/dev/null || echo "")
    CURRENT_PHASE=$(echo "$CURRENT_STATE" | cut -d'|' -f1)
    _TDD_PREV_EPOCH=$(echo "$CURRENT_STATE" | cut -d'|' -f4)

    if [ "$EXIT_CODE" = "0" ]; then
        # Test PASS
        case "$CURRENT_PHASE" in
            INIT)
                # INIT + PASS = test passed immediately → not TDD (test existed already)
                # Stay INIT — user needs to write a NEW failing test
                ;;
            RED)
                # RED + PASS = transition to GREEN (implementation code made test pass)
                echo "GREEN|$(echo "$CURRENT_STATE" | cut -d'|' -f2)|$(echo "$CURRENT_STATE" | cut -d'|' -f3)|$(date +%s)" > "$TDD_STATE_FILE"
                ;;
            GREEN)
                # GREEN + PASS = stay GREEN (refactor safe, tests still passing)
                ;;
            REFACTOR)
                # REFACTOR + PASS = stay REFACTOR (refactor safe)
                ;;
        esac
    else
        # Test FAIL (EXIT_CODE non-zero or empty when field not found in payload)
        case "$CURRENT_PHASE" in
            ""|NONE|INIT)
                # INIT/empty + FAIL = first failing test confirmed → enter RED
                echo "RED|unknown|test-confirmed|$(date +%s)" > "$TDD_STATE_FILE"
                ;;
            GREEN)
                # GREEN + FAIL = regression! Back to RED
                echo "RED|$(echo "$CURRENT_STATE" | cut -d'|' -f2)|regression|$(date +%s)" > "$TDD_STATE_FILE"
                ;;
            REFACTOR)
                # REFACTOR + FAIL = regression during refactor! Back to RED
                echo "RED|$(echo "$CURRENT_STATE" | cut -d'|' -f2)|refactor-regression|$(date +%s)" > "$TDD_STATE_FILE"
                ;;
            RED)
                # RED + FAIL = expected, stay RED
                ;;
        esac
    fi
fi

# Comp.2: emit tdd_cycle on a phase transition (RED→GREEN, GREEN→RED regression, …).
# Raw: from/to/elapsed_sec/reason. Best-effort, never aborts the test run.
if [ -n "${TDD_STATE_FILE:-}" ] && command -v devforge_log >/dev/null 2>&1; then
    _TDD_NEW_STATE=$(cat "$TDD_STATE_FILE" 2>/dev/null || echo "")
    _TDD_NEW_PHASE=$(echo "$_TDD_NEW_STATE" | cut -d'|' -f1)
    _TDD_NEW_REASON=$(echo "$_TDD_NEW_STATE" | cut -d'|' -f3)
    if [ -n "${CURRENT_PHASE:-}" ] && [ -n "$_TDD_NEW_PHASE" ] && [ "$_TDD_NEW_PHASE" != "${CURRENT_PHASE}" ]; then
        _TDD_ELAPSED=0
        if [[ "${_TDD_PREV_EPOCH:-}" =~ ^[0-9]+$ ]]; then
            _TDD_ELAPSED=$(( $(date +%s) - _TDD_PREV_EPOCH ))
            [ "$_TDD_ELAPSED" -lt 0 ] && _TDD_ELAPSED=0
        fi
        _SAFE_REASON=$(devforge_sanitize_json_str "${_TDD_NEW_REASON:-}")
        devforge_log "tdd_cycle" "success" \
            "{\"from_phase\":\"${CURRENT_PHASE}\",\"to_phase\":\"${_TDD_NEW_PHASE}\",\"elapsed_sec\":${_TDD_ELAPSED},\"reason\":\"${_SAFE_REASON}\"}" || true
    fi
fi

# Build summary
NOW=$(date '+%H:%M')
if [ "$EXIT_CODE" = "0" ]; then
    STATUS="PASS"
else
    STATUS="FAIL (exit ${EXIT_CODE})"
fi

# Extract key lines from output (pass/fail counts, errors)
SUMMARY_LINES=""
if [ -n "$STDOUT" ]; then
    # Common test framework patterns
    SUMMARY_LINES=$(echo "$STDOUT" | grep -iE '(passed|failed|error|Tests run|test suites|FAIL|OK|SUCCESS|assertions)' | tail -5 || echo "")
fi

{
    echo "${STATUS} at ${NOW} — cmd: ${COMMAND}"
    [ -n "$SUMMARY_LINES" ] && echo "$SUMMARY_LINES"
} > "$RESULT_FILE"

# --- Coverage Extraction: parse coverage % from test output ---
COVERAGE_FILE="${STATE_DIR}/.devforge-last-coverage"
COVERAGE_PCT=""

if [ -n "$STDOUT" ]; then
    # Jest/Vitest: "All files | 85.71 | 100 | 75 | 85.71"
    if [ -z "$COVERAGE_PCT" ]; then
        COVERAGE_PCT=$(echo "$STDOUT" | grep -oE 'All files[[:space:]]*\|[[:space:]]*[0-9]+(\.[0-9]+)?' | head -1 | grep -oE '[0-9]+(\.[0-9]+)?$' || true)
    fi
    # Jest/Vitest/Istanbul: "Statements   : 85.71%"
    if [ -z "$COVERAGE_PCT" ]; then
        COVERAGE_PCT=$(echo "$STDOUT" | grep -oiE 'Statements[[:space:]]*:?[[:space:]]*[0-9]+(\.[0-9]+)?%' | head -1 | grep -oE '[0-9]+(\.[0-9]+)?' || true)
    fi
    # pytest-cov: "TOTAL    150     30    80%"
    if [ -z "$COVERAGE_PCT" ]; then
        COVERAGE_PCT=$(echo "$STDOUT" | grep -oE 'TOTAL[[:space:]]+[0-9]+[[:space:]]+[0-9]+[[:space:]]+[0-9]+%' | head -1 | grep -oE '[0-9]+%' | tr -d '%' || true)
    fi
    # Go: "coverage: 82.3% of statements"
    if [ -z "$COVERAGE_PCT" ]; then
        COVERAGE_PCT=$(echo "$STDOUT" | grep -oE 'coverage:[[:space:]]*[0-9]+(\.[0-9]+)?%' | head -1 | grep -oE '[0-9]+(\.[0-9]+)?' || true)
    fi
    # JaCoCo summary: "Total coverage: 75%" or "Coverage: 75.5%"
    if [ -z "$COVERAGE_PCT" ]; then
        COVERAGE_PCT=$(echo "$STDOUT" | grep -oiE '[Cc]overage:?[[:space:]]*[0-9]+(\.[0-9]+)?%' | head -1 | grep -oE '[0-9]+(\.[0-9]+)?' || true)
    fi
    # Vitest v8: "% Lines" header followed by data — "  85.71" in the All files row
    if [ -z "$COVERAGE_PCT" ]; then
        COVERAGE_PCT=$(echo "$STDOUT" | grep -oE '^\s*[0-9]+(\.[0-9]+)?\s*\|' | head -1 | grep -oE '[0-9]+(\.[0-9]+)?' || true)
    fi
fi

if [ -n "$COVERAGE_PCT" ]; then
    echo "${COVERAGE_PCT}|$(date +%s)|${COMMAND}" > "$COVERAGE_FILE"
fi

# Comp.2: emit test_run_result raw (status, exit, coverage, framework). Best-effort.
if command -v devforge_log >/dev/null 2>&1; then
    _TRR_STATUS="PASS"; [ "$EXIT_CODE" != "0" ] && _TRR_STATUS="FAIL"
    _TRR_FRAMEWORK="unknown"
    case "$COMMAND" in
        *pytest*) _TRR_FRAMEWORK="pytest" ;;
        *vitest*) _TRR_FRAMEWORK="vitest" ;;
        *jest*)   _TRR_FRAMEWORK="jest" ;;
        *mvn*)    _TRR_FRAMEWORK="maven" ;;
        *gradle*) _TRR_FRAMEWORK="gradle" ;;
        *"go test"*) _TRR_FRAMEWORK="go" ;;
        *"cargo test"*) _TRR_FRAMEWORK="cargo" ;;
    esac
    _TRR_COV="${COVERAGE_PCT:-null}"
    _TRR_EXIT="${EXIT_CODE:-}"
    [[ "$_TRR_EXIT" =~ ^[0-9]+$ ]] || _TRR_EXIT="null"
    devforge_log "test_run_result" "success" \
        "{\"status\":\"${_TRR_STATUS}\",\"exit_code\":${_TRR_EXIT},\"coverage_pct\":${_TRR_COV},\"framework\":\"${_TRR_FRAMEWORK}\"}" || true
fi

exit 0
