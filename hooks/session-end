#!/usr/bin/env bash
# session-end — SessionEnd hook: emette session_end con conteggi accumulati.
# ─────────────────────────────────────────────────────────────────
# Hook:     session-end
# Evento:   SessionEnd
# Matcher:  "" (tutti i reason: clear/resume/logout/prompt_input_exit/other)
# Timeout:  async:false — only cleanup/logging, non puo' bloccare
# Formato:  echo '{}' (SessionEnd non puo' emettere decision:block)
# History:  v1.93.0 — estratto da stop-gate::_devforge_emit_session_end SENZA il
#           blocco rm dello stato di sessione. Lo Stop fira per-turno e cancellava
#           lo stato a meta'-sessione (bloccava il git gate); session_end migra qui
#           dove i conteggi sono accumulati fino alla fine reale. Il reset dello
#           stato resta di competenza di session-start (per `source`).
# Design:   docs/plans/2026-06-19-stop-gate-session-lifecycle-fix-design.md
# ─────────────────────────────────────────────────────────────────

set -euo pipefail
export DEVFORGE_CURRENT_HOOK="session-end"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${PLUGIN_ROOT}/lib/logger.sh"
devforge_init_session 2>/dev/null || true
source "${PLUGIN_ROOT}/lib/telemetry-upload.sh" 2>/dev/null || true

# reason (diagnostico, NON entra nello schema dell'event session_end — design §3.6).
INPUT=$(cat 2>/dev/null || echo "")
REASON="other"
if command -v jq >/dev/null 2>&1 && [ -n "$INPUT" ]; then
    REASON=$(printf '%s' "$INPUT" | jq -r '.reason // "other"' 2>/dev/null || echo "other")
fi

SESSION_START_NS_FILE="${HOME}/.claude/.devforge-session-start-ns"
SESSION_COMMITS_FILE="${HOME}/.claude/.devforge-session-commits"
SESSION_SKILLS_FILE="${HOME}/.claude/.devforge-session-skills"
SESSION_END_GUARD="${HOME}/.claude/.devforge-session-end-guard"

# Guard at-most-once per segmento (clearato da session-start all'avvio successivo).
if ! mkdir "$SESSION_END_GUARD" 2>/dev/null; then
    echo '{}'; exit 0
fi

SESSION_START_NS=$(cat "$SESSION_START_NS_FILE" 2>/dev/null || echo "0")
COMMITS_COUNT=$(cat "$SESSION_COMMITS_FILE" 2>/dev/null || echo "0")
SKILLS_LIST=$(cat "$SESSION_SKILLS_FILE" 2>/dev/null || echo "")
if [ -n "$SKILLS_LIST" ]; then
    SKILLS_USED_COUNT=$(echo "$SKILLS_LIST" | tr ',' '\n' | sort -u | wc -l | tr -d ' ')
else
    SKILLS_USED_COUNT=0
fi

# Close last skill via timestamp chaining (portato da stop-gate).
SKILL_TS_FILE="${HOME}/.claude/.devforge-skill-start"
if [ -f "$SKILL_TS_FILE" ]; then
    PREV_DATA=$(cat "$SKILL_TS_FILE")
    PREV_START_NS=$(echo "$PREV_DATA" | cut -d'|' -f1)
    PREV_SKILL=$(echo "$PREV_DATA" | cut -d'|' -f2)
    PREV_PHASE=$(echo "$PREV_DATA" | cut -d'|' -f3)
    SAFE_PREV_SKILL=$(devforge_sanitize_json_str "$PREV_SKILL")
    SAFE_PREV_PHASE=$(devforge_sanitize_json_str "$PREV_PHASE")

    if [ -n "$PREV_START_NS" ] && [ -n "$PREV_SKILL" ]; then
        devforge_log_timed "skill_completed" "success" "$PREV_START_NS" \
            "{\"skill_name\":\"${SAFE_PREV_SKILL}\",\"sdlc_phase\":\"${SAFE_PREV_PHASE}\",\"outcome\":\"success\"}" || true
    fi
    # skill-start NON e' stato di sessione (resettato da session-start) — ok rimuoverlo.
    rm -f "$SKILL_TS_FILE"
fi

# Refresh token stats
python3 "${PLUGIN_ROOT}/lib/token-collector.py" update 2>/dev/null || true

# Token stats for session_end enrichment (field contract: token-collector.py fields)
TOKEN_TOTAL=0 TOKEN_OUTPUT=0 TOKEN_COST_EUR="0" TOKEN_MODEL=""
TOKEN_INPUT=0 TOKEN_CACHE_READ=0 TOKEN_CW5M=0 TOKEN_CW1H=0
TOKEN_BY_MODEL="{}" TOKEN_BY_TOOL="{}"
TOKEN_BY_SKILL="{}" TOKEN_BY_MODEL_TOKENS="{}" TOKEN_PRICING="{}"
# Fail-closed: di default lo stato e' "incompleto". Il consumer scarta i blocchi
# con token_state_complete=false invece di contare gli zeri come dati reali.
TOKEN_STATE_COMPLETE="false"
if [ -n "${DEVFORGE_SESSION_DIR:-}" ] && [ -f "${DEVFORGE_SESSION_DIR}/token-stats.json" ]; then
    TDATA=$(python3 "${PLUGIN_ROOT}/lib/token-collector.py" fields 2>/dev/null) || true
    if [ -n "$TDATA" ]; then
        TOKEN_TOTAL=$(printf '%s' "$TDATA" | cut -f1)
        TOKEN_OUTPUT=$(printf '%s' "$TDATA" | cut -f2)
        TOKEN_COST_EUR=$(printf '%s' "$TDATA" | cut -f3)
        TOKEN_MODEL=$(printf '%s' "$TDATA" | cut -f4)
        TOKEN_INPUT=$(printf '%s' "$TDATA" | cut -f5)
        TOKEN_CACHE_READ=$(printf '%s' "$TDATA" | cut -f6)
        TOKEN_CW5M=$(printf '%s' "$TDATA" | cut -f7)
        TOKEN_CW1H=$(printf '%s' "$TDATA" | cut -f8)
        TOKEN_BY_MODEL=$(printf '%s' "$TDATA" | cut -f9)
        TOKEN_BY_TOOL=$(printf '%s' "$TDATA" | cut -f10)
        TOKEN_BY_SKILL=$(printf '%s' "$TDATA" | cut -f11)
        TOKEN_BY_MODEL_TOKENS=$(printf '%s' "$TDATA" | cut -f12)
        TOKEN_PRICING=$(printf '%s' "$TDATA" | cut -f13)
        TOKEN_STATE_COMPLETE=$(printf '%s' "$TDATA" | cut -f14)
        # Guardia: se f14 manca/non-booleano (contratto vecchio), resta "false"
        case "$TOKEN_STATE_COMPLETE" in true|false) ;; *) TOKEN_STATE_COMPLETE="false" ;; esac
    fi
fi

devforge_log_timed "session_end" "success" "$SESSION_START_NS" \
    "{\"skills_used_count\":${SKILLS_USED_COUNT},\"commits_count\":${COMMITS_COUNT},\"total_tokens\":${TOKEN_TOTAL},\"output_tokens\":${TOKEN_OUTPUT},\"cost_estimate_eur\":${TOKEN_COST_EUR},\"model_prevalent\":\"${TOKEN_MODEL}\",\"input_tokens\":${TOKEN_INPUT},\"cache_read_tokens\":${TOKEN_CACHE_READ},\"cache_write_5m_tokens\":${TOKEN_CW5M},\"cache_write_1h_tokens\":${TOKEN_CW1H},\"by_model\":${TOKEN_BY_MODEL},\"by_tool\":${TOKEN_BY_TOOL},\"by_skill\":${TOKEN_BY_SKILL},\"by_model_tokens\":${TOKEN_BY_MODEL_TOKENS},\"pricing\":${TOKEN_PRICING},\"token_state_complete\":${TOKEN_STATE_COMPLETE}}"

# task_adoption (Layer 1) — best-effort, non blocca lo Stop/SessionEnd.
if [ -f "${PLUGIN_ROOT}/lib/adoption-emit.sh" ]; then
    # shellcheck disable=SC1091
    . "${PLUGIN_ROOT}/lib/adoption-emit.sh" 2>/dev/null || true
    devforge_emit_task_adoption 2>/dev/null || true
fi

# Recap 3-righe a stderr (non-blocking). Opt-out via DEVFORGE_DISABLE_RECAP=1.
if [ "${DEVFORGE_DISABLE_RECAP:-0}" != "1" ] \
   && command -v python3 >/dev/null 2>&1 \
   && [ -f "${PLUGIN_ROOT}/lib/adoption-analyzer.py" ]; then
    python3 "${PLUGIN_ROOT}/lib/adoption-analyzer.py" --format recap 2>/dev/null \
        | sed 's/^/[devforge-recap] /' >&2 || true
fi

# Flush telemetry. NESSUN rm dei file di stato: il reset e' di session-start.
devforge_upload_logs 2>/dev/null || true

echo '{}'
exit 0
