#!/usr/bin/env bash
# UserPromptSubmit hook — always-on lightweight context injection
# ─────────────────────────────────────────────────────────────────
# Hook:     devforge-context-always
# Evento:   UserPromptSubmit
# Matcher:  * (ogni messaggio utente)
# Timeout:  5s
# Formato:  additional_context (standard DevForge)
# ─────────────────────────────────────────────────────────────────
# Injects: git state, session stats, last test results, PR context.
# Runs every message — must stay under 200ms.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

STATE_DIR="${HOME}/.claude"

# ── Git State ───────────────────────────────────────────────────
# Only if we're in a git repo
GIT_SECTION=""
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    GIT_BRANCH=$(git branch --show-current 2>/dev/null || echo "detached")
    GIT_LAST_COMMIT=$(git log --oneline -1 2>/dev/null || echo "no commits")
    GIT_DIRTY_COUNT=$(git status --short 2>/dev/null | wc -l | tr -d ' ')
    GIT_DIRTY_FILES=""
    if [ "$GIT_DIRTY_COUNT" -gt 0 ] && [ "$GIT_DIRTY_COUNT" -le 15 ]; then
        GIT_DIRTY_FILES=$(git status --short 2>/dev/null | head -15 | tr '\n' ', ' | sed 's/,$//')
    elif [ "$GIT_DIRTY_COUNT" -gt 15 ]; then
        GIT_DIRTY_FILES="${GIT_DIRTY_COUNT} file modificati (troppi per elencarli)"
    fi

    GIT_SECTION="Git: branch=${GIT_BRANCH} | last_commit=${GIT_LAST_COMMIT} | dirty=${GIT_DIRTY_COUNT}"
    [ -n "$GIT_DIRTY_FILES" ] && GIT_SECTION="${GIT_SECTION}\\n  Files: ${GIT_DIRTY_FILES}"

    # ── PR Context (only on feature branches, cached) ───────────
    PR_SECTION=""
    if echo "$GIT_BRANCH" | grep -qE '^(feature|fix|hotfix|bugfix)/' && command -v gh >/dev/null 2>&1; then
        # Cache PR info to avoid hitting API every message
        PR_CACHE="${STATE_DIR}/.devforge-pr-cache-$(echo "$GIT_BRANCH" | md5sum 2>/dev/null | cut -d' ' -f1 || echo "$GIT_BRANCH" | shasum | cut -d' ' -f1)"
        PR_CACHE_MAX_AGE=300  # 5 minutes

        NEED_REFRESH=1
        if [ -f "$PR_CACHE" ]; then
            CACHE_MTIME=$(stat -f%m "$PR_CACHE" 2>/dev/null || stat -c%Y "$PR_CACHE" 2>/dev/null || echo "0")
            NOW=$(date +%s)
            [ $((NOW - CACHE_MTIME)) -lt "$PR_CACHE_MAX_AGE" ] && NEED_REFRESH=0
        fi

        if [ "$NEED_REFRESH" -eq 1 ]; then
            PR_JSON=$(gh pr view --json number,title,state,reviewDecision,url 2>/dev/null || echo "")
            if [ -n "$PR_JSON" ]; then
                echo "$PR_JSON" > "$PR_CACHE"
            else
                echo "" > "$PR_CACHE"
            fi
        fi

        if [ -f "$PR_CACHE" ] && [ -s "$PR_CACHE" ]; then
            PR_NUM=$(cat "$PR_CACHE" | grep -o '"number":[0-9]*' | head -1 | cut -d: -f2 || echo "")
            PR_TITLE=$(cat "$PR_CACHE" | grep -o '"title":"[^"]*"' | head -1 | sed 's/"title":"//;s/"$//' || echo "")
            PR_STATE=$(cat "$PR_CACHE" | grep -o '"state":"[^"]*"' | head -1 | sed 's/"state":"//;s/"$//' || echo "")
            PR_REVIEW=$(cat "$PR_CACHE" | grep -o '"reviewDecision":"[^"]*"' | head -1 | sed 's/"reviewDecision":"//;s/"$//' || echo "")
            if [ -n "$PR_NUM" ]; then
                PR_SECTION="PR: #${PR_NUM} ${PR_TITLE} [${PR_STATE}]"
                [ -n "$PR_REVIEW" ] && PR_SECTION="${PR_SECTION} review=${PR_REVIEW}"
            fi
        fi
    fi
fi

# ── Session Stats ───────────────────────────────────────────────
STATS_SECTION=""
COMMITS=$(cat "${STATE_DIR}/.devforge-session-commits" 2>/dev/null || echo "0")
SKILLS=$(cat "${STATE_DIR}/.devforge-session-skills" 2>/dev/null | grep -c '.' || echo "0")
MSG_COUNT=$(cat "${STATE_DIR}/.devforge-message-counter" 2>/dev/null || echo "?")
START_NS=$(cat "${STATE_DIR}/.devforge-session-start-ns" 2>/dev/null || echo "0")

DURATION_MIN="?"
if [ "$START_NS" != "0" ] && [ -n "$START_NS" ]; then
    NOW_S=$(date +%s)
    START_S=$((START_NS / 1000000000))
    if [ "$START_S" -gt 0 ] 2>/dev/null; then
        ELAPSED=$((NOW_S - START_S))
        DURATION_MIN=$((ELAPSED / 60))
    fi
fi

STATS_SECTION="Session: ${DURATION_MIN}min | messaggi=${MSG_COUNT} | commits=${COMMITS} | skills=${SKILLS}"

# ── Last Test Results ───────────────────────────────────────────
TEST_SECTION=""
TEST_FILE="${STATE_DIR}/.devforge-last-test-result"
if [ -f "$TEST_FILE" ] && [ -s "$TEST_FILE" ]; then
    # Only show if less than 30 min old
    TEST_MTIME=$(stat -f%m "$TEST_FILE" 2>/dev/null || stat -c%Y "$TEST_FILE" 2>/dev/null || echo "0")
    NOW=$(date +%s)
    if [ $((NOW - TEST_MTIME)) -lt 1800 ]; then
        TEST_CONTENT=$(head -c 500 "$TEST_FILE" 2>/dev/null | tr -cd '[:print:]\n' | head -5)
        TEST_SECTION="Last test: ${TEST_CONTENT}"
    fi
fi

# ── Active Plan ─────────────────────────────────────────────────
PLAN_SECTION=""
PLAN_SENTINEL="${STATE_DIR}/.devforge-active-plan"
if [ -f "$PLAN_SENTINEL" ] && [ -s "$PLAN_SENTINEL" ]; then
    PLAN_CONTENT=$(head -c 300 "$PLAN_SENTINEL" 2>/dev/null | tr -cd '[:print:]\n')
    PLAN_SECTION="Active plan: ${PLAN_CONTENT}"
fi

# ── Build output ────────────────────────────────────────────────
# Skip if nothing to report (e.g. not in a git repo, no stats)
SECTIONS=""
[ -n "$GIT_SECTION" ] && SECTIONS="${SECTIONS}${GIT_SECTION}\\n"
[ -n "$PR_SECTION" ] && SECTIONS="${SECTIONS}${PR_SECTION}\\n"
[ -n "$STATS_SECTION" ] && SECTIONS="${SECTIONS}${STATS_SECTION}\\n"
[ -n "$TEST_SECTION" ] && SECTIONS="${SECTIONS}${TEST_SECTION}\\n"
[ -n "$PLAN_SECTION" ] && SECTIONS="${SECTIONS}${PLAN_SECTION}\\n"

if [ -z "$SECTIONS" ]; then
    exit 0
fi

# Escape for JSON
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

SECTIONS_ESCAPED=$(escape_for_json "$SECTIONS")

CONTEXT="[DevForge Context]\\n${SECTIONS_ESCAPED}"

cat <<EOF
{
  "additional_context": "${CONTEXT}",
  "hookSpecificOutput": {
    "hookEventName": "UserPromptSubmit",
    "additionalContext": "${CONTEXT}"
  }
}
EOF

exit 0
