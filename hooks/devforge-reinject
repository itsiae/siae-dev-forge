#!/usr/bin/env bash
# UserPromptSubmit hook — periodic re-injection of DevForge context
# ─────────────────────────────────────────────────────────────────
# Hook:     devforge-reinject
# Evento:   UserPromptSubmit
# Matcher:  * (ogni messaggio utente)
# Timeout:  5s
# Formato:  additional_context (standard DevForge)
# ─────────────────────────────────────────────────────────────────
# Re-injects compact DevForge context every N user messages to survive
# context compression in long conversations.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

DEVFORGE_STATE_DIR="${DEVFORGE_STATE_DIR:-${HOME}/.claude}"
REINJECT_EVERY=20
COUNTER_FILE="${DEVFORGE_STATE_DIR}/.devforge-message-counter"

# Initialize counter if missing
if [ ! -f "$COUNTER_FILE" ]; then
    echo "0" > "$COUNTER_FILE"
fi

# Read and increment counter
COUNT=$(cat "$COUNTER_FILE" 2>/dev/null || echo "0")
# Sanitize: ensure it's a number
COUNT=$((COUNT + 0))
COUNT=$((COUNT + 1))
echo "$COUNT" > "$COUNTER_FILE"

# Only inject every N messages
if [ $((COUNT % REINJECT_EVERY)) -ne 0 ]; then
    exit 0
fi

# ── Build phase-based DevForge context ─────────────────────────

# Source SDLC state
source "${PLUGIN_ROOT}/lib/logger.sh"
source "${PLUGIN_ROOT}/lib/sdlc-state.sh"

CURRENT=$(sdlc_get_current_stage)
COMPLETED=$(sdlc_get_completed_stages)

# Get specialists for current stage
SPECIALISTS=""
if [ "$CURRENT" != "idle" ] && command -v node >/dev/null 2>&1; then
    SPECIALISTS=$(sdlc_get_stage_specialists "$CURRENT" "$PLUGIN_ROOT" 2>/dev/null | tr '\n' ', ' | sed 's/,$//')
fi

# Determine open gates
GATES=""
if [ "$(sdlc_is_stage_completed "brainstorming")" != "yes" ]; then
    GATES="brainstorming richiesto prima di qualsiasi implementazione"
elif [ "$(sdlc_is_stage_completed "tdd")" != "yes" ] && [ "$CURRENT" != "tdd" ]; then
    GATES="tdd richiesto prima di modificare codice produzione"
elif [ "$(sdlc_is_stage_completed "review")" != "yes" ]; then
    GATES="review richiesto prima di chiudere"
fi

# Build compact SDLC context
SDLC_LINES="Fase SDLC attuale: ${CURRENT}"
[ -n "$COMPLETED" ] && SDLC_LINES="${SDLC_LINES}\\nFasi completate: ${COMPLETED}"
[ -n "$GATES" ] && SDLC_LINES="${SDLC_LINES}\\nGate aperti: ${GATES}"
[ -n "$SPECIALISTS" ] && SDLC_LINES="${SDLC_LINES}\\nSkill specialistiche consigliate: ${SPECIALISTS}"

# Generate skill catalog (still needed for skill discovery)
skill_catalog=""
if command -v node >/dev/null 2>&1; then
    skill_catalog=$(node "${PLUGIN_ROOT}/lib/skills-core.js" "${PLUGIN_ROOT}" 2>/dev/null || echo "")
fi
if [ -z "$skill_catalog" ]; then
    skill_catalog="| (catalogo non disponibile) | | |"
fi

# Escape for JSON
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

skill_catalog_escaped=$(escape_for_json "$skill_catalog")

COMPACT_CONTEXT="<IMPORTANT>\\n\
DevForge SDLC Context (msg #${COUNT})\\n\\n\
${SDLC_LINES}\\n\\n\
**3 Regole Madre:**\\n\
1. Nessuna implementazione senza brainstorming + plan\\n\
2. Nessun codice produzione senza tdd\\n\
3. Nessuna chiusura senza review + verification + finish\\n\\n\
**Skill Catalog:**\\n\\n\
${skill_catalog_escaped}\\n\
</IMPORTANT>"

cat <<EOF
{
  "additional_context": "${COMPACT_CONTEXT}",
  "hookSpecificOutput": {
    "hookEventName": "UserPromptSubmit",
    "additionalContext": "${COMPACT_CONTEXT}"
  }
}
EOF

exit 0
