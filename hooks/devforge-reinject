#!/usr/bin/env bash
# UserPromptSubmit hook — periodic re-injection of DevForge context
# ─────────────────────────────────────────────────────────────────
# Hook:     devforge-reinject
# Evento:   UserPromptSubmit
# Matcher:  * (ogni messaggio utente)
# Timeout:  5s
# Formato:  additional_context (standard DevForge)
# ─────────────────────────────────────────────────────────────────
# Re-injects compact DevForge context every N user messages to survive
# context compression in long conversations.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

REINJECT_EVERY=10
COUNTER_FILE="${HOME}/.claude/.devforge-message-counter"

# Initialize counter if missing
if [ ! -f "$COUNTER_FILE" ]; then
    echo "0" > "$COUNTER_FILE"
fi

# Read and increment counter
COUNT=$(cat "$COUNTER_FILE" 2>/dev/null || echo "0")
# Sanitize: ensure it's a number
COUNT=$((COUNT + 0))
COUNT=$((COUNT + 1))
echo "$COUNT" > "$COUNTER_FILE"

# Only inject every N messages
if [ $((COUNT % REINJECT_EVERY)) -ne 0 ]; then
    exit 0
fi

# ── Build compact DevForge context ──────────────────────────────

# Generate dynamic skill catalog
skill_catalog=""
if command -v node >/dev/null 2>&1; then
    skill_catalog=$(node "${PLUGIN_ROOT}/lib/skills-core.js" "${PLUGIN_ROOT}" 2>/dev/null || echo "")
fi
if [ -z "$skill_catalog" ]; then
    skill_catalog="| (catalogo non disponibile) | | |"
fi

# Escape for JSON
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

extract_md_section() {
    local file="$1"
    local start_heading="$2"
    local end_heading="${3:-}"
    awk -v start="$start_heading" -v end="$end_heading" '
        $0 == start {capture=1}
        capture && end != "" && $0 == end {exit}
        capture {print}
    ' "$file" 2>/dev/null || true
}

USING_DEVFORGE_FILE="${PLUGIN_ROOT}/skills/using-devforge/SKILL.md"
BACKBONE_TEXT=""
if [ -f "$USING_DEVFORGE_FILE" ]; then
    RULE_SECTION=$(extract_md_section "$USING_DEVFORGE_FILE" "## La Regola" "## DevForge Backbone Core")
    CORE_SECTION=$(extract_md_section "$USING_DEVFORGE_FILE" "## DevForge Backbone Core" "## Skill Priority")
    PRIORITY_SECTION=$(extract_md_section "$USING_DEVFORGE_FILE" "## Skill Priority" "## Gate Operativi")
    GATE_SECTION=$(extract_md_section "$USING_DEVFORGE_FILE" "## Gate Operativi" "## Regole Operative Brevi")
    BACKBONE_TEXT="${RULE_SECTION}\n\n${CORE_SECTION}\n\n${PRIORITY_SECTION}\n\n${GATE_SECTION}"
fi

if [ -z "$(printf '%s' "$BACKBONE_TEXT" | tr -d '[:space:]')" ]; then
    read -r -d '' BACKBONE_TEXT <<'EOF' || true
## La Regola
Se c'e' anche l'1% di probabilita' che una skill si applichi, invocala prima di rispondere.
Controlla sempre il Dynamic Skill Catalog.

## DevForge Backbone Core
- Task implementativo -> `siae-brainstorming`, poi `siae-writing-plans`
- Bug/failure -> `siae-debugging` prima del fix
- Implementazione -> skill di dominio + `siae-security` + `siae-tdd`
- Review/pre-PR -> skill di dominio + workflow review + `siae-security`
- Completamento -> `siae-verification`
EOF
fi

backbone_text_escaped=$(escape_for_json "$BACKBONE_TEXT")
skill_catalog_escaped=$(escape_for_json "$skill_catalog")

# Compact context: backbone from using-devforge + full catalog
COMPACT_CONTEXT="<EXTREMELY_IMPORTANT>\\n\
🔨 DevForge Context Refresh (messaggio #${COUNT})\\n\\n\
**Backbone Meta-Skill Refresh:**\\n\\n\
${backbone_text_escaped}\\n\\n\
**Always-On Companion Rule:** skill specifica di dominio -> aggancia SEMPRE siae-security; task che va in review/PR -> aggancia SEMPRE workflow review + siae-verification; brainstorming SEMPRE per QUALSIASI task implementativo (escluse pure operazioni git).\\n\\n\
**Dynamic Skill Catalog:**\\n\\n\
${skill_catalog_escaped}\\n\\n\
**Disambiguazione:** bug/errore/stacktrace → siae-debugging | git op → siae-git-workflow | C4/HLD/CQRS → siae-architecture | Terraform/ECS → siae-iac | Glue/PySpark/ETL → siae-data-engineering | Playwright/Cypress/E2E → siae-automation | brainstorming SEMPRE per QUALSIASI task implementativo.\\n\
</EXTREMELY_IMPORTANT>"

cat <<EOF
{
  "additional_context": "${COMPACT_CONTEXT}",
  "hookSpecificOutput": {
    "hookEventName": "UserPromptSubmit",
    "additionalContext": "${COMPACT_CONTEXT}"
  }
}
EOF

exit 0
