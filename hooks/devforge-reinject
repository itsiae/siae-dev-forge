#!/usr/bin/env bash
# UserPromptSubmit hook — periodic re-injection of DevForge context
# ─────────────────────────────────────────────────────────────────
# Hook:     devforge-reinject
# Evento:   UserPromptSubmit
# Matcher:  * (ogni messaggio utente)
# Timeout:  5s
# Formato:  additional_context (standard DevForge)
# ─────────────────────────────────────────────────────────────────
# Re-injects compact DevForge context every N user messages to survive
# context compression in long conversations.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

REINJECT_EVERY=20
COUNTER_FILE="${HOME}/.claude/.devforge-message-counter"

# Initialize counter if missing
if [ ! -f "$COUNTER_FILE" ]; then
    echo "0" > "$COUNTER_FILE"
fi

# Read and increment counter
COUNT=$(cat "$COUNTER_FILE" 2>/dev/null || echo "0")
# Sanitize: ensure it's a number
COUNT=$((COUNT + 0))
COUNT=$((COUNT + 1))
echo "$COUNT" > "$COUNTER_FILE"

# Only inject every N messages
if [ $((COUNT % REINJECT_EVERY)) -ne 0 ]; then
    exit 0
fi

# ── Build compact DevForge context ──────────────────────────────

# Generate dynamic skill catalog
skill_catalog=""
if command -v node >/dev/null 2>&1; then
    skill_catalog=$(node "${PLUGIN_ROOT}/lib/skills-core.js" "${PLUGIN_ROOT}" 2>/dev/null || echo "")
fi
if [ -z "$skill_catalog" ]; then
    skill_catalog="| (catalogo non disponibile) | | |"
fi

# Escape for JSON
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

skill_catalog_escaped=$(escape_for_json "$skill_catalog")

# Compact context: essential rules + full catalog
# Not the full using-devforge skill — just enough to keep Claude on track
COMPACT_CONTEXT="<EXTREMELY_IMPORTANT>\\n\
🔨 DevForge Context Refresh (messaggio #${COUNT})\\n\\n\
**AZIONE IMMEDIATA:** Prima di rispondere a questo messaggio, stampa su una riga separata esattamente: '🔄 DevForge re-iniettato (msg #${COUNT})'\\n\\n\
**OBBLIGO:** Per OGNI messaggio utente, scansiona il Dynamic Skill Catalog sotto. Se trovi un match anche parziale, invoca la skill PRIMA di rispondere.\\n\\n\
**Git Operations Intercept:** Prima di QUALSIASI git command (checkout, commit, push, merge, tag, gh pr create), verifica di aver invocato siae-git-workflow. Prima di aprire una PR, verifica siae-finishing-branch.\\n\\n\
**EnterPlanMode Intercept:** Prima di EnterPlanMode, verifica che il brainstorming sia stato fatto (siae-brainstorming).\\n\\n\
**Verification:** Prima di dichiarare qualsiasi task fatto/completato/fixato, invoca siae-verification.\\n\\n\
**Red Flags — STOP se pensi:**\\n\
- 'E solo una domanda semplice' → Le domande sono task. Controlla le skill.\\n\
- 'Posso controllare git velocemente' → Carica siae-git-workflow prima.\\n\
- 'La skill e eccessiva' → Le cose semplici diventano complesse. Usala.\\n\
- 'E solo un commit veloce' → Ogni commit senza siae-git-workflow = naming sbagliato.\\n\\n\
**Dynamic Skill Catalog:**\\n\\n\
${skill_catalog_escaped}\\n\\n\
**Disambiguazione:** bug/errore/stacktrace → siae-debugging | git op → siae-git-workflow | C4/HLD/CQRS → siae-architecture | Terraform/ECS → siae-iac | Glue/PySpark/ETL → siae-data-engineering | Playwright/Cypress/E2E → siae-automation | brainstorming SEMPRE per QUALSIASI task implementativo (feature, bug fix, refactoring, config — escluse pure operazioni git).\\n\
</EXTREMELY_IMPORTANT>"

cat <<EOF
{
  "additional_context": "${COMPACT_CONTEXT}",
  "hookSpecificOutput": {
    "hookEventName": "UserPromptSubmit",
    "additionalContext": "${COMPACT_CONTEXT}"
  }
}
EOF

exit 0
