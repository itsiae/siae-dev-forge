#!/usr/bin/env bash
# convention-injector — re-inietta la convenzione SIAE pertinente ai momenti clou.
# Baseline = session-start (sempre); qui = re-iniezione mirata, compatta, diff-deduped.
# Trigger (REQ-DF-01/02/06):
#   1. deploy/PR          -> siae-environments + siae-plan-deploy
#   2. edit IaC / multirepo -> siae-multirepo + siae-environments
#   3. promozione ambiente  -> siae-plan-deploy
set -uo pipefail

PLUGIN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REF="$PLUGIN_ROOT/skills/using-devforge/reference"
PER_SECTION_BYTES=1200
STATE_DIR="${HOME}/.claude"
STATE="$STATE_DIR/.devforge-convention-injected"

INPUT="$(cat)"
_jq(){ printf '%s' "$INPUT" | jq -r "$1" 2>/dev/null || echo ""; }
EVENT=$(_jq '.hook_event_name // empty'); [ -z "$EVENT" ] && EVENT="UserPromptSubmit"
PROMPT=$(_jq '.prompt // empty')
TOOL=$(_jq '.tool_name // empty')
FILE=$(_jq '.tool_input.file_path // empty')
CMD=$(_jq '.tool_input.command // empty')

emit_section(){ # $1 = base name; sezione compatta o marker se assente
    local f="$REF/$1"
    if [ ! -f "$f" ]; then
        echo "[FONTE NON DISPONIBILE: $1 SIAE — NON ipotizzare, dichiara l'assenza]"
        return
    fi
    head -c "$PER_SECTION_BYTES" "$f"
}

# INVARIANTE DI SICUREZZA (review): WANT contiene SOLO nomi-file whitelisted
# hardcoded qui sotto (siae-*.md), MAI valori derivati da $PROMPT/$CMD/$FILE.
# L'espansione non quotata a valle (printf/for) e' sicura solo per questo motivo:
# non concatenare mai input non fidato in WANT (altrimenti diventa injection).
WANT=""
# Trigger 1: deploy / PR
if printf '%s %s' "$PROMPT" "$CMD" | grep -qiE 'deploy|collaudo|certificazione|terragrunt|make (dev|qa)|git tag|release' \
   || printf '%s' "$CMD" | grep -qE 'gh pr create'; then
    WANT="siae-environments.md siae-plan-deploy.md"
fi
# Trigger 2: edit IaC / contesto multi-repo
if { [ "$TOOL" = "Edit" ] || [ "$TOOL" = "Write" ]; } && printf '%s' "$FILE" | grep -qE '\.(tf|hcl)$'; then
    WANT="$WANT siae-multirepo.md siae-environments.md"
fi
if printf '%s' "$PWD" | grep -qE '\-(iac|bff|spa)(/|$)'; then
    WANT="$WANT siae-multirepo.md"
fi
# Trigger 3: promozione ambiente
if printf '%s' "$CMD" | grep -qE 'git tag (sviluppo|collaudo)'; then
    WANT="$WANT siae-plan-deploy.md"
fi

# nessun trigger -> passthrough
WANT=$(printf '%s\n' $WANT | awk 'NF' | sort -u | tr '\n' ' ')
if [ -z "${WANT// }" ]; then echo '{}'; exit 0; fi

# dedup: non re-iniettare la stessa combinazione consecutivamente
HASH=$(printf '%s' "$WANT" | shasum 2>/dev/null | cut -d' ' -f1)
mkdir -p "$STATE_DIR" 2>/dev/null || true
if [ "$(cat "$STATE" 2>/dev/null || echo "")" = "$HASH" ]; then echo '{}'; exit 0; fi
printf '%s' "$HASH" > "$STATE" 2>/dev/null || true

BODY="[SIAE Convenzioni — momento clou]"
for s in $WANT; do
    BODY="$BODY"$'\n\n'"## $s"$'\n'"$(emit_section "$s")"
done

# Emissione formato standard DevForge: additional_context + hookSpecificOutput.
if command -v jq >/dev/null 2>&1; then
    jq -n --arg c "$BODY" --arg evt "$EVENT" \
      '{additional_context:$c, hookSpecificOutput:{hookEventName:$evt, additionalContext:$c}}'
else
    echo '{}'
fi
