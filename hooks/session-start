#!/usr/bin/env bash
# SessionStart hook for siae-devforge plugin
# ─────────────────────────────────────────────────────────────────
# Hook:     session-start
# Evento:   SessionStart
# Matcher:  startup/resume/clear/compact
# Timeout:  async:false — Deve completare prima del primo prompt
# Formato:  additional_context (standard DevForge)
# ─────────────────────────────────────────────────────────────────

set -euo pipefail
export DEVFORGE_CURRENT_HOOK="session-start"

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Source activity logger and start session
source "${PLUGIN_ROOT}/lib/logger.sh"
# Network resilience: NO_PROXY-github (correttezza) + net_run (timeout hard portabile).
# Il source applica già il fix NO_PROXY; net_run avvolge le call gh/git sotto.
source "${PLUGIN_ROOT}/lib/net-timeout.sh" \
    || { echo "[devforge] net-timeout.sh non sourcabile" >&2; }
# Plugin version observability helpers (_ver_lt, devforge_installed_version, devforge_latest_release)
source "${PLUGIN_ROOT}/lib/plugin-version.sh" \
    || { echo "[devforge] plugin-version.sh non sourcabile" >&2; }
# P-banner: helper devforge_python3_banner (avviso esplicito se python3 manca).
source "${PLUGIN_ROOT}/lib/python3-check.sh" 2>/dev/null || true
START_NS=$(_devforge_epoch_ns)
DEVFORGE_SID=$(devforge_new_sid)

# Create session state directory
DEVFORGE_SESSION_DIR="${HOME}/.claude/devforge-state/${DEVFORGE_SID}"
mkdir -p "${DEVFORGE_SESSION_DIR}/outbox/acked"

# --- Plugin update notice (Feature 2a) — pure-local, no network ---
# Rileva il cambio di versione del plugin rispetto all'ultima sessione e scrive un flag
# session-scoped che la status line mostra per tutta la sessione post-update. Nessuna
# call di rete, nessun output su stdout (non deve corrompere additional_context).
_devforge_detect_plugin_update() {
    local current last_seen_file last_seen
    current="$(basename "$PLUGIN_ROOT")"
    # Dev-mode (repo non versionato in cache): basename non e' semver -> fallback plugin.json
    # Pattern ancorato (^...$): scarta basename inattesi tipo "1.91.0 beta" o path con suffissi.
    if ! printf '%s' "$current" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
        if command -v jq >/dev/null 2>&1 && [ -f "${PLUGIN_ROOT}/.claude-plugin/plugin.json" ]; then
            current="$(jq -r '.version // empty' "${PLUGIN_ROOT}/.claude-plugin/plugin.json" 2>/dev/null)"
        fi
    fi
    # Post-fallback: se ancora non-semver (o vuoto) -> versione non determinabile -> skip (no scrittura)
    if ! printf '%s' "$current" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
        return 0
    fi
    last_seen_file="${HOME}/.claude/.devforge-plugin-version"
    last_seen=""
    [ -f "$last_seen_file" ] && IFS= read -r last_seen < "$last_seen_file" 2>/dev/null || true
    if [ -z "$last_seen" ]; then
        printf '%s' "$current" > "$last_seen_file" 2>/dev/null || true   # prima installazione: nessun avviso
        return 0
    fi
    if [ "$last_seen" != "$current" ]; then
        printf '%s' "$current" > "${DEVFORGE_SESSION_DIR}/.plugin-updated" 2>/dev/null || true
        printf '%s' "$current" > "$last_seen_file" 2>/dev/null || true
    fi
}
_devforge_detect_plugin_update >/dev/null 2>&1 || true

# Resolve raw identity (before canonicalization)
USER_RAW_EMAIL=""
USER_SOURCE="unknown"
if git config user.email >/dev/null 2>&1; then
    USER_RAW_EMAIL=$(git config user.email)
    USER_SOURCE="git-config-local"
elif git config --global user.email >/dev/null 2>&1; then
    USER_RAW_EMAIL=$(git config --global user.email)
    USER_SOURCE="git-config-global"
elif [ -f "${HOME}/.claude/.devforge-user" ]; then
    USER_RAW_EMAIL=$(cat "${HOME}/.claude/.devforge-user" 2>/dev/null)
    USER_SOURCE="session-cache"
else
    USER_RAW_EMAIL="${USER:-$(whoami 2>/dev/null || echo "unknown")}"
    USER_SOURCE="os-user"
fi
USER_CANONICAL=$(devforge_canonicalize_user "$USER_RAW_EMAIL")

# Raw multi-signal identity bundle (resolution happens downstream)
IDENTITY_BUNDLE=$(devforge_identity_bundle 2>/dev/null || echo '{}')
# Validity guard: the bundle is interpolated verbatim into the session_start
# meta JSON. If a partial/non-object output ever slips through, coerce to {} so
# the JSONL line on S3 can never be corrupted. Lightweight, no python dependency.
case "$IDENTITY_BUNDLE" in
    '{'*'}') : ;;
    *) IDENTITY_BUNDLE='{}' ;;
esac

# Write user.json (pinned for entire session). identity is best-effort: if the
# bundle is unparsable, json.loads fails and user.json is written without it.
if command -v python3 >/dev/null 2>&1; then
    python3 -c "
import json,sys
d={'raw': sys.argv[1], 'source': sys.argv[2], 'canonical': sys.argv[3]}
try:
    d['identity']=json.loads(sys.argv[5])
except Exception:
    pass
json.dump(d, open(sys.argv[4], 'w'))
" "$USER_RAW_EMAIL" "$USER_SOURCE" "$USER_CANONICAL" "${DEVFORGE_SESSION_DIR}/user.json" "$IDENTITY_BUNDLE" 2>/dev/null || true
fi

# Initialize seq counter
echo "0" > "${DEVFORGE_SESSION_DIR}/seq"

# Export DEVFORGE_SESSION_DIR PRIMA di init(): il token-collector gira in un
# sottoprocesso python che eredita solo le variabili exportate. Senza questo,
# init() non vedrebbe la dir di sessione e lo stato finirebbe fuori scope
# (defense-in-depth: il collector si auto-deriva il path dal sid-file, ma
# l'export esplicito è la cintura).
export DEVFORGE_SESSION_DIR

# Initialize token collector for this session
python3 "${PLUGIN_ROOT}/lib/token-collector.py" init 2>/dev/null || true

# Export session context for logger
export DEVFORGE_SESSION_DIR DEVFORGE_PINNED_USER="$USER_CANONICAL" DEVFORGE_PINNED_SID="$DEVFORGE_SID"

# Pin authenticated SSO identity for per-event top-level fields (auth_email/auth_account_uuid).
# Best-effort: empty if ~/.claude.json/oauthAccount absent (Bedrock/API-key auth).
AUTH_RESOLVED=$(devforge_resolve_auth_identity 2>/dev/null || printf '|||')
DEVFORGE_AUTH_EMAIL="${AUTH_RESOLVED%%|*}"
_AUTH_REST="${AUTH_RESOLVED#*|}"
DEVFORGE_AUTH_ACCOUNT_UUID="${_AUTH_REST%%|*}"
export DEVFORGE_AUTH_EMAIL DEVFORGE_AUTH_ACCOUNT_UUID

# Zero-loss PR-A: NTP clock skew check (edge case #7 + #18 del design).
# Fetch Date header from time.cloudflare.com (HTTPS, no admin required) with
# 2s timeout. If >1h skew, flag force_received_at in session dir so Lambda
# uses received_at instead of client ts for S3 partitioning.
# Silent failure: any network issue → empty arg → no-op (no blocking).
NTP_EPOCH=""
if command -v curl >/dev/null 2>&1; then
    # Silent failure: curl timeout / no internet / grep no-match must not kill
    # the hook. With `set -euo pipefail` a failing command in this pipeline
    # would abort session-start before additional_context is emitted (manifests
    # as "SessionStart hook error · No stderr output" in Claude Code).
    NTP_HEADER=$(curl -sfI -m 2 https://time.cloudflare.com/ 2>/dev/null | grep -i '^date:' | head -1 | sed 's/^[Dd]ate:[[:space:]]*//;s/\r$//' || echo "")
    if [ -n "$NTP_HEADER" ]; then
        # Try BSD date format (macOS), then GNU date (Linux)
        NTP_EPOCH=$(date -j -f "%a, %d %b %Y %H:%M:%S %Z" "$NTP_HEADER" +%s 2>/dev/null \
            || date -d "$NTP_HEADER" +%s 2>/dev/null || echo "")
    fi
fi
_devforge_check_clock_skew "$NTP_EPOCH" 2>/dev/null || true

PLUGIN_VERSION=$(grep -o '"version"[[:space:]]*:[[:space:]]*"[^"]*"' "${PLUGIN_ROOT}/.claude-plugin/plugin.json" 2>/dev/null | head -1 | sed 's/.*"version"[[:space:]]*:[[:space:]]*"//;s/"$//' || echo "unknown")

# Auto-install status line (idempotente)
# NB: redirect completo — qualsiasi byte su stdout corromperebbe il JSON
# additional_context emesso sotto (line ~255), rendendolo non parsabile.
bash "${PLUGIN_ROOT}/statusline/install.sh" >/dev/null 2>&1 || true

# Install DevForge-Author trailer hook (Comp.4 — idempotente, zero-harm, fast/local).
# rc=2 → hook estraneo (husky) presente: skip preservando l'hook utente, log telemetria.
TRAILER_RC=0
bash "${PLUGIN_ROOT}/lib/install-trailer-hook.sh" >/dev/null 2>&1 || TRAILER_RC=$?
[ "$TRAILER_RC" = "2" ] && devforge_log "trailer_hook_skipped_foreign" "success" "{}" 2>/dev/null || true

# Auto-install siae-mcp-kibana (idempotente, asincrono — non blocca la sessione)
# stdout/stderr soppressi: il background job puo' stampare output npm/tsc
# durante la prima install e contaminerebbe il JSON del hook.
bash "${PLUGIN_ROOT}/hooks/setup-mcp-kibana" >/dev/null 2>&1 &

# Auto-install siae-sport-mcp (idempotente, asincrono — non blocca la sessione)
bash "${PLUGIN_ROOT}/hooks/setup-mcp-sport" >/dev/null 2>&1 &

# Print brand banner to stderr (visible in terminal at startup)
cat >&2 <<'BANNER'

╔══════════════════════════════════════════════════════════════════╗
║    ███████╗██╗ █████╗ ███████╗    ██████╗ ███████╗██╗   ██╗    ║
║    ██╔════╝██║██╔══██╗██╔════╝    ██╔══██╗██╔════╝██║   ██║    ║
║    ███████╗██║███████║█████╗      ██║  ██║█████╗  ██║   ██║    ║
║    ╚════██║██║██╔══██║██╔══╝      ██║  ██║██╔══╝  ╚██╗ ██╔╝    ║
║    ███████║██║██║  ██║███████╗    ██████╔╝███████╗ ╚████╔╝     ║
║    ╚══════╝╚═╝╚═╝  ╚═╝╚══════╝    ╚═════╝ ╚══════╝  ╚═══╝      ║
║              🔨 DevForge · AI Competence Center                ║
║         "Il codice si forgia. Il developer cresce."            ║
╚══════════════════════════════════════════════════════════════════╝

BANNER

# Plugin version OBSERVABILITY (design 2026-06-19 plugin-update-safety).
# L'aggiornamento è gestito dal meccanismo NATIVO di Claude Code (autoUpdate
# org-wide via remote-settings.json): a ogni startup Claude refresha il marketplace
# e aggiorna i plugin installati, dietro le quinte, senza azione utente.
# Qui NON si aggiorna nulla — si OSSERVA soltanto. Il vecchio blocco custom
# (claude plugin update + rm -rf cache + git pull in background) è stato rimosso:
# era inerte su scope managed (rc=0 falso successo), corrompeva cache/registry,
# e non portabile su Windows (pgrep/kill MSYS). Vedi design per gli 11+2 difetti.
INSTALLED_VERSION=$(devforge_installed_version "$PLUGIN_ROOT")
LATEST_VERSION=$(devforge_latest_release)   # release stabile (prerelease escluse); "" se non risolvibile
VERSION_STATUS=""
PV_STATE="unavailable"
PV_LATEST_JSON="null"
if [ "$INSTALLED_VERSION" != "unknown" ]; then
    if [ -n "$LATEST_VERSION" ] && _ver_is_semver "$LATEST_VERSION"; then
        PV_LATEST_JSON="\"${LATEST_VERSION}\""
        if _ver_lt "$INSTALLED_VERSION" "$LATEST_VERSION"; then
            PV_STATE="behind"
            # Informativo, NON un call-to-action: l'update arriva da solo al prossimo avvio.
            VERSION_STATUS="DevForge v${INSTALLED_VERSION} (v${LATEST_VERSION} in arrivo — aggiornamento automatico in background)"
        else
            PV_STATE="up_to_date"
            VERSION_STATUS="DevForge v${INSTALLED_VERSION} — aggiornato"
        fi
    else
        VERSION_STATUS="DevForge v${INSTALLED_VERSION}"
    fi
fi
# Telemetria convergenza: emessa SEMPRE (anche in fallback con status=unavailable),
# così a valle (S3) si verifica che TUTTI i seat convergano all'ultima versione.
devforge_log "plugin_version_observed" "success" \
    "{\"installed\":\"$(devforge_sanitize_json_str "$INSTALLED_VERSION")\",\"latest\":${PV_LATEST_JSON},\"status\":\"${PV_STATE}\"}" \
    2>/dev/null || true

# Read using-devforge content
using_devforge_content=$(cat "${PLUGIN_ROOT}/skills/using-devforge/SKILL.md" 2>&1 || echo "Error reading using-devforge skill")

# Generate dynamic skill catalog using skills-core.js
# Falls back to empty string if node is not available or the script fails
skill_catalog=""
if command -v node >/dev/null 2>&1; then
    skill_catalog=$(node "${PLUGIN_ROOT}/lib/skills-core.js" "${PLUGIN_ROOT}" 2>/dev/null || echo "")
fi
if [ -z "$skill_catalog" ]; then
    skill_catalog="| (catalogo non disponibile — skills-core.js ha fallito) | | |"
    devforge_log "skill_catalog" "warning" "{\"reason\":\"skills-core.js returned empty or failed\"}" 2>/dev/null || true
fi

# JSON escaping is centralized in lib/logger.sh :: devforge_sanitize_json_str.
# Local alias for readability in this file.
escape_for_json() { devforge_sanitize_json_str "$1"; }

using_devforge_escaped=$(escape_for_json "$using_devforge_content")

# Append dynamic catalog if available
catalog_section=""
if [ -n "$skill_catalog" ]; then
    skill_catalog_escaped=$(escape_for_json "$skill_catalog")
    catalog_section="\\n\\n**Dynamic Skill Catalog (auto-generated):**\\n\\n${skill_catalog_escaped}"
fi

version_status_escaped=$(escape_for_json "$VERSION_STATUS")

# --- Branching compliance check (repo corrente) ---
BRANCHING_SUMMARY=""
if command -v gh >/dev/null 2>&1; then
    CURRENT_REPO=$(net_run 5 gh repo view --json nameWithOwner -q '.nameWithOwner' 2>/dev/null || echo "")
    if [ -n "$CURRENT_REPO" ]; then
        DEFAULT_BRANCH=$(net_run 5 gh repo view --json defaultBranchRef -q '.defaultBranchRef.name' 2>/dev/null || echo "main")
        VIOLS=0
        VIOL_DETAILS=""

        if [ "$DEFAULT_BRANCH" != "main" ]; then
            VIOLS=$((VIOLS + 1))
            VIOL_DETAILS="default branch is \`${DEFAULT_BRANCH}\` (atteso: \`main\`)"
        else
            BAD_PRS=$(net_run 8 gh pr list --base main --state open \
                --json number,headRefName \
                --jq '[.[] | select(.headRefName | test("^release/") | not) | "#\(.number) (\(.headRefName))"] | join(", ")' 2>/dev/null || echo "")
            if [ -n "$BAD_PRS" ]; then
                VIOLS=$((VIOLS + 1))
                VIOL_DETAILS="PR verso main da branch non-release: ${BAD_PRS}"
            fi
        fi

        if [ "$VIOLS" -gt 0 ]; then
            BRANCHING_SUMMARY="⚠️ Branching compliance [${CURRENT_REPO}]: ${VIOL_DETAILS} — invoca /branching-strategy-check per dettagli."
        fi
    fi
fi

branching_section=""
if [ -n "$BRANCHING_SUMMARY" ]; then
    branching_summary_escaped=$(escape_for_json "$BRANCHING_SUMMARY")
    branching_section="\\n\\n${branching_summary_escaped}"
fi
# --- End branching compliance ---

# --- Global DevForge memory (cross-project feedback, applies to ALL repos) ---
GLOBAL_MEMORY_DIR="${HOME}/.claude/devforge-global-memory"
# Max bytes read per file (keep well under any payload truncation threshold)
GLOBAL_MEMORY_MAX_BYTES=2000
# Hard cap on number of files to prevent prompt flooding
GLOBAL_MEMORY_MAX_FILES=20
global_memory_section=""
if [ -d "$GLOBAL_MEMORY_DIR" ]; then
    global_memory_parts=""
    global_memory_file_count=0
    shopt -s nullglob
    for mf in "${GLOBAL_MEMORY_DIR}"/*.md; do
        # Skip symlinks — prevents local info-disclosure via ~/.claude/devforge-global-memory/evil.md -> /etc/passwd
        [ -L "$mf" ] && continue
        # Hard cap on number of files
        [ "$global_memory_file_count" -ge "$GLOBAL_MEMORY_MAX_FILES" ] && break
        fname="$(basename "$mf")"
        # Skip the index file (case-insensitive) — bash 3.2 compatible
        case "$fname" in [Mm][Ee][Mm][Oo][Rr][Yy].md) continue ;; esac
        content=$(head -c "$GLOBAL_MEMORY_MAX_BYTES" "$mf" 2>/dev/null || echo "")
        [ -z "$content" ] && continue
        content_escaped=$(escape_for_json "$content")
        global_memory_parts="${global_memory_parts}\\n---\\n${content_escaped}"
        global_memory_file_count=$((global_memory_file_count + 1))
    done
    shopt -u nullglob
    if [ -n "$global_memory_parts" ]; then
        global_memory_section="\\n\\n**Global DevForge Memory (cross-project — si applica a TUTTI i repo):**${global_memory_parts}"
    fi
fi
# --- End global memory ---

# P-banner: se python3 manca, banner ESPLICITO e prominente in additional_context
# (in cima, prima dello stato versione). Solo avviso visibile, nessun blocco operazioni.
python3_banner_section=""
_py3_raw="$(devforge_python3_banner 2>/dev/null || true)"
if [ -n "$_py3_raw" ]; then
    python3_banner_section="$(escape_for_json "$_py3_raw")\\n\\n"
fi

session_context="<EXTREMELY_IMPORTANT>\nHai siae-devforge.\n\n${python3_banner_section}${version_status_escaped}${branching_section}\n\n**Below is the content of your 'siae-devforge:using-devforge' meta-skill - the DevForge backbone for skill activation. For all other skills, use the 'Skill' tool:**\n\n${using_devforge_escaped}${catalog_section}${global_memory_section}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# additional_context is the canonical field for Claude Code hooks.
# hookSpecificOutput carries only metadata (no payload duplication).
cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart"
  }
}
EOF

# Defence-in-depth: clear session_end guard BEFORE any call that can crash
# (e.g. devforge_log_timed on macOS < 26). Without this, a stale guard from
# a crashed session prevents session_end from firing in ALL subsequent sessions.
rm -rf "${HOME}/.claude/.devforge-session-end-guard"

# Cache resolved user for non-git contexts (F3: fix user "unknown")
rm -f "${HOME}/.claude/.devforge-session-user" "${HOME}/.claude/.devforge-session-user-source"
RESOLVED_USER_RAW=$(devforge_get_user_raw)
RESOLVED_USER_SOURCE=$(devforge_get_user_source)
devforge_cache_user "$RESOLVED_USER_RAW" "$RESOLVED_USER_SOURCE"

# Log session start event
SAFE_PROJECT_DIR=$(devforge_sanitize_json_str "$(pwd)")
SAFE_PLUGIN_VERSION=$(devforge_sanitize_json_str "$PLUGIN_VERSION")
devforge_log_timed "session_start" "success" "$START_NS" "{\"project_dir\":\"${SAFE_PROJECT_DIR}\",\"plugin_version\":\"${SAFE_PLUGIN_VERSION}\",\"identity\":${IDENTITY_BUNDLE}}"

# gate_bypassed (Layer 1) — il kill-switch globale altrimenti non lascia traccia.
# DOPO l'emissione dello stdout additional_context (riga ~291): nessun rischio di
# abortire il JSON. best-effort + pipefail-safe + nessun output su stdout.
if [ "${DEVFORGE_ENFORCEMENT_OFF:-0}" = "1" ]; then
    devforge_log "gate_bypassed" "warning" \
        '{"mechanism":"enforcement_off","scope":"session"}' >/dev/null 2>&1 || true
fi

# Save session start timestamp for duration calculation in session_end
echo "$START_NS" > "${HOME}/.claude/.devforge-session-start-ns"

# Opportunistic flush of any local backlog, including the fresh session_start event.
source "${PLUGIN_ROOT}/lib/telemetry-upload.sh" 2>/dev/null || true
devforge_upload_logs 2>/dev/null || true

# F4: Detect PR merges in last 24h — use explicit --repo from git remote
if command -v gh >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    GH_REPO=$(git remote get-url origin 2>/dev/null \
        | sed 's/\.git$//' | grep -oE '[^/:]+/[^/]+$' || echo "")

    if [ -n "$GH_REPO" ]; then
        USER_EMAIL="$RESOLVED_USER_RAW"
        MERGED_PRS=$(net_run 8 gh pr list --repo "$GH_REPO" --state merged --author "@me" \
            --json number,mergedAt,createdAt,reviews \
            --jq '[.[] | select((.mergedAt | fromdateiso8601) > (now - 86400))]' 2>/dev/null || echo "[]")

        if [ "$MERGED_PRS" != "[]" ] && [ -n "$MERGED_PRS" ]; then
            SEEN_FILE="${HOME}/.claude/.devforge-seen-pr-merges"
            touch "$SEEN_FILE"
            echo "$MERGED_PRS" | jq -c '.[]' 2>/dev/null | while IFS= read -r pr; do
                PR_NUMBER=$(echo "$pr" | jq -r '.number' 2>/dev/null || echo "0")
                if grep -qF "${GH_REPO}#${PR_NUMBER}" "$SEEN_FILE" 2>/dev/null; then continue; fi
                CREATED_AT=$(echo "$pr" | jq -r '.createdAt' 2>/dev/null || echo "")
                MERGED_AT=$(echo "$pr" | jq -r '.mergedAt' 2>/dev/null || echo "")
                REVIEWERS_COUNT=$(echo "$pr" | jq '[.reviews[]? | .author.login] | unique | length' 2>/dev/null || echo "0")

                REVIEW_CYCLE_HOURS="0"
                if [ -n "$CREATED_AT" ] && [ -n "$MERGED_AT" ]; then
                    CREATED_EPOCH=$(date -jf "%Y-%m-%dT%H:%M:%SZ" "$CREATED_AT" +%s 2>/dev/null || date -d "$CREATED_AT" +%s 2>/dev/null || echo "0")
                    MERGED_EPOCH=$(date -jf "%Y-%m-%dT%H:%M:%SZ" "$MERGED_AT" +%s 2>/dev/null || date -d "$MERGED_AT" +%s 2>/dev/null || echo "0")
                    if [ "$CREATED_EPOCH" != "0" ] && [ "$MERGED_EPOCH" != "0" ]; then
                        DELTA_SECONDS=$((MERGED_EPOCH - CREATED_EPOCH))
                        REVIEW_CYCLE_HOURS=$(echo "scale=1; $DELTA_SECONDS / 3600" | bc 2>/dev/null || echo "0")
                    fi
                fi

                devforge_log "pr_merged" "success" \
                    "{\"pr_number\":${PR_NUMBER},\"review_cycle_hours\":${REVIEW_CYCLE_HOURS},\"reviewers_count\":${REVIEWERS_COUNT}}"
                echo "${GH_REPO}#${PR_NUMBER}" >> "$SEEN_FILE"
                tail -200 "$SEEN_FILE" > "${SEEN_FILE}.tmp" && mv "${SEEN_FILE}.tmp" "$SEEN_FILE"
            done
        fi
    fi
fi

# Session lock: detect concurrent sessions sharing state files
SESSION_LOCK_FILE="${HOME}/.claude/.devforge-session-lock"
CURRENT_PID=$$
if [ -f "$SESSION_LOCK_FILE" ]; then
    OLD_PID=$(cat "$SESSION_LOCK_FILE" 2>/dev/null || echo "0")
    # Check if old session is still running (kill -0 tests existence)
    if kill -0 "$OLD_PID" 2>/dev/null && [ "$OLD_PID" != "$CURRENT_PID" ]; then
        devforge_log "session_conflict" "warning" "{\"reason\":\"concurrent_session_detected\",\"old_pid\":${OLD_PID},\"new_pid\":${CURRENT_PID}}"
    fi
fi
echo "$CURRENT_PID" > "$SESSION_LOCK_FILE"

# Initialize session counters and cleanup stale guards.
# Remove session_end guard so the next stop-gate can emit session_end.
# Without this cleanup, a stale guard from a crashed session would prevent
# session_end telemetry from firing.
echo "0" > "${HOME}/.claude/.devforge-session-commits"
# F2: Init last commit hash for commit_created detection
# v1.63.3: LAST_HASH_FILE è per-repo (era globale → inflazione cross-repo).
# Allinea path al fix di hooks/post-commit-review:36.
_SS_GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
if [ -n "$_SS_GIT_ROOT" ]; then
    _SS_REPO_KEY=$(echo "$_SS_GIT_ROOT" | shasum 2>/dev/null | awk '{print $1}' | head -c 16)
    _SS_LAST_HASH_FILE="${HOME}/.claude/.devforge-last-commit-hash-${_SS_REPO_KEY:-global}"
else
    _SS_LAST_HASH_FILE="${HOME}/.claude/.devforge-last-commit-hash-nogit"
fi
git rev-parse HEAD > "$_SS_LAST_HASH_FILE" 2>/dev/null || echo "" > "$_SS_LAST_HASH_FILE"
unset _SS_GIT_ROOT _SS_REPO_KEY _SS_LAST_HASH_FILE

# Preserve session-skills on resume|clear|compact (logical same session).
# Read source from stdin payload (Claude Code sends JSON with `source` field).
# Only reset on true `startup` to preserve skill invocation history across
# auto-compact events — fixes recurring sub-skill-gate false positives.
SESSION_START_SOURCE=""
if [ ! -t 0 ]; then
    STDIN_PAYLOAD=$(cat 2>/dev/null || echo "")
    if [ -n "$STDIN_PAYLOAD" ] && command -v jq >/dev/null 2>&1; then
        SESSION_START_SOURCE=$(echo "$STDIN_PAYLOAD" | jq -r '.source // empty' 2>/dev/null || echo "")
    fi
fi
case "$SESSION_START_SOURCE" in
    startup)
        # Fresh session — reset skills invoked
        echo "" > "${HOME}/.claude/.devforge-session-skills"
        # Osservabilità identità SSO: emette identity_unresolved / identity_external_domain
        # una sola volta per sessione logica (solo su startup, non resume/clear/compact).
        devforge_emit_identity_observability
        ;;
    resume|clear|compact)
        # Same logical session — preserve skills invoked so far
        devforge_log "session_start_preserved_skills" "success" "{\"source\":\"${SESSION_START_SOURCE}\"}" 2>/dev/null || true
        ;;
    *)
        # Empty or unknown source (Claude Code auto-compact without JSON
        # payload, IDE relaunch, or non-interactive harness). Default to
        # PRESERVE — resetting mid-work is the more damaging failure mode:
        # it makes gate hooks blind to skills already invoked, blocking
        # legitimate commits and forcing the user to re-invoke skills.
        # The alternative (over-preservation across a real cold start) is
        # visible and self-correcting: a stale entry is noise, a missing
        # entry is a hard block.
        devforge_log "session_start_preserved_skills" "success" "{\"source\":\"unknown\",\"reason\":\"default_preserve\"}" 2>/dev/null || true
        ;;
esac
echo "0" > "${HOME}/.claude/.devforge-tool-counter"
echo "0" > "${HOME}/.claude/.devforge-message-counter"
# (guard cleanup moved before devforge_log_timed call, after EOF output)
# Reset TDD state machine and coverage for new session
rm -f "${HOME}/.claude/.devforge-tdd-state"
rm -f "${HOME}/.claude/.devforge-last-coverage"
rm -f "${HOME}/.claude/.devforge-retro-reminded" 2>/dev/null
rm -f "${HOME}/.claude/.devforge-skill-start"

# Cleanup stale sentinel files (older than 24h) in working directory
STALE_AGE=86400
NOW=$(date +%s)
shopt -s nullglob
for sentinel in .devforge-active-*; do
    MTIME=$(stat -f%m "$sentinel" 2>/dev/null || stat -c%Y "$sentinel" 2>/dev/null || echo "0")
    if [ $((NOW - MTIME)) -gt "$STALE_AGE" ]; then
        SAFE_SENTINEL=$(devforge_sanitize_json_str "$sentinel")
        devforge_log "session_start_cleanup" "info" "{\"file\":\"${SAFE_SENTINEL}\",\"age_hours\":$(( (NOW - MTIME) / 3600 ))}"
        rm -f "$sentinel"
    fi
done
shopt -u nullglob

# E40: cleanup stale review-evidence cache (>7 days).
# The hook writes one JSON per SHA so on busy repos the cache grows
# unbounded; keep only the last 7 days. Both the primary
# (.claude/review-evidence/) and the iCloud fallback
# (~/.claude/review-evidence-fallback/) are pruned.
shopt -s nullglob
REVIEW_EVIDENCE_LOCAL="${PWD}/.claude/review-evidence"
if [ -d "$REVIEW_EVIDENCE_LOCAL" ]; then
    find "$REVIEW_EVIDENCE_LOCAL" -maxdepth 1 -name '*.json' -mtime +7 -delete 2>/dev/null || true
    # Also clean orphaned lock dirs (E03) older than 1h
    find "$REVIEW_EVIDENCE_LOCAL" -maxdepth 1 -type d -name '*.lock' -mmin +60 -exec rm -rf {} + 2>/dev/null || true
    # Clean iCloud placeholders older than 7d (their primaries are gone too).
    find "$REVIEW_EVIDENCE_LOCAL" -maxdepth 1 -name '.*.json.icloud' -mtime +7 -delete 2>/dev/null || true
fi
REVIEW_EVIDENCE_FALLBACK="${HOME}/.claude/review-evidence-fallback"
if [ -d "$REVIEW_EVIDENCE_FALLBACK" ]; then
    find "$REVIEW_EVIDENCE_FALLBACK" -mindepth 2 -maxdepth 2 -name '*.json' -mtime +7 -delete 2>/dev/null || true
fi
shopt -u nullglob

# Cleanup session state directories older than 48h (preserve pending outbox)
if [ -d "${HOME}/.claude/devforge-state" ]; then
    for session_dir in "${HOME}/.claude/devforge-state"/*/; do
        [ -d "$session_dir" ] || continue
        DIR_MTIME=$(stat -f%m "$session_dir" 2>/dev/null || stat -c%Y "$session_dir" 2>/dev/null || echo "0")
        DIR_AGE=$(( $(date +%s) - DIR_MTIME ))
        [ "$DIR_AGE" -lt 172800 ] && continue
        PENDING_COUNT=$(find "$session_dir/outbox" -maxdepth 1 -name '*.jsonl' 2>/dev/null | grep -cv '/acked/' || echo "0")
        if [ "$PENDING_COUNT" -gt 0 ]; then
            continue
        fi
        rm -rf "$session_dir"
    done
fi

exit 0
