#!/usr/bin/env bash
# PreToolUse hook: BLOCCA Edit/Write su codice produzione senza siae-tdd
# ─────────────────────────────────────────────────────────────────
# Hook:     tdd-gate
# Evento:   PreToolUse
# Matcher:  Edit, Write
# Timeout:  5s
# Formato:  decision:"block" se siae-tdd non invocata (HARD GATE)
# History:  v1.3.0 ALLOW+warn → v1.4.0 BLOCK → v1.47.0 task-scoped (ADR-001+005)
#
# Task-scoped enforcement (PR #2 ADR-001):
#   Instead of trusting "skill invoked once per session", the gate computes
#   task_id = sha256(branch|latest-design-doc|mtime)[:12] and asks
#   devforge_skill_validated(siae-tdd, task_id). A session can span N
#   tasks — each needs its own TDD validation.
#
# Fallback: DEVFORGE_USE_SESSION_SCOPE=1 restores legacy session-scoped
# behavior (per-sid grep on .devforge-session-skills).
# ─────────────────────────────────────────────────────────────────

set -euo pipefail
export DEVFORGE_CURRENT_HOOK="tdd-gate"

HOOK_INPUT=$(cat)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${PLUGIN_ROOT}/lib/logger.sh" 2>/dev/null || true
# Track which libs actually loaded — a missing task-id.sh silently degrades
# the gate to session-scope, which we want to record in telemetry.
_LIB_MISSING=""
source "${PLUGIN_ROOT}/lib/file-taxonomy.sh" 2>/dev/null || _LIB_MISSING="${_LIB_MISSING}file-taxonomy "
source "${PLUGIN_ROOT}/lib/task-id.sh"       2>/dev/null || _LIB_MISSING="${_LIB_MISSING}task-id "
source "${PLUGIN_ROOT}/lib/evidence-check.sh" 2>/dev/null || _LIB_MISSING="${_LIB_MISSING}evidence-check "
source "${PLUGIN_ROOT}/lib/block-explainer.sh" 2>/dev/null || true
if [ -n "$_LIB_MISSING" ] && command -v devforge_log >/dev/null 2>&1; then
    devforge_log "hook_degraded" "warning" \
        "{\"hook\":\"tdd-gate\",\"missing\":\"${_LIB_MISSING% }\"}" 2>/dev/null || true
fi

# Extract file_path from tool input
if command -v jq >/dev/null 2>&1; then
    FILE_PATH=$(echo "$HOOK_INPUT" | jq -r '.file_path // .tool_input.file_path // empty' 2>/dev/null || true)
else
    FILE_PATH=$(echo "$HOOK_INPUT" | grep -o '"file_path"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"file_path"[[:space:]]*:[[:space:]]*"//;s/"$//' || true)
fi

if [ -z "$FILE_PATH" ]; then
    echo '{}'
    exit 0
fi

# Normalize relative → absolute (claude tool may pass either)
if [[ "$FILE_PATH" != /* ]]; then
    FILE_PATH="$(pwd)/${FILE_PATH#./}"
fi

# Walk up from FILE_PATH's directory to the nearest existing ancestor so
# Write on a not-yet-created directory still resolves a git root.
FILE_DIR="$(dirname "$FILE_PATH")"
while [ -n "$FILE_DIR" ] && [ ! -d "$FILE_DIR" ]; do
    FILE_DIR="$(dirname "$FILE_DIR")"
done
if [ -z "$FILE_DIR" ]; then
    echo '{}'
    exit 0
fi
FILE_GIT_ROOT="$(git -C "$FILE_DIR" rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$FILE_GIT_ROOT" ]; then
    echo '{}'
    exit 0
fi

# Scope: itsiae/* only (same policy as compute_task_id)
REMOTE_URL="$(git -C "$FILE_GIT_ROOT" remote get-url origin 2>/dev/null || true)"
if ! echo "$REMOTE_URL" | grep -qE "[/:]itsiae/"; then
    echo '{}'
    exit 0
fi

# File-taxonomy decides whether this path triggers TDD. Falls back to the
# legacy inline regex if file-taxonomy.sh failed to source (defense in depth).
if command -v devforge_file_requires_tdd >/dev/null 2>&1; then
    if ! devforge_file_requires_tdd "$FILE_PATH"; then
        echo '{}'
        exit 0
    fi
else
    PROD_EXTENSIONS="\.java$|\.ts$|\.tsx$|\.js$|\.jsx$|\.py$|\.vue$|\.go$|\.kt$"
    EXCLUDED_PATHS="test/|tests/|__tests__|spec/|Test\.(java|kt)$|IT\.(java|kt)$|\.spec\.|\.test\.|test_.*\.py$|_test\.go$|docs/|plans/|SKILL\.md|CLAUDE\.md|\.md$|evals/"
    if ! echo "$FILE_PATH" | grep -qE "$PROD_EXTENSIONS"; then echo '{}'; exit 0; fi
    if echo "$FILE_PATH" | grep -qE "$EXCLUDED_PATHS"; then echo '{}'; exit 0; fi
fi

# ─── Skill check: task-scoped (default) with session-scoped rollback ───
SESSION_SKILLS_FILE="${HOME}/.claude/.devforge-session-skills"
SESSION_SKILLS=$(cat "$SESSION_SKILLS_FILE" 2>/dev/null || echo "")

# Is the skill recorded at all (either scope)?
SKILL_INVOKED=0
if echo "$SESSION_SKILLS" | grep -qF "siae-tdd"; then
    SKILL_INVOKED=1
fi

# Task-scoped layer: if the primitives are available and rollback is NOT
# set, require that siae-tdd was validated inside the current task_id.
USE_SESSION_SCOPE="${DEVFORGE_USE_SESSION_SCOPE:-0}"
TASK_ID=""
if [ "$USE_SESSION_SCOPE" != "1" ] && command -v devforge_compute_task_id >/dev/null 2>&1; then
    TASK_ID=$(cd "$FILE_GIT_ROOT" && devforge_compute_task_id 2>/dev/null || echo "")
    if [ -n "$TASK_ID" ] && command -v devforge_task_skill_invoked >/dev/null 2>&1; then
        # Dual-write: record session skill invocations into the per-task
        # ledger so later checks find the evidence. Idempotent.
        if [ "$SKILL_INVOKED" = "1" ]; then
            devforge_task_skill_invoked "$TASK_ID" siae-tdd 2>/dev/null || true
        fi
    fi
fi

if [ "$SKILL_INVOKED" = "1" ]; then
    # siae-tdd invocata — check TDD phase state machine
    TDD_STATE_FILE="${HOME}/.claude/.devforge-tdd-state"
    TDD_STATE=$(cat "$TDD_STATE_FILE" 2>/dev/null || echo "")
    TDD_PHASE=$(echo "$TDD_STATE" | cut -d'|' -f1)

    # TDD Phase State Machine:
    #   INIT = siae-tdd invocata, nessun test scritto/eseguito → BLOCCA codice prod
    #   RED  = test scritto e FALLITO (confermato) → PERMETTI codice prod (passo GREEN)
    #   GREEN = test passa → PERMETTI (refactor o nuovo ciclo)
    #   REFACTOR = refactor in corso → PERMETTI
    #   empty/unknown = nessuno stato → PERMETTI (graceful)
    if [ "$TDD_PHASE" = "INIT" ]; then
        devforge_init_session 2>/dev/null || true
        BASENAME=$(basename "$FILE_PATH")
        SAFE_FILE_PATH=$(devforge_sanitize_json_str "$FILE_PATH")
        devforge_log "tdd_gate" "blocked" "{\"file_path\":\"${SAFE_FILE_PATH}\",\"phase\":\"INIT\",\"violation\":\"prod_code_before_test\",\"task_id\":\"${TASK_ID}\"}"

        cat <<PHASE_EOF
{
  "decision": "block",
  "reason": "DevForge TDD Phase Gate — BLOCCATO. Hai invocato siae-tdd ma non hai ancora un test fallente. Scrivi PRIMA il test per ${BASENAME}, eseguilo (deve fallire → fase RED), poi potrai scrivere il codice di produzione."
}
PHASE_EOF
        exit 0
    fi

    # Evidence-based check (task-scoped only — session-scoped fallback keeps
    # legacy behavior where invocation alone is enough).
    if [ -n "$TASK_ID" ] && [ "$USE_SESSION_SCOPE" != "1" ] \
       && command -v devforge_skill_validated >/dev/null 2>&1; then
        if ! devforge_skill_validated siae-tdd "$TASK_ID" 2>/dev/null; then
            # Invoked but no RED→GREEN transition observed for THIS task.
            # Keep allow-with-log: phase-gate above already blocks INIT,
            # and RED/GREEN/REFACTOR pass through. Emit divergence event so
            # shadow analysis can measure dual-write delta.
            devforge_log "tdd_gate_task_divergence" "info" \
                "{\"task_id\":\"${TASK_ID}\",\"session_allow\":true,\"task_validated\":false}" 2>/dev/null || true
        fi
    fi

    # RED / GREEN / REFACTOR / empty → allow
    echo '{}'
    exit 0
fi

# siae-tdd NOT invoked — BLOCK (hard gate)
devforge_init_session 2>/dev/null || true
SAFE_FILE_PATH=$(devforge_sanitize_json_str "$FILE_PATH")
devforge_log "tdd_gate" "blocked" "{\"file_path\":\"${SAFE_FILE_PATH}\",\"skill_missing\":\"siae-tdd\",\"task_id\":\"${TASK_ID}\"}"

BASENAME=$(basename "$FILE_PATH")
EXPLAINER=""
if command -v devforge_block_explainer >/dev/null 2>&1; then
    EXPLAINER=$(devforge_block_explainer siae-tdd || true)
    [ -n "$EXPLAINER" ] && EXPLAINER=" ${EXPLAINER}"
fi

cat <<EOF
{
  "decision": "block",
  "reason": "DevForge TDD Gate — BLOCCATO. Stai modificando codice di produzione (${BASENAME}) ma NON hai invocato siae-tdd in questa sessione. La Legge di Ferro: TEST PRIMA DEL CODICE, SEMPRE. Invoca siae-tdd PRIMA di scrivere codice di produzione: Skill tool -> siae-devforge:siae-tdd. Dopo aver invocato la skill, potrai procedere.${EXPLAINER}"
}
EOF
exit 0
