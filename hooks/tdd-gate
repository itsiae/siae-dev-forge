#!/usr/bin/env bash
# PreToolUse hook: BLOCCA Edit/Write su codice produzione senza siae-tdd
# ─────────────────────────────────────────────────────────────────
# Hook:     tdd-gate
# Evento:   PreToolUse
# Matcher:  Edit, Write
# Timeout:  5s — Solo check file flat + estensione
# Formato:  decision:"block" se siae-tdd non invocata (HARD GATE)
# History:  v1.3.0 ALLOW+warn → v1.4.0 BLOCK (determinismo SDLC)
# ─────────────────────────────────────────────────────────────────

set -euo pipefail

HOOK_INPUT=$(cat)

# Extract file_path from tool input (jq handles escaped quotes in paths with spaces)
if command -v jq >/dev/null 2>&1; then
    FILE_PATH=$(echo "$HOOK_INPUT" | jq -r '.file_path // .tool_input.file_path // empty' 2>/dev/null || true)
else
    FILE_PATH=$(echo "$HOOK_INPUT" | grep -o '"file_path"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"file_path"[[:space:]]*:[[:space:]]*"//;s/"$//' || true)
fi

if [ -z "$FILE_PATH" ]; then
    echo '{}'
    exit 0
fi

# Normalize relative paths to absolute so gating is deterministic.
# Claude can provide either relative or absolute file_path depending on tool flow.
if [[ "$FILE_PATH" != /* ]]; then
    FILE_PATH="$(pwd)/${FILE_PATH#./}"
fi

# Skip files not inside any git repository (temp scripts, /tmp/, one-shot generators).
# Use the FILE's git root, not the hook dir — the hook runs from ~/.claude/plugins/ (non-git dir).
# Walk up from FILE_PATH's directory to the nearest existing ancestor before calling git,
# so that Write tool calls for new files in not-yet-created directories are handled correctly.
FILE_DIR="$(dirname "$FILE_PATH")"
while [ -n "$FILE_DIR" ] && [ ! -d "$FILE_DIR" ]; do
    FILE_DIR="$(dirname "$FILE_DIR")"
done
if [ -z "$FILE_DIR" ]; then
    echo '{}'
    exit 0
fi
FILE_GIT_ROOT="$(git -C "$FILE_DIR" rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$FILE_GIT_ROOT" ]; then
    echo '{}'
    exit 0
fi

# Gate applies only to SIAE repos (itsiae org on GitHub).
# Personal projects, forks, and unrelated repos are excluded.
# Use [/:]itsiae/ to match both HTTPS (/itsiae/) and SSH (:itsiae/) remotes,
# avoiding false positives from orgs whose name ends with "itsiae" (e.g. notitsiae).
REMOTE_URL="$(git -C "$FILE_GIT_ROOT" remote get-url origin 2>/dev/null || true)"
if ! echo "$REMOTE_URL" | grep -qE "[/:]itsiae/"; then
    echo '{}'
    exit 0
fi

# Check if file is production code with testable runtime behavior.
# IaC (.tf, .hcl), config, CI, and docs are validated via plan/lint, NOT TDD.
PROD_EXTENSIONS="\.java$|\.ts$|\.tsx$|\.js$|\.jsx$|\.py$|\.vue$|\.go$|\.kt$"
if ! echo "$FILE_PATH" | grep -qE "$PROD_EXTENSIONS"; then
    echo '{}'
    exit 0
fi

# Exclude test files and non-production paths
EXCLUDED_PATHS="test/|tests/|__tests__|spec/|Test\.(java|kt)$|IT\.(java|kt)$|\.spec\.|\.test\.|test_.*\.py$|_test\.go$|docs/|plans/|SKILL\.md|CLAUDE\.md|\.md$|evals/"
if echo "$FILE_PATH" | grep -qE "$EXCLUDED_PATHS"; then
    echo '{}'
    exit 0
fi

# Check if siae-tdd was invoked this session
SESSION_SKILLS_FILE="${HOME}/.claude/.devforge-session-skills"
SESSION_SKILLS=$(cat "$SESSION_SKILLS_FILE" 2>/dev/null || echo "")

if echo "$SESSION_SKILLS" | grep -qF "siae-tdd"; then
    # siae-tdd invoked — check TDD phase state machine
    TDD_STATE_FILE="${HOME}/.claude/.devforge-tdd-state"
    TDD_STATE=$(cat "$TDD_STATE_FILE" 2>/dev/null || echo "")
    TDD_PHASE=$(echo "$TDD_STATE" | cut -d'|' -f1)

    # TDD Phase State Machine:
    #   INIT = siae-tdd invocata, nessun test scritto/eseguito → BLOCCA codice prod
    #   RED  = test scritto e FALLITO (confermato) → PERMETTI codice prod (è il passo GREEN)
    #   GREEN = test passa → PERMETTI (refactor o nuovo ciclo)
    #   REFACTOR = refactor in corso → PERMETTI
    #   empty/unknown = nessuno stato → PERMETTI (graceful)
    if [ "$TDD_PHASE" = "INIT" ]; then
        # INIT phase: siae-tdd invocata ma nessun test fallente ancora
        # BLOCCA codice produzione — prima devi scrivere un test e vederlo fallire
        SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
        PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
        source "${PLUGIN_ROOT}/lib/logger.sh"
        BASENAME=$(basename "$FILE_PATH")
        devforge_log "tdd_gate" "blocked" "{\"file_path\":\"${FILE_PATH}\",\"phase\":\"INIT\",\"violation\":\"prod_code_before_test\"}"

        cat <<PHASE_EOF
{
  "decision": "block",
  "reason": "DevForge TDD Phase Gate — BLOCCATO. Hai invocato siae-tdd ma non hai ancora un test fallente. Scrivi PRIMA il test per ${BASENAME}, eseguilo (deve fallire → fase RED), poi potrai scrivere il codice di produzione."
}
PHASE_EOF
        exit 0
    fi

    # RED (test fallente confermato), GREEN, REFACTOR, empty → allow production code edits
    echo '{}'
    exit 0
fi

# siae-tdd NOT invoked — BLOCK operation (hard gate)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${PLUGIN_ROOT}/lib/logger.sh"
devforge_log "tdd_gate" "blocked" "{\"file_path\":\"${FILE_PATH}\",\"skill_missing\":\"siae-tdd\"}"

BASENAME=$(basename "$FILE_PATH")

cat <<EOF
{
  "decision": "block",
  "reason": "DevForge TDD Gate — BLOCCATO. Stai modificando codice di produzione (${BASENAME}) ma NON hai invocato siae-tdd in questa sessione. La Legge di Ferro: TEST PRIMA DEL CODICE, SEMPRE. Invoca siae-tdd PRIMA di scrivere codice di produzione: Skill tool -> siae-devforge:siae-tdd. Dopo aver invocato la skill, potrai procedere con la modifica."
}
EOF
exit 0
